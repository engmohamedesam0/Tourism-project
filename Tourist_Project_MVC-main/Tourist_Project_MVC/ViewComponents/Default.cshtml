@model Tourist_Project_MVC.View_Model.NotificationBellVM

<button type="button"
        id="notificationBellBtn"
        class="ai-fab notification-bell"
        data-bs-toggle="modal"
        data-bs-target="#notificationPanelModal"
        aria-label="Notifications"
        style="top: 22px; right: 22px; width: 48px; height: 48px; font-size: 1.2rem; z-index: 1041;">
    <i class="bi bi-bell-fill"></i>
    @if (Model.UnreadCount > 0)
    {
        <span class="notification-badge" id="notificationBadge">@Model.UnreadCount</span>
    }
</button>

<div class="modal fade" id="notificationPanelModal" tabindex="-1"
     aria-labelledby="notificationPanelModalLabel" aria-hidden="true">
    <div class="modal-dialog ai-modal-dialog notification-panel">
        <div class="modal-content ai-modal">
            <div class="modal-header ai-modal-header">
                <h5 class="modal-title" id="notificationPanelModalLabel">
                    <i class="bi bi-bell-fill me-2"></i> Notifications
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body ai-modal-body" id="notificationPanelBody" style="max-height: 60vh; overflow-y: auto; align-items: flex-start; justify-content: flex-start;">
                <div class="text-center w-100 py-4">
                    <div class="spinner-border text-warning" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer ai-modal-footer">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Index">View All</a>
                <a class="btn btn-sm btn-outline-success" asp-action="Support">Support</a>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var bellBtn = document.getElementById('notificationBellBtn');
        if (!bellBtn) return;

        bellBtn.addEventListener('click', function () {
            loadPanel();
        });

        var modalEl = document.getElementById('notificationPanelModal');
        modalEl.addEventListener('hidden.bs.modal', function () {
            document.getElementById('notificationPanelBody').innerHTML =
                '<div class="text-center w-100 py-4"><div class="spinner-border text-warning" role="status"><span class="visually-hidden">Loading...</span></div></div>';
        });

        function loadPanel() {
            fetch('@Url.Action("Panel", "SponsorNotification")')
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    document.getElementById('notificationPanelBody').innerHTML = html;
                })
                .catch(function () {
                    document.getElementById('notificationPanelBody').innerHTML = '<div class="alert alert-danger m-3">Failed to load notifications.</div>';
                });
        }
    })();
</script>
