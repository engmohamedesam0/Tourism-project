@model IEnumerable<Tourist_Project_MVC.Models.Destination>

@{
    ViewData["Title"] = "Explore";
    ViewData["IsHomePage"] = true;
}

<div class="explore-page">
    <div class="container-fluid">
        <div class="row g-0">

            <!-- LEFT PANEL: list + filters -->
            <div class="col-lg-5 col-xl-4 explore-list-panel">

                <div class="explore-header">
                    <h2 class="page-title mb-0">🧭 @Localizer["Explore_Title"].Value</h2>
                    <p class="text-muted small mb-0">@Localizer["Explore_Subtitle"].Value</p>
                </div>

                <!-- Search box (reuses Destination admin search pattern) -->
                <div class="explore-search">
                    <form method="get" asp-action="Index" id="exploreSearchForm">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text"
                                   name="search"
                                   id="exploreSearch"
                                   class="form-control border-start-0"
                                   placeholder="@Localizer["Explore_SearchPlaceholder"].Value"
                                   value="@ViewBag.Search" />
                        </div>
                    </form>
                </div>

                <!-- Category filter chips -->
                <!-- NOTE: The requested chip labels do not map 1:1 to the Category
                     values that actually exist in the data. Existing Category values are:
                     Archaeological, Temple, Museum, Natural, Historical, Religious.
                     Mapping used here (clearly documented for review):
                       • Temples  -> Category "Temple"
                       • Museums  -> Category "Museum"
                       • Nature   -> Category "Natural"
                       • Hidden Gems -> destinations with Status "Pending" (lesser-known/upcoming)
                       • Adventure -> no matching Category in data; mapped to "Archaeological"
                                     (closest adventurous/excavation vibe). CONFIRM / adjust.
                -->
                <div class="category-chips" id="categoryChips">
                    <button type="button" class="chip chip-active" data-filter="all">@Localizer["Explore_All"].Value</button>
                    <button type="button" class="chip" data-filter="Hidden Gems" data-status="Pending">@Localizer["Explore_HiddenGems"].Value</button>
                    <button type="button" class="chip" data-filter="Temples" data-category="Temple">@Localizer["Explore_Temples"].Value</button>
                    <button type="button" class="chip" data-filter="Museums" data-category="Museum">@Localizer["Explore_Museums"].Value</button>
                    <button type="button" class="chip" data-filter="Nature" data-category="Natural">@Localizer["Explore_Nature"].Value</button>
                    <button type="button" class="chip" data-filter="Adventure" data-category="Archaeological">@Localizer["Explore_Adventure"].Value</button>
                </div>

                <!-- Scrollable destination list -->
                <div class="explore-list" id="exploreList">
                    @foreach (var item in Model)
                    {
                        <div class="explore-card stat-card"
                             data-id="@item.Id"
                             data-lat="@item.Location.Y"
                             data-lng="@item.Location.X"
                             data-category="@item.Category"
                             data-status="@item.Status"
                             data-name="@item.Name">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="explore-card-title mb-0">@item.Name</h5>
                                @if (item.Rating.HasValue)
                                {
                                    <span class="rating-badge" title="Average rating">
                                        <i class="bi bi-star-fill"></i> @item.Rating.Value.ToString("0.0")
                                    </span>
                                }
                                else
                                {
                                     <span class="rating-badge rating-new" title="@Localizer["Explore_NotRated"].Value">@Localizer["Explore_New"].Value</span>
                                }
                            </div>

                            <div class="explore-card-city text-muted small mb-2">
                                <i class="bi bi-geo-alt-fill"></i> @item.City
                            </div>

                            <span class="badge-category">@item.Category</span>

                            <p class="explore-card-desc small mt-2 mb-2">
                                @(item.Description?.Length > 90 ? item.Description.Substring(0, 90) + "…" : item.Description)
                            </p>

                            @if (!string.IsNullOrWhiteSpace(item.Tags))
                            {
                                <div class="explore-tags">
                                    @foreach (var tag in item.Tags.Split(','))
                                    {
                                        <span class="tag-pill">@tag.Trim()</span>
                                    }
                                </div>
                            }

                            <div class="mt-2">
                                 <a asp-controller="Destination" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye-fill me-1"></i> @Localizer["Explore_Details"].Value
                                </a>
                            </div>
                        </div>
                    }

                    @if (!Model.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-geo-alt" style="font-size: 2.5rem; color: var(--egy-primary);"></i>
                            <p class="mt-2 mb-0">@Localizer["Explore_NoDestinations"].Value</p>
                        </div>
                    }
                </div>
            </div>

            <!-- RIGHT PANEL: map placeholder -->
            <div class="col-lg-7 col-xl-8 explore-map-panel">
                <div id="exploreMap" class="explore-map-container">
                    <div class="map-watermark">
                        <i class="bi bi-map" style="font-size: 3rem;"></i>
                        <p class="mb-0 mt-2">@Localizer["Explore_MapPlaceholder"].Value</p>
                        <small class="text-muted">@Localizer["Explore_MapNote"].Value</small>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<style>
    .explore-page {
        padding-top: var(--nav-offset);
    }

    .explore-list-panel {
        background: var(--egy-light);
        border-right: 1px solid rgba(200, 131, 42, 0.2);
        height: calc(100vh - var(--nav-offset));
        display: flex;
        flex-direction: column;
    }

    .explore-header {
        padding: 20px 20px 0;
    }

    .explore-search {
        padding: 12px 20px;
    }

    .category-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 0 20px 14px;
        border-bottom: 1px solid rgba(200, 131, 42, 0.15);
    }

    .chip {
        border: 1px solid var(--egy-primary);
        background: #fff;
        color: var(--egy-muted-gold);
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: 'Nunito', sans-serif;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .chip:hover {
            background: var(--egy-accent);
            color: var(--egy-dark);
            border-color: var(--egy-accent);
        }

        .chip-active {
            background: var(--egy-primary);
            color: #fff;
            border-color: var(--egy-primary);
        }

    .explore-list {
        flex: 1;
        overflow-y: auto;
        padding: 16px 20px 40px;
    }

    .explore-card {
        background: #fff;
        border: 1px solid rgba(200, 131, 42, 0.25) !important;
        border-radius: 14px;
        padding: 16px 18px;
        margin-bottom: 14px;
        transition: all 0.3s ease;
    }

        .explore-card:hover {
            background: #fff !important;
            border-color: var(--egy-primary) !important;
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(200, 131, 42, 0.18);
        }

        .explore-card::before {
            display: none;
        }

    .explore-card-title {
        font-family: 'Cinzel', serif;
        color: var(--egy-dark);
        font-size: 1.05rem;
    }

    .rating-badge {
        background: rgba(200, 131, 42, 0.12);
        color: var(--egy-muted-gold);
        border: 1px solid var(--egy-accent);
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: 700;
        white-space: nowrap;
    }

        .rating-badge i {
            color: var(--egy-primary);
        }

    .rating-new {
        background: rgba(30, 18, 10, 0.06);
        color: #888;
        border-color: #ccc;
    }

    .explore-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .tag-pill {
        background: var(--egy-light);
        border: 1px solid rgba(200, 131, 42, 0.35);
        color: var(--egy-muted-gold);
        border-radius: 12px;
        padding: 2px 9px;
        font-size: 0.72rem;
        font-weight: 600;
    }

    .explore-map-panel {
        height: calc(100vh - var(--nav-offset));
        background: #ece6db;
        position: relative;
    }

    .explore-map-container {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            repeating-linear-gradient(45deg, #e7e0d5 0 18px, #efe9df 18px 36px);
    }

    .map-watermark {
        text-align: center;
        color: var(--egy-muted-gold);
        opacity: 0.75;
    }

    @@media (max-width: 991.98px) {
        .explore-list-panel,
        .explore-map-panel {
            height: auto;
        }

        .explore-map-panel {
            min-height: 320px;
            position: relative;
        }

        .explore-map-container {
            position: relative;
            inset: auto;
        }

        .explore-list {
            max-height: 60vh;
        }
    }
</style>

<script>
    (function () {
        var chips = document.querySelectorAll('#categoryChips .chip');
        var cards = Array.from(document.querySelectorAll('#exploreList .explore-card'));

        function applyFilter(chip) {
            var category = chip.getAttribute('data-category');
            var status = chip.getAttribute('data-status');

            cards.forEach(function (card) {
                var match = true;
                if (category) {
                    match = card.getAttribute('data-category') === category;
                } else if (status) {
                    match = card.getAttribute('data-status') === status;
                }
                card.style.display = match ? '' : 'none';
            });
        }

        chips.forEach(function (chip) {
            chip.addEventListener('click', function () {
                chips.forEach(function (c) { c.classList.remove('chip-active'); });
                chip.classList.add('chip-active');
                if (chip.getAttribute('data-filter') === 'all') {
                    cards.forEach(function (c) { c.style.display = ''; });
                } else {
                    applyFilter(chip);
                }
            });
        });

        // Client-side text search (in addition to server search on submit)
        var searchInput = document.getElementById('exploreSearch');
        if (searchInput) {
            searchInput.addEventListener('keyup', function () {
                var q = searchInput.value.trim().toLowerCase();
                cards.forEach(function (card) {
                    var name = (card.getAttribute('data-name') || '').toLowerCase();
                    var cat = (card.getAttribute('data-category') || '').toLowerCase();
                    card.style.display = (!q || name.indexOf(q) > -1 || cat.indexOf(q) > -1) ? '' : 'none';
                });
            });
            searchInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    document.getElementById('exploreSearchForm').submit();
                }
            });
        }
    })();
</script>
}
