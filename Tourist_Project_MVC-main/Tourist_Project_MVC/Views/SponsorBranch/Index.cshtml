@model IEnumerable<Tourist_Project_MVC.Models.Branch>

@{
    ViewData["Title"] = "My Branches";
}

<div class="inner-page-wrapper">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="page-title mb-0">📍 My Branches</h2>
            <a asp-action="Create" class="btn btn-success px-4">
                <i class="bi bi-plus-lg me-1"></i> + Add Branch
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle destinations-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th>Coordinates</th>
                        <th>Phone</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">@i.ToString("D2")</td>
                            <td><div class="fw-bold">@item.Name</div></td>
                            <td>@item.Address</td>
                            <td><small class="text-muted">@item.Lat, @item.Long</small></td>
                            <td>@(item.ContactNumber?.ToString() ?? "—")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-geo-alt" style="font-size:3rem; color:var(--egy-primary);"></i>
                <p class="text-muted mt-2">No branches found. Add your first branch above.</p>
            </div>
        }
    </div>
</div>
