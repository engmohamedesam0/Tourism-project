@model IEnumerable<Tourist_Project_MVC.Models.Branch>

@{
    ViewData["Title"] = Localizer["SponsorBranch_IndexTitle"].Value;
}

<div class="inner-page-wrapper">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="page-title mb-0">📍 @Localizer["SponsorBranch_IndexHeading"].Value</h2>
            <a asp-action="Create" class="btn btn-success px-4">
                <i class="bi bi-plus-lg me-1"></i> @Localizer["SponsorBranch_CreateBtn"].Value
            </a>
        </div>

    @await Html.PartialAsync("_StatBoxRow", (List<Tourist_Project_MVC.View_Model.StatBoxItem>)ViewBag.StatBoxes)

        <div class="table-responsive">
            <table class="table table-hover align-middle destinations-table">
                <thead>
                    <tr>
                        <th>@Localizer["SponsorBranch_ColHash"].Value</th>
                        <th>@Localizer["SponsorBranch_ColName"].Value</th>
                        <th>@Localizer["SponsorBranch_ColAddress"].Value</th>
                        <th>@Localizer["SponsorBranch_ColCoordinates"].Value</th>
                        <th>@Localizer["SponsorBranch_ColPhone"].Value</th>
                        <th>@Localizer["SponsorBranch_ColActions"].Value</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">@i.ToString("D2")</td>
                            <td><div class="fw-bold">@item.Name</div></td>
                            <td>@item.Address</td>
                            <td><small class="text-muted">@item.Lat, @item.Long</small></td>
                            <td>@(item.ContactNumber?.ToString() ?? "—")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning" title="@Localizer["SponsorBranch_EditTip"].Value">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="@Localizer["SponsorBranch_DeleteTip"].Value">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-geo-alt" style="font-size:3rem; color:var(--egy-primary);"></i>
                <p class="text-muted mt-2">@Localizer["SponsorBranch_EmptyMessage"].Value</p>
            </div>
        }
    </div>
</div>