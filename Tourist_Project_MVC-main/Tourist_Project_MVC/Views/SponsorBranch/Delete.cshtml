@model Tourist_Project_MVC.Models.Branch

@{
    ViewData["Title"] = "Delete Branch";
}

<div class="inner-page-wrapper">
    <div class="container">
        <h2>🗑️ Delete Branch</h2>
        <hr />
        <div class="alert alert-warning">
            <strong>Are you sure you want to delete this branch?</strong>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Coordinates</dt>
            <dd class="col-sm-9">@Model.Location.Y, @Model.Location.X</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@(Model.ContactNumber?.ToString() ?? "—")</dd>
        </dl>

        <form asp-action="DeleteConfirmed" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
