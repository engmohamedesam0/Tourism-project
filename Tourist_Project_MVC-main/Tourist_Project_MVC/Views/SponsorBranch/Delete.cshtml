@model Tourist_Project_MVC.Models.Branch

@{
    ViewData["Title"] = Localizer["SponsorBranch_DeleteTitle"].Value;
}

<div class="inner-page-wrapper">
    <div class="container">
        <h2>🗑️ @Localizer["SponsorBranch_DeleteHeading"].Value</h2>
        <hr />
        <div class="alert alert-warning">
            <strong>@Localizer["SponsorBranch_DeleteConfirm"].Value</strong>
        </div>

        <dl class="row">
            <dt class="col-sm-3">@Localizer["SponsorBranch_ColName"].Value</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">@Localizer["SponsorBranch_ColAddress"].Value</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">@Localizer["SponsorBranch_ColCoordinates"].Value</dt>
            <dd class="col-sm-9">@Model.Lat, @Model.Long</dd>

            <dt class="col-sm-3">@Localizer["SponsorBranch_ColPhone"].Value</dt>
            <dd class="col-sm-9">@(Model.ContactNumber?.ToString() ?? "—")</dd>
        </dl>

        <form asp-action="DeleteConfirmed" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">@Localizer["SponsorBranch_DeleteBtn"].Value</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["SponsorBranch_CancelBtn"].Value</a>
        </form>
    </div>
</div>