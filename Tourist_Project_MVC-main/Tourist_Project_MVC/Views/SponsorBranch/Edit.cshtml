@model Tourist_Project_MVC.View_Model.SponsorBranchVM

@{
    ViewData["Title"] = Localizer["SponsorBranch_EditTitle"].Value;
}

<div class="inner-page-wrapper">
    <div class="container">
        <h2>✏️ @Localizer["SponsorBranch_EditHeading"].Value</h2>
        <hr />
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SponsorId" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Lat" class="form-label"></label>
                    <input asp-for="Lat" class="form-control" type="number" step="any" />
                    <span asp-validation-for="Lat" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Long" class="form-label"></label>
                    <input asp-for="Long" class="form-control" type="number" step="any" />
                    <span asp-validation-for="Long" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <div id="branchMap" style="height:360px;border-radius:14px;border:1px solid rgba(200,131,42,0.25);background:#ece6db;"></div>
            </div>

            <div class="mb-3">
                <label asp-for="ContactNumber" class="form-label"></label>
                <input asp-for="ContactNumber" class="form-control" type="number" />
                <span asp-validation-for="ContactNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="@Localizer["SponsorBranch_UpdateBtn"].Value" class="btn btn-warning" />
                <a asp-action="Index" class="btn btn-secondary">@Localizer["SponsorBranch_CancelBtn"].Value</a>
            </div>
        </form>
    </div>

    @section Scripts {
    <script>
        (function () {
            var latVal = parseFloat(document.getElementById('Lat').value);
            var lngVal = parseFloat(document.getElementById('Long').value);
            EGYMaps.initLocationPicker({
                mapElId: 'branchMap',
                latInputId: 'Lat',
                lngInputId: 'Long',
                contextLayer: 'branches',
                contextStyle: { radius: 6, fillColor: '#888', color: '#555', weight: 1, opacity: 0.5, fillOpacity: 0.2 },
                initialLat: isNaN(latVal) ? 30.0444 : latVal,
                initialLng: isNaN(lngVal) ? 31.2357 : lngVal
            });
        })();
    </script>
}
</div>