@model Tourist_Project_MVC.View_Model.SponsorDashboardVM

@{
    ViewData["Title"] = "Sponsor Dashboard";
    ViewData["IsHomePage"] = false;
}

<div class="container my-4" style="max-width: 1000px;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="page-title mb-0">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </h1>
        <a asp-controller="SponsorRedemption" asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-receipt me-1"></i> Redemption History
        </a>
    </div>

    <div class="row g-3">
        <!-- Redeemed rewards count -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-ticket-perforated-fill text-primary" style="font-size: 2rem;"></i>
                    <div class="stat-mini-number mt-2">@Model.RedeemedCount</div>
                    <div class="stat-mini-label">Rewards Redeemed</div>
                </div>
            </div>
        </div>

        <!-- Reward detail views -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-eye-fill text-primary" style="font-size: 2rem;"></i>
                    <div class="stat-mini-number mt-2">@Model.RewardViewCount</div>
                    <div class="stat-mini-label">Reward Detail Views</div>
                </div>
            </div>
        </div>

        <!-- Most-wanted reward + branch -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-fire text-primary" style="font-size: 2rem;"></i>
                    <div class="stat-mini-number mt-2" style="font-size: 1.1rem; line-height: 1.3;">
                        @(Model.MostWantedRewardTitle ?? "—")
                    </div>
                    <div class="stat-mini-label">
                        Most-Wanted
                        @if (Model.MostWantedRewardRedemptions > 0)
                        {
                            @:(@Model.MostWantedRewardRedemptions)
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.MostWantedBranchName))
                    {
                        <div class="small text-muted mt-1">
                            <i class="bi bi-geo-alt-fill"></i> @Model.MostWantedBranchName
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tourist rating -->
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-star-fill text-primary" style="font-size: 2rem;"></i>
                    <div class="stat-mini-number mt-2">
                        @(Model.RatingAvailable ? $"{Model.AverageRating:F1}" : "—")
                    </div>
                    <div class="stat-mini-label">
                        Avg. Rating
                        @if (Model.RatingAvailable)
                        {
                            @:(@Model.ReviewCount)
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.RatingAvailable)
    {
        <div class="alert alert-info mt-3" role="alert">
            <i class="bi bi-info-circle-fill me-1"></i>
            No reviews yet for your place — the rating card will populate once tourists leave reviews.
        </div>
    }

    <p class="text-muted small mt-4 mb-0">
        Metrics are scoped to your own rewards and branches.
    </p>
</div>

@section Scripts {
    <style>
        .stat-mini-number {
            font-family: 'Cinzel', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: #2C1A0E;
        }
        .stat-mini-label {
            font-size: 0.72rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
}
