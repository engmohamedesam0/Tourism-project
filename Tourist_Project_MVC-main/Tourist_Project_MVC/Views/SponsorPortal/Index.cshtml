@model Tourist_Project_MVC.Models.Sponsor

@{
    ViewData["Title"] = "Sponsor Portal";
    ViewData["IsHomePage"] = false;
}

<div class="container my-4" style="max-width: 1000px;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="page-title mb-1">
                <i class="bi bi-building-fill me-2"></i> @(string.IsNullOrEmpty(Model.Name) ? "Sponsor Portal" : Model.Name)
            </h1>
            <p class="text-muted mb-0">Welcome to your sponsor portal.</p>
        </div>
        <span class="badge bg-warning text-dark fs-6">Sponsor</span>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <a asp-controller="SponsorBranch" asp-action="Index" class="text-decoration-none portal-stat-link">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-geo-alt-fill text-primary" style="font-size: 2rem;"></i>
                        <div class="stat-mini-number mt-2">@(Model.Branches?.Count ?? 0)</div>
                        <div class="stat-mini-label">Branches</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorReward" asp-action="Index" class="text-decoration-none portal-stat-link">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-gift-fill text-primary" style="font-size: 2rem;"></i>
                        <div class="stat-mini-number mt-2">@(Model.Rewards?.Count ?? 0)</div>
                        <div class="stat-mini-label">Rewards</div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorReview" asp-action="Index" class="text-decoration-none portal-stat-link">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-star-fill text-primary" style="font-size: 2rem;"></i>
                        <div class="stat-mini-number mt-2">@(Model.Reviews?.Count ?? 0)</div>
                        <div class="stat-mini-label">Reviews</div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Address))
    {
        <div class="card border-0 shadow-sm rounded-4 mt-3">
            <div class="card-body">
                <h6 class="mb-2"><i class="bi bi-info-circle-fill me-1 text-primary"></i> Profile</h6>
                <p class="mb-1"><strong>Type:</strong> @Model.Type</p>
                <p class="mb-1"><strong>Address:</strong> @Model.Address</p>
                <p class="mb-0"><strong>Contact:</strong> @Model.ContactNumber</p>
            </div>
        </div>
    }

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <a asp-action="Dashboard" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-speedometer2 text-primary" style="font-size: 1.6rem;"></i>
                        <div>
                            <div class="fw-bold">Dashboard</div>
                            <div class="small text-muted">Redemptions, views &amp; ratings</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorRedemption" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-receipt text-primary" style="font-size: 1.6rem;"></i>
                        <div>
                            <div class="fw-bold">Redemption History</div>
                            <div class="small text-muted">Filter by date, reward &amp; status</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorNotification" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-bell-fill text-primary" style="font-size: 1.6rem;"></i>
                        <div>
                            <div class="fw-bold">Notifications</div>
                            <div class="small text-muted">Alerts and updates</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorNotification" asp-action="Support" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-life-preserver text-primary" style="font-size: 1.6rem;"></i>
                        <div>
                            <div class="fw-bold">Support</div>
                            <div class="small text-muted">Tickets and help</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="SponsorPortal" asp-action="Reports" class="text-decoration-none">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        <i class="bi bi-bar-chart-fill text-primary" style="font-size: 1.6rem;"></i>
                        <div>
                            <div class="fw-bold">Reports</div>
                            <div class="small text-muted">Monthly redemptions &amp; views</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <p class="text-muted small mt-4 mb-0">
        Manage your branches and rewards from the respective portal sections.
    </p>
</div>

@section Scripts {
    <style>
        .stat-mini-number {
            font-family: 'Cinzel', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: #2C1A0E;
        }
        .stat-mini-label {
            font-size: 0.72rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .portal-stat-link .card {
            transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
            border: 1px solid transparent;
        }

        .portal-stat-link:hover .card {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(200, 131, 42, 0.18);
            border-color: var(--egy-primary);
        }
    </style>
}
