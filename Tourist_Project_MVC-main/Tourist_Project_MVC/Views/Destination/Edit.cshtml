@model Tourist_Project_MVC.Models.Destination

@{
    ViewData["Title"] = @Localizer["Destination_EditTitle"].Value;
}
@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4">
        <h2>✏️ @Localizer["Destination_EditTitle"].Value</h2>
        <hr />
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">@Localizer["Destination_Description"].Value</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>

            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label">@Localizer["Destination_Status"].Value</label>
                <select asp-for="Status" class="form-select">
                    <option value="Active">@Localizer["Destination_StatusActive"].Value</option>
                    <option value="Pending">@Localizer["Destination_StatusPending"].Value</option>
                    <option value="Inactive">@Localizer["Destination_StatusInactive"].Value</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Visits" class="form-label">@Localizer["Destination_Visits"].Value</label>
                <input asp-for="Visits" class="form-control" type="number" />
            </div>
            <div class="mb-3">
                <label asp-for="TicketPrice" class="form-label"></label>
                <input asp-for="TicketPrice" class="form-control" type="number" step="0.01" />
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Lat" class="form-label">@Localizer["Destination_Latitude"].Value</label>
                    <input asp-for="Lat" class="form-control" />
                </div>
                <div class="col mb-3">
                    <label asp-for="Long" class="form-label">@Localizer["Destination_Longitude"].Value</label>
                    <input asp-for="Long" class="form-control" />
                </div>
            </div>

            <button type="submit" class="btn btn-warning">@Localizer["Destination_Update"].Value</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["Destination_Cancel"].Value</a>
        </form>
    </div>
}
