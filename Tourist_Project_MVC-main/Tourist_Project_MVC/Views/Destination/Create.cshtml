@model Tourist_Project_MVC.Models.Destination

@{
    ViewData["Title"] = @Localizer["Destination_CreateTitle"].Value;
}
@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4">
        <h2>@Localizer["Destination_CreateHeading"].Value</h2>
        <hr />
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">@Localizer["Destination_Description"].Value</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TicketPrice" class="form-label"></label>
                <input asp-for="TicketPrice" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="TicketPrice" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label class="form-label">Latitude</label>
                    <input name="Lat" id="Lat" class="form-control" type="number" step="any"
                           value="@(ViewBag.Lat ?? string.Empty)" />
                </div>
                <div class="col mb-3">
                    <label class="form-label">Longitude</label>
                    <input name="Long" id="Long" class="form-control" type="number" step="any"
                           value="@(ViewBag.Long ?? string.Empty)" />
                </div>
            </div>

            <div class="mb-3">
                <div id="destinationMap" style="height:360px;border-radius:14px;border:1px solid rgba(200,131,42,0.25);background:#ece6db;"></div>
            </div>

            <button type="submit" class="btn btn-success">@Localizer["Destination_Save"].Value</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["Destination_Cancel"].Value</a>
        </form>
    </div>

    @section Scripts {
    <script>
        (function () {
            var latVal = parseFloat(document.getElementById('Lat').value);
            var lngVal = parseFloat(document.getElementById('Long').value);
            EGYMaps.initLocationPicker({
                mapElId: 'destinationMap',
                latInputId: 'Lat',
                lngInputId: 'Long',
                contextProxyUrl: '/Map/GetDestinationsGeoJson',
                contextStyle: { radius: 6, fillColor: '#888', color: '#555', weight: 1, opacity: 0.5, fillOpacity: 0.2 },
                initialLat: isNaN(latVal) ? 30.0444 : latVal,
                initialLng: isNaN(lngVal) ? 31.2357 : lngVal
            });
        })();
    </script>
}
}