<script>
    (function () {
        var filterForm = document.getElementById('filterForm');
        var searchInput = document.getElementById('destinationSearch');
        var categorySelect = document.getElementById('destinationCategory');

        if (categorySelect) {
            categorySelect.addEventListener('change', function () {
                window.location.href = this.value;
            });
        }

        if (filterForm && searchInput) {
            filterForm.addEventListener('submit', function () {
                if (!searchInput.value.trim()) {
                    searchInput.removeAttribute('name');
                }
            });
        }

        document.querySelectorAll('.destination-row[data-href]').forEach(function (row) {
            row.addEventListener('click', function (event) {
                if (event.target.closest('a, button, .destination-action-group')) {
                    return;
                }

                window.location.href = row.getAttribute('data-href');
            });
        });
    })();
</script>
}
