@model IEnumerable<Tourist_Project_MVC.Models.Destination>

@{
    ViewData["Title"] = @Localizer["Destination_PageTitle"].Value;
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title mb-0">🗺️ @Localizer["Destination_Heading"].Value</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success px-4">
                <i class="bi bi-plus-lg me-1"></i> @Localizer["Destination_AddBtn"].Value
            </a>            
        }
    </div>

    @await Html.PartialAsync("_StatBoxRow", (List<Tourist_Project_MVC.View_Model.StatBoxItem>)ViewBag.StatBoxes)

    <!-- Filter Bar -->
    <div class="filter-bar mb-3">
        <div class="row g-2 align-items-center">

            <!-- Search -->
            <div class="col-md-4">
                <form method="get" asp-action="Index" id="filterForm">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="search"
                               class="form-control border-start-0"
                               placeholder="@Localizer["Destination_SearchPlaceholder"].Value"
                               value="@ViewBag.Search" />
                        <input type="hidden" name="status" value="@ViewBag.Status" />
                        <input type="hidden" name="category" value="@ViewBag.Category" />
                    </div>
                </form>
            </div>

            <div class="col-md-5">
                <div class="btn-group w-100" role="group">
                    <a href="@Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category })"
                       class="btn @(ViewBag.Status == null ? "btn-primary" : "btn-outline-secondary")">
                        @Localizer["Destination_FilterAll"].Value (@ViewBag.AllCount)
                    </a>
                    <a href="@Url.Action("Index", new { search = ViewBag.Search, status = "Active", category = ViewBag.Category })"
                       class="btn @(ViewBag.Status == "Active" ? "btn-success" : "btn-outline-secondary")">
                        @Localizer["Destination_FilterActive"].Value (@ViewBag.ActiveCount)
                    </a>
                    <a href="@Url.Action("Index", new { search = ViewBag.Search, status = "Pending", category = ViewBag.Category })"
                       class="btn @(ViewBag.Status == "Pending" ? "btn-warning" : "btn-outline-secondary")">
                        @Localizer["Destination_FilterPending"].Value (@ViewBag.PendingCount)
                    </a>
                    <a href="@Url.Action("Index", new { search = ViewBag.Search, status = "Inactive", category = ViewBag.Category })"
                       class="btn @(ViewBag.Status == "Inactive" ? "btn-danger" : "btn-outline-secondary")">
                        @Localizer["Destination_FilterInactive"].Value (@ViewBag.InactiveCount)
                    </a>
                </div>
            </div>

            <div class="col-md-3">
                <select class="form-select"
                        onchange="window.location.href=this.value">
                    <option value="@Url.Action("Index", new { search = ViewBag.Search, status = ViewBag.Status })">
                        @Localizer["Destination_AllCategories"].Value
                    </option>
                    @foreach (var cat in ViewBag.Categories as List<string> ?? new List<string>())
                    {
                        var url = Url.Action("Index", new { search = ViewBag.Search, status = ViewBag.Status, category = cat });
                        var isSelected = ViewBag.Category == cat;
                        if (isSelected)
                        {
                            <option value="@url" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@url">@cat</option>
                        }
                    }
                </select>
            </div>

        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle destinations-table">
            <thead>
                <tr>
                    <th>@Localizer["Destination_TableNum"].Value</th>
                    <th>@Localizer["Destination_TableDestination"].Value</th>
                    <th>@Localizer["Destination_TableGovernorate"].Value</th>
                    <th>@Localizer["Destination_TableCategory"].Value</th>
                    <th>@Localizer["Destination_TableVisits"].Value</th>
                    <th>@Localizer["Destination_TableTicketPrice"].Value</th>
                    <th>@Localizer["Destination_TableStatus"].Value</th>
                    <th>@Localizer["Destination_TableActions"].Value</th>
                </tr>
            </thead>
            <tbody>
                @{int i = 1;}
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-muted">@i.ToString("D2")</td>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                            <small class="text-muted">@item.Description?.Substring(0, Math.Min(40, item.Description?.Length ?? 0))...</small>
                        </td>
                        <td>@item.City</td>
                        <td>
                            <span class="badge-category">@item.Category</span>
                        </td>
                        <td>
                            <i class="bi bi-eye-fill text-muted me-1"></i>
                            @item.Visits.ToString("N0")
                        </td>
                        <td>
                            @(item.TicketPrice == 0 ? Localizer["Destination_Free"].Value : item.TicketPrice?.ToString("C"))
                        </td>
                        <td>
                            @{
                                var badgeClass = item.Status switch
                                {
                                    "Active" => "badge-status-active",
                                    "Pending" => "badge-status-pending",
                                    "Inactive" => "badge-status-inactive",
                                    _ => "badge-status-active"
                                };
                            }
                            <span class="badge-status @badgeClass">@item.Status</span>
                        </td>
                        <td>
                         @if (User.Identity.IsAuthenticated){
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                        class="btn btn-sm btn-outline-info"
                                        title="@Localizer["Destination_DetailsTitle"].Value">
                                            <i class="bi bi-eye-fill"></i>
                                 </a>

                                    @if (User.IsInRole("Admin"))
                                    {
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-warning"
                                   title="@Localizer["Destination_EditTitle"].Value">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                        class="btn btn-sm btn-outline-danger"
                                        title="@Localizer["Destination_DeleteTitle"].Value">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>                    
                                    }
                               </div>
                             }
                             else
                             {
                            <span class="text-muted small">@Localizer["Destination_GuestsOnly"].Value</span>
                             }
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-geo-alt" style="font-size: 3rem; color: #C8832A;"></i>
            <p class="text-muted mt-2">@Localizer["Destination_NoDestinations"].Value</p>
            <a asp-action="Create" class="btn btn-primary">@Localizer["Destination_AddFirst"].Value</a>
        </div>
    }

</div>

@section Scripts {
<style>
    .filter-bar {
        background: white;
        padding: 16px;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .destinations-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .badge-category {
        background-color: #FDF6EC;
        color: #C8832A;
        border: 1px solid #E8A045;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .badge-status {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .badge-status-active {
        background-color: #d4edda;
        color: #155724;
    }

    .badge-status-pending {
        background-color: #fff3cd;
        color: #856404;
    }

    .badge-status-inactive {
        background-color: #f8d7da;
        color: #721c24;
    }

    .btn-group .btn {
        font-size: 0.85rem;
    }
</style>

<script>
    document.querySelector('input[name="search"]').addEventListener('keypress', function (e) {
        if (e.key === 'Enter') {
            document.getElementById('filterForm').submit();
        }
    });
</script>
}