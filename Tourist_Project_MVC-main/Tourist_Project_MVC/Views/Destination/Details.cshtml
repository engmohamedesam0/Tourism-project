@model Tourist_Project_MVC.Models.Destination

@{
    ViewData["Title"] = "Destination Details";
}

<div class="container mt-4" style="max-width: 800px;">

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Card Header -->
        <div class="card-header py-3"
             style="background: linear-gradient(135deg, #2C1A0E, #C8832A);">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="text-white mb-0">
                    <i class="bi bi-geo-alt-fill me-2"></i> @Model.Name
                </h4>
                @{
                    var badgeClass = Model.Status switch
                    {
                        "Active" => "bg-success",
                        "Pending" => "bg-warning text-dark",
                        "Inactive" => "bg-danger",
                        _ => "bg-success"
                    };
                }
                <span class="badge @badgeClass fs-6">@Model.Status</span>
            </div>
        </div>

        <div class="card-body p-4">

            <!-- Stats Row -->
            <div class="row text-center mb-4">
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-eye-fill text-primary"></i>
                        <div class="stat-mini-number">@Model.Visits.ToString("N0")</div>
                        <div class="stat-mini-label">Total Visits</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-ticket-perforated-fill text-warning"></i>
                        <div class="stat-mini-number">
                            @(Model.TicketPrice == 0 ? "Free" : Model.TicketPrice?.ToString("C"))
                        </div>
                        <div class="stat-mini-label">Ticket Price</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-tag-fill text-success"></i>
                        <div class="stat-mini-number">@Model.Category</div>
                        <div class="stat-mini-label">Category</div>
                    </div>
                </div>
            </div>

            <hr />

            <!-- Details -->
            <dl class="row">
                <dt class="col-sm-4 text-muted">City / Governorate</dt>
                <dd class="col-sm-8">@Model.City</dd>

                <dt class="col-sm-4 text-muted">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>

                <dt class="col-sm-4 text-muted">Coordinates</dt>
                <dd class="col-sm-8">
                    <i class="bi bi-geo text-danger me-1"></i>
                    Lat: @Model.Lat | Long: @Model.Long
                </dd>

                <dt class="col-sm-4 text-muted">Opening Hours</dt>
                <dd class="col-sm-8">
                    @(Model.OpeningHours.HasValue ? Model.OpeningHours.Value.ToString("hh:mm tt") : "Not specified")
                </dd>
            </dl>
        </div>

        <!-- Card Footer -->
        <div class="card-footer bg-white d-flex gap-2 justify-content-end">
           @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-fill me-1"></i> Edit
            </a>
            }
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <style>
        .stat-mini-card {
            background: #FDF6EC;
            border: 1px solid #E8A045;
            border-radius: 12px;
            padding: 15px 10px;
        }

        .stat-mini-number {
            font-family: 'Cinzel', sans-serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: #2C1A0E;
            margin: 6px 0 2px;
        }

        .stat-mini-label {
            font-size: 0.75rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
}