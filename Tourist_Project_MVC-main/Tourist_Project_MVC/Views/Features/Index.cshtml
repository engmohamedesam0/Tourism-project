@{
    ViewData["Title"] = "Features";
}

<div class="features-page inner-page-wrapper">
    <div class="container px-4 px-lg-5">

        <!-- HERO / TOP CTA -->
        <section class="text-center py-5">
            <h1 class="display-4 cinzel-title">The EGYXPLORE App</h1>
            <p class="lead text-muted">
                Your smart companion for exploring Egypt — maps, games, AI, and rewards,
                all in your pocket.
            </p>
            <div class="store-badges mt-4 d-flex justify-content-center gap-3 flex-wrap">
                <!-- TODO: real store listings -->
                <a href="#" class="store-badge">
                    <i class="bi bi-apple me-2"></i> App Store
                </a>
                <a href="#" class="store-badge">
                    <i class="bi bi-google-play me-2"></i> Google Play
                </a>
            </div>
        </section>

        <!-- FEATURE SECTIONS -->
        <section class="features-sections">

            <!-- 1. Indoor Maps -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/demo-image-01.jpg">
                            <source src="" data-poster="~/assets/img/demo-image-01.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-start ps-lg-4">
                        <h3><i class="bi bi-map-fill me-2 text-primary"></i> Indoor Maps</h3>
                        <p class="text-black-50">
                            Never get lost inside vast museums and temples. High-detail indoor
                            maps guide you corridor by corridor through Egypt's heritage sites.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 2. Navigation Mode -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6 order-lg-last">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/demo-image-02.jpg">
                            <source src="" data-poster="~/assets/img/demo-image-02.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-end pe-lg-4">
                        <h3><i class="bi bi-signpost-split-fill me-2 text-primary"></i> Navigation Mode</h3>
                        <p class="text-black-50">
                            Turn-by-turn routing between destinations with smart GIS optimization
                            that accounts for opening hours and travel time.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 3. Fun Games -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/bg-masthead.jpg">
                            <source src="" data-poster="~/assets/img/bg-masthead.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-start ps-lg-4">
                        <h3><i class="bi bi-controller me-2 text-primary"></i> Fun Games</h3>
                        <p class="text-black-50">
                            Turn every visit into an adventure with location-based mini-games and
                            scavenger hunts for the whole family.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 4. Camera Scanner -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6 order-lg-last">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/ipad.png">
                            <source src="" data-poster="~/assets/img/ipad.png" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-end pe-lg-4">
                        <h3><i class="bi bi-camera-fill me-2 text-primary"></i> Camera Scanner</h3>
                        <p class="text-black-50">
                            Point your camera at a monument to instantly reveal its history,
                            era, and the stories carved into every stone.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 5. AI Assistant -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/demo-image-01.jpg">
                            <source src="" data-poster="~/assets/img/demo-image-01.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-start ps-lg-4">
                        <h3><i class="bi bi-stars me-2 text-primary"></i> AI Assistant</h3>
                        <p class="text-black-50">
                            Ask anything about Egypt's wonders and get personalized itineraries,
                            tips, and answers powered by a smart travel assistant.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 6. P2P Translation -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6 order-lg-last">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/demo-image-02.jpg">
                            <source src="" data-poster="~/assets/img/demo-image-02.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-end pe-lg-4">
                        <h3><i class="bi bi-translate me-2 text-primary"></i> P2P Translation</h3>
                        <p class="text-black-50">
                            Break the language barrier with real-time peer-to-peer translation,
                            so you can connect with locals wherever you roam.
                        </p>
                    </div>
                </div>
            </div>

            <!-- 7. Rewarding System -->
            <div class="row gx-0 mb-5 align-items-center feature-row">
                <div class="col-lg-6">
                    <div class="feature-media">
                        <video class="feature-video" autoplay loop muted playsinline
                               poster="~/assets/img/bg-masthead.jpg">
                            <source src="" data-poster="~/assets/img/bg-masthead.jpg" />
                        </video>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="featured-text text-center text-lg-start ps-lg-4">
                        <h3><i class="bi bi-gift-fill me-2 text-primary"></i> Rewarding System</h3>
                        <p class="text-black-50">
                            Earn points for every mission and redeem them for exclusive discounts
                            on meals, stays, and experiences with our partners.
                        </p>
                    </div>
                </div>
            </div>

        </section>

        <!-- BOTTOM CTA -->
        <section class="text-center py-5 border-top">
            <h2 class="cinzel-title mb-3">Start Exploring Today</h2>
            <p class="text-muted mb-4">Download the app and unlock hidden wonders across Egypt.</p>
            <div class="store-badges d-flex justify-content-center gap-3 flex-wrap">
                <!-- TODO: real store listings -->
                <a href="#" class="store-badge">
                    <i class="bi bi-apple me-2"></i> App Store
                </a>
                <a href="#" class="store-badge">
                    <i class="bi bi-google-play me-2"></i> Google Play
                </a>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <style>
        .features-page {
            background-color: var(--egy-light);
        }

        .cinzel-title {
            font-family: 'Cinzel', serif;
            color: var(--egy-dark);
            letter-spacing: 1px;
        }

        .feature-media {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 14px 30px rgba(200, 131, 42, 0.18);
            background: #ece6db;
            border: 1px solid rgba(200, 131, 42, 0.3);
        }

        .feature-video {
            width: 100%;
            height: 320px;
            object-fit: cover;
            display: block;
            opacity: 0.85;
            transition: opacity 0.4s ease;
        }

            .feature-video.playing {
                opacity: 1;
            }

        .store-badge {
            display: inline-flex;
            align-items: center;
            background: var(--egy-dark);
            color: #fff;
            border: 1px solid var(--egy-primary);
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.25s ease;
        }

            .store-badge:hover {
                background: var(--egy-primary);
                color: #fff;
                transform: translateY(-2px);
            }
    </style>

    <script>
        // Autoplay-on-scroll: only the section whose <video> is >=50% visible plays.
        (function () {
            var videos = Array.from(document.querySelectorAll('.feature-video'));
            if (!('IntersectionObserver' in window) || !videos.length) {
                return;
            }

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    var video = entry.target;
                    if (entry.isIntersecting) {
                        video.classList.add('playing');
                        var p = video.play();
                        if (p && typeof p.catch === 'function') {
                            p.catch(function () { /* autoplay blocked; poster stays */ });
                        }
                    } else {
                        video.classList.remove('playing');
                        video.pause();
                    }
                });
            }, { threshold: 0.5 });

            videos.forEach(function (v) { observer.observe(v); });
        })();
    </script>
}
