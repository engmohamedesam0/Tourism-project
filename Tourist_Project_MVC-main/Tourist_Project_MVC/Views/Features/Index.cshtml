@section Scripts {
    <style>
        .features-page {
            background-color: var(--egy-light);
        }

        .cinzel-title {
            font-family: 'Cinzel', serif;
            color: var(--egy-dark);
            letter-spacing: 1px;
        }

        .feature-media {
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 14px 30px rgba(200, 131, 42, 0.18);
            background: #ece6db;
            border: 1px solid rgba(200, 131, 42, 0.3);
        }

        .feature-video {
            width: 100%;
            height: 320px;
            object-fit: cover;
            display: block;
            opacity: 0.85;
            transition: opacity 0.4s ease;
        }

            .feature-video.playing {
                opacity: 1;
            }

        .store-badge {
            display: inline-flex;
            align-items: center;
            background: var(--egy-dark);
            color: #fff;
            border: 1px solid var(--egy-primary);
            border-radius: 10px;
            padding: 10px 20px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.25s ease;
        }

            .store-badge:hover {
                background: var(--egy-primary);
                color: #fff;
                transform: translateY(-2px);
            }
    </style>

    <script>
        // Autoplay-on-scroll: only the section whose <video> is >=50% visible plays.
        (function () {
            var videos = Array.from(document.querySelectorAll('.feature-video'));
            if (!('IntersectionObserver' in window) || !videos.length) {
                return;
            }

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    var video = entry.target;
                    if (entry.isIntersecting) {
                        video.classList.add('playing');
                        var p = video.play();
                        if (p && typeof p.catch === 'function') {
                            p.catch(function () { /* autoplay blocked; poster stays */ });
                        }
                    } else {
                        video.classList.remove('playing');
                        video.pause();
                    }
                });
            }, { threshold: 0.5 });

            videos.forEach(function (v) { observer.observe(v); });
        })();
    </script>
}
