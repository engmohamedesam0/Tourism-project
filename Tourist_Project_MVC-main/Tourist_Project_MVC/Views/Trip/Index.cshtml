@model Tourist_Project_MVC.View_Model.TripBuilderVM

@{
    ViewData["Title"] = "My Trip";
    var tourist = ViewBag.Tourist as Tourist_Project_MVC.Models.Tourist;
    var myTrips = (ViewBag.MyTrips as IEnumerable<Tourist_Project_MVC.Models.TripPlan>) ?? new List<Tourist_Project_MVC.Models.TripPlan>();
}

<div class="container mt-4" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h2 class="page-title mb-0">🗺️ Plan Your Trip</h2>
        @if (tourist != null)
        {
            <span class="text-muted small">Planning as <strong>@tourist.Name</strong></span>
        }
    </div>

    <!-- EXISTING TRIPS TIMELINE -->
    @if (myTrips.Any())
    {
        <h4 class="mb-3" style="font-family:'Cinzel',serif; color:var(--egy-dark);">My Trips</h4>
        <div class="trip-timeline mb-5">
            @foreach (var trip in myTrips)
            {
                var statusBadge = trip.Status switch
                {
                    "Active" => "badge-status-active",
                    "Completed" => "badge-status-pending",
                    "Cancelled" => "badge-status-inactive",
                    "Draft" => "badge-status-draft",
                    _ => "badge-status-active"
                };
                <div class="trip-timeline-item">
                    <div class="trip-timeline-dot"></div>
                    <a asp-controller="Trip" asp-action="Details" asp-route-id="@trip.Id" class="text-decoration-none">
                        <div class="card trip-card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="mb-1" style="font-family:'Cinzel',serif; color:var(--egy-dark);">@trip.Title</h5>
                                    <span class="badge-status @statusBadge">@trip.Status</span>
                                </div>
                                <div class="text-muted small mb-2">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @trip.StartDate.ToString("MMM dd, yyyy") &ndash; @trip.EndDate.ToString("MMM dd, yyyy")
                                </div>
                                <div class="trip-stops">
                                    @foreach (var td in trip.TripDestinations.OrderBy(x => x.Visit_Order))
                                    {
                                        <span class="trip-stop-pill">
                                            <i class="bi bi-geo-alt-fill me-1"></i>@td.Destination?.Name
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

</div>

<!-- BUILDER (full-width form) -->
<form asp-action="Create" method="post" id="tripForm">
        @Html.AntiForgeryToken()

        <!-- FULL-BLEED MAP + PLANNING FILTERS (Item 3) -->
        <section class="trip-map-filter-section">
            <div class="container-fluid px-3 px-lg-4">
                <div class="row align-items-stretch">
                    <div class="col-lg-4">
                        <!-- PLANNING FILTER BAR (Item 4) -->
                        <div class="filter-bar mb-4">
                            <div class="filter-field">
                                <label class="form-label fw-semibold mb-1">@Localizer["Trip_Duration"].Value</label>
                                <div class="form-control-plaintext fw-semibold" id="tripDuration">—</div>
                            </div>

                            <div class="filter-field">
                                <label class="form-label fw-semibold mb-1">@Localizer["Trip_Budget"].Value</label>
                                <input asp-for="Budget" class="form-control" type="number" min="0" step="0.01"
                                       placeholder="@Localizer["Trip_BudgetPlaceholder"].Value" />
                            </div>

                            <div class="filter-field">
                                <label class="form-label fw-semibold mb-1">@Localizer["Trip_Companions"].Value</label>
                                <input asp-for="Companions" class="form-control" type="number" min="1"
                                       placeholder="@Localizer["Trip_CompanionsPlaceholder"].Value" />
                            </div>

                            <div class="filter-field filter-interests" id="tripInterests">
                                <label class="form-label fw-semibold mb-1 d-block">@Localizer["Trip_Interests"].Value</label>
                                <div class="d-flex flex-wrap gap-2">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-hidden" data-status="Pending" />
                                        <label class="form-check-label" for="int-hidden">@Localizer["Trip_HiddenGems"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-temples" data-category="Temple" />
                                        <label class="form-check-label" for="int-temples">@Localizer["Trip_Temples"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-museums" data-category="Museum" />
                                        <label class="form-check-label" for="int-museums">@Localizer["Trip_Museums"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-nature" data-category="Natural" />
                                        <label class="form-check-label" for="int-nature">@Localizer["Trip_Nature"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-adventure" data-category="Archaeological" />
                                        <label class="form-check-label" for="int-adventure">@Localizer["Trip_Adventure"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-historical" data-category="Historical" />
                                        <label class="form-check-label" for="int-historical">@Localizer["Trip_Historical"].Value</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="int-religious" data-category="Religious" />
                                        <label class="form-check-label" for="int-religious">@Localizer["Trip_Religious"].Value</label>
                                    </div>
                                </div>
                            </div>

                            <div class="filter-field filter-actions">
                                <button type="button" class="btn btn-outline-secondary" id="tripFilterBtn">
                                    <i class="bi bi-funnel-fill me-1"></i> @Localizer["Trip_Filter"].Value
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div id="tripBuilderMap" class="trip-builder-map mb-3">
                            <div class="map-watermark">
                                <i class="bi bi-map" style="font-size: 2rem;"></i>
                                <p class="mb-0 mt-1 small">Map will render here</p>
                                <small class="text-muted">Your selected stops feed a future map</small>
                            </div>
                        </div>
                    </div>
                </div>

        <!-- CONTAINED BUILDER -->
        <div class="container mt-4" style="max-width:1200px;">
        <div class="row g-4">
            <!-- Picker -->
            <div class="col-lg-5">
                <h4 class="mb-3" style="font-family:'Cinzel',serif; color:var(--egy-dark);">1. Pick Destinations</h4>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trip Title</label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Cairo & Luxor Escape" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label fw-semibold">Start</label>
                            <input asp-for="StartDate" class="form-control" type="date" id="StartDate" />
                        </div>
                        <div class="col">
                            <label class="form-label fw-semibold">End</label>
                            <input asp-for="EndDate" class="form-control" type="date" id="EndDate" />
                        </div>
                    </div>

                    <div class="destination-picker">
                        <div id="tripEmptyFilter" class="text-muted small py-2" style="display:none">No destinations match your filters.</div>
                        @for (int i = 0; i < Model.Stops.Count; i++)
                        {
                            <div class="picker-row"
                                 data-dest-id="@Model.Stops[i].DestinationId"
                                 data-category="@Model.Stops[i].Category"
                                 data-status="@Model.Stops[i].Status"
                                 data-price="@(Model.Stops[i].TicketPrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0")"
                                 data-lat="@Model.Stops[i].Lat.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                 data-lng="@Model.Stops[i].Lng.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                <div class="form-check">
                                    <input type="hidden" asp-for="Stops[i].DestinationId" />
                                    <input type="hidden" asp-for="Stops[i].DestinationName" />
                                    <input type="hidden" asp-for="Stops[i].City" />
                                    <input class="form-check-input stop-select"
                                           type="checkbox"
                                           asp-for="Stops[i].Selected"
                                           id="stop_@i" />
                                    <label class="form-check-label" for="stop_@i">
                                        <strong>@Model.Stops[i].DestinationName</strong>
                                        <small class="text-muted d-block">@Model.Stops[i].City</small>
                                    </label>
                                </div>
                                <div class="picker-dates d-none">
                                    <input asp-for="Stops[i].ArrivalDate" class="form-control form-control-sm" type="date" />
                                    <input asp-for="Stops[i].DepartureDate" class="form-control form-control-sm" type="date" />
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Live itinerary preview -->
                    <div class="mt-3">
                        <h6 class="text-muted">Itinerary preview</h6>
                        <ol class="itinerary-preview mb-3" id="itineraryPreview"></ol>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-save me-1"></i> Save Trip
                    </button>
            </div>

            <!-- Running itinerary -->
            <div class="col-lg-7">
                <h4 class="mb-3" style="font-family:'Cinzel',serif; color:var(--egy-dark);">2. Your Itinerary</h4>
                <div class="itinerary-board" id="itineraryBoard">
                    <p class="text-muted" id="emptyHint">
                        <i class="bi bi-arrow-left-circle me-1"></i>
                        Select destinations on the left to build your day-by-day plan.
                    </p>
                </div>
            </div>
        </div>
        </div>
    </form>

@section Scripts {
<style>
    .trip-timeline {
        border-left: 2px solid var(--egy-primary);
        padding-left: 22px;
        margin-left: 8px;
    }

    .trip-timeline-item {
        position: relative;
        margin-bottom: 18px;
    }

    .trip-timeline-dot {
        position: absolute;
        left: -30px;
        top: 18px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--egy-primary);
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px var(--egy-primary);
    }

    .trip-card {
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 14px;
    }

    .trip-stop-pill {
        display: inline-block;
        background: var(--egy-light);
        border: 1px solid rgba(200, 131, 42, 0.35);
        color: var(--egy-muted-gold);
        border-radius: 14px;
        padding: 3px 10px;
        font-size: 0.78rem;
        margin: 2px 4px 2px 0;
    }

    .destination-picker {
        max-height: 360px;
        overflow-y: auto;
        border: 1px solid rgba(200, 131, 42, 0.2);
        border-radius: 12px;
        padding: 6px;
        background: #fff;
    }

    .picker-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-bottom: 1px solid #f0e7d8;
    }

        .picker-row:last-child {
            border-bottom: none;
        }

    .picker-dates {
        display: flex;
        gap: 6px;
    }

        .picker-dates .form-control {
            width: 130px;
        }

    .itinerary-board {
        background: #fff;
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 14px;
        padding: 18px;
        min-height: 320px;
    }

    .itinerary-stop {
        display: flex;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px dashed #e7dcc8;
    }

        .itinerary-stop:last-child {
            border-bottom: none;
        }

    .itinerary-order {
        flex: 0 0 34px;
        height: 34px;
        border-radius: 50%;
        background: var(--egy-primary);
        color: #fff;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Cinzel', serif;
    }

    .itinerary-preview li {
        color: var(--egy-muted-gold);
    }

    /* Planning filter bar (Item 4) */
    .filter-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 18px;
        background: var(--egy-light);
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 14px;
        padding: 16px 18px;
    }

        .filter-bar .filter-field {
            min-width: 140px;
        }

        .filter-bar .filter-interests {
            flex: 1 1 320px;
        }

        .filter-bar .filter-actions {
            margin-left: auto;
        }

        .filter-bar #tripDuration {
            color: var(--egy-muted-gold);
        }

    .trip-map-filter-section {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        padding: 1.5rem 0;
    }

    .trip-builder-map {
        height: 100%;
        min-height: 340px;
        border-radius: 14px;
        border: 1px solid rgba(200, 131, 42, 0.25);
        background: repeating-linear-gradient(45deg, #e7e0d5 0 18px, #efe9df 18px 36px);
    }

    .map-watermark {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: var(--egy-muted-gold);
        opacity: 0.65;
    }

    .picker-row.match-highlight {
        background: rgba(200, 131, 42, 0.10);
        border-radius: 10px;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script>
    (function () {
        var tripPropMap = {
            id: ['id', 'Id', 'destination_id'],
            name: ['name', 'Name', 'destination_name'],
            city: ['city', 'City'],
            category: ['category', 'Category'],
            detailsUrl: '/Destination/Details/{id}'
        };

        function buildPopup(feature) {
            var p = feature.properties || {};
            var id = destId(feature);
            var name = _firstDefined(p, tripPropMap.name, ['Unnamed']);
            var city = _firstDefined(p, tripPropMap.city, ['']);
            var cat = _firstDefined(p, tripPropMap.category, ['']);
            var html = '';
            if (name) html += '<strong>' + _esc(name) + '</strong>';
            if (city) html += '<br><span style="color:#666">' + _esc(city) + '</span>';
            if (cat) html += '<br><span class="badge bg-secondary">' + _esc(cat) + '</span>';
            if (id && tripPropMap.detailsUrl) {
                html += '<br><a href="' + tripPropMap.detailsUrl.replace('{id}', encodeURIComponent(id)) + '" class="btn btn-sm btn-outline-primary mt-1">Details</a>';
            }
            return html;
        }

        function _esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
        function _firstDefined(p, keys, fallback) {
            for (var i = 0; i < keys.length; i++) {
                var val = p[keys[i]];
                if (val !== undefined && val !== null && String(val) !== '') return String(val);
            }
            return fallback[0] || '';
        }
        function destId(feature) { return String(feature.id || '').split('.').pop(); }

        var tripMap = EGYMaps.initWfsMap({
            mapElId: 'tripBuilderMap',
            layer: 'destinations',
            propMap: tripPropMap,
            popupHtml: buildPopup,
            markerStyle: { radius: 8, fillColor: '#C8832A', color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.85 },
            onLayerReady: function () {
                applyTripFilter();
            }
        });

        var $checks = $('.stop-select');
        var $board = $('#itineraryBoard');
        var $empty = $('#emptyHint');
        var $preview = $('#itineraryPreview');
        var stopOverlays = [];
        var rowById = {};

        $('.picker-row').each(function () {
            var id = $(this).attr('data-dest-id');
            if (id) rowById[String(id)] = $(this);
        });

        function rowMatches($row) {
            var cat = $row.data('category');
            var st = $row.data('status');
            var price = parseFloat($row.data('price')) || 0;
            var interests = [];
            $('#tripInterests input:checked').each(function () {
                interests.push({ cat: $(this).data('category'), st: $(this).data('status') });
            });
            var budget = parseFloat($('#Budget').val());
            var budgetSet = !isNaN(budget);

            var interestMatch = interests.length === 0;
            for (var j = 0; j < interests.length; j++) {
                if (interests[j].cat && cat === interests[j].cat) { interestMatch = true; break; }
                if (interests[j].st && st === interests[j].st) { interestMatch = true; break; }
            }
            var budgetMatch = !budgetSet || price <= budget;
            return interestMatch && budgetMatch;
        }

        function tripPredicate(feature) {
            var p = feature.attributes || {};
            var id = destId(feature);
            var row = rowById[String(id)];
            return row ? rowMatches(row) : false;
        }

        function clearStopOverlays() {
            stopOverlays.forEach(function (m) { if (tripMap && tripMap.map && tripMap.map.hasLayer(m)) tripMap.map.removeLayer(m); });
            stopOverlays = [];
        }

        function refresh() {
            var selected = $checks.filter(':checked');
            $preview.empty();
            clearStopOverlays();

            if (selected.length === 0) {
                $empty.show();
                $board.find('.itinerary-stop').remove();
                return;
            }

            $empty.hide();
            $board.find('.itinerary-stop').remove();
            var latlngs = [];

            selected.each(function (idx) {
                var $row = $(this).closest('.picker-row');
                var name = $row.find('label strong').text();
                var arr = $row.find('input[type=date]').eq(0).val();
                var dep = $row.find('input[type=date]').eq(1).val();
                var lat = parseFloat($row.attr('data-lat'));
                var lng = parseFloat($row.attr('data-lng'));

                var $stop = $('<div class="itinerary-stop"></div>');
                $stop.append('<div class="itinerary-order">' + (idx + 1) + '</div>');
                $stop.append('<div><strong>' + name + '</strong>' +
                    '<div class="text-muted small">' +
                    (arr ? 'Arrive ' + arr : '') +
                    (dep ? ' &middot; Depart ' + dep : '') + '</div></div>');
                $board.append($stop);

                $preview.append('<li>' + name + '</li>');

                if (!isNaN(lat) && !isNaN(lng) && tripMap && tripMap.addStopOverlay) {
                    var overlay = tripMap.addStopOverlay(lat, lng, idx + 1);
                    latlngs.push([lat, lng]);
                }
            });

            if (latlngs.length > 1 && tripMap && tripMap.fitBounds) {
                tripMap.fitBounds(latlngs);
            }
        }

        $checks.on('change', function () {
            $(this).closest('.picker-row').find('.picker-dates').toggleClass('d-none', !this.checked);
            refresh();
        });

        refresh();

        // ---- Planning filter bar (Item 4) ----
        function updateDuration() {
            var start = $('#StartDate').val();
            var end = $('#EndDate').val();
            if (start && end) {
                var d1 = new Date(start), d2 = new Date(end);
                var days = Math.round((d2 - d1) / 86400000) + 1;
                $('#tripDuration').text((days > 0 ? days : 0) + (days === 1 ? ' day' : ' days'));
            } else {
                $('#tripDuration').text('—');
            }
        }

        function applyTripFilter() {
            var interests = [];
            $('#tripInterests input:checked').each(function () {
                interests.push({ cat: $(this).data('category'), st: $(this).data('status') });
            });

            var budgetRaw = $('#Budget').val();
            var budget = parseFloat(budgetRaw);
            var budgetSet = !isNaN(budget);
            var hasFilter = interests.length > 0 || budgetSet;

            $('.picker-row').each(function () {
                var cat = $(this).data('category');
                var st = $(this).data('status');
                var price = parseFloat($(this).data('price')) || 0;

                var interestMatch = interests.length === 0;
                for (var j = 0; j < interests.length; j++) {
                    if (interests[j].cat && cat === interests[j].cat) { interestMatch = true; break; }
                    if (interests[j].st && st === interests[j].st) { interestMatch = true; break; }
                }

                var budgetMatch = !budgetSet || price <= budget;
                var match = interestMatch && budgetMatch;

                if (!hasFilter || match) {
                    $(this).show();
                    $(this).toggleClass('match-highlight', hasFilter && match);
                } else {
                    $(this).hide();
                    $(this).removeClass('match-highlight');
                }
            });

            if (tripMap && tripMap.filterMarkers) tripMap.filterMarkers(tripPredicate);
            toggleTripEmpty();
            fitTripBounds();
        }

        function fitTripBounds() {
            if (!tripMap || !tripMap.fitBounds) return;
            var latlngs = [];
            $('.picker-row').each(function () {
                if ($(this).css('display') === 'none') return;
                var lat = parseFloat($(this).attr('data-lat'));
                var lng = parseFloat($(this).attr('data-lng'));
                if (!isNaN(lat) && !isNaN(lng)) latlngs.push([lat, lng]);
            });
            if (latlngs.length === 0) return;
            tripMap.fitBounds(latlngs);
        }

        function toggleTripEmpty() {
            var visible = $('.picker-row:visible');
            var empty = document.getElementById('tripEmptyFilter');
            if (empty) empty.style.display = visible.length === 0 ? '' : 'none';
        }

        $('#StartDate, #EndDate').on('change', updateDuration);
        $('#tripFilterBtn').on('click', applyTripFilter);
        $('#tripInterests input, #Budget').on('change', function () {
            if ($('#tripInterests input:checked').length || $('#Budget').val()) applyTripFilter();
        });

        updateDuration();
    })();
</script>
}
