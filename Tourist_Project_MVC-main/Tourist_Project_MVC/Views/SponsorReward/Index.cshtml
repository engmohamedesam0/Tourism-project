@model IEnumerable<Tourist_Project_MVC.Models.Reward>

@{
    ViewData["Title"] = @Localizer["SponsorReward_MyRewards"].Value;
}

<div class="inner-page-wrapper">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="page-title mb-0">🎁 @Localizer["SponsorReward_MyRewards"].Value</h2>
            <a asp-action="Create" class="btn btn-success px-4">
                <i class="bi bi-plus-lg me-1"></i> @Localizer["SponsorReward_AddReward"].Value
            </a>
        </div>

    @await Html.PartialAsync("_StatBoxRow", (List<Tourist_Project_MVC.View_Model.StatBoxItem>)ViewBag.StatBoxes)

        <div class="table-responsive">
            <table class="table table-hover align-middle destinations-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>@Localizer["SponsorReward_TableTitle"].Value</th>
                        <th>@Localizer["SponsorReward_TableType"].Value</th>
                        <th>@Localizer["SponsorReward_TablePoints"].Value</th>
                        <th>@Localizer["SponsorReward_TableQty"].Value</th>
                        <th>@Localizer["SponsorReward_TableRedemptions"].Value</th>
                        <th>@Localizer["SponsorReward_TableStatus"].Value</th>
                        <th>@Localizer["SponsorReward_TableActions"].Value</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        var redemptionCount = item.Redemptions?.Count ?? 0;
                        var redemptionRate = item.QuantityAvailable > 0
                            ? (redemptionCount / (double)item.QuantityAvailable * 100).ToString("F1")
                            : "0.0";
                        <tr>
                            <td class="fw-bold text-muted">@i.ToString("D2")</td>
                            <td><div class="fw-bold">@item.Title</div></td>
                            <td><span class="badge-category">@item.RewardType</span></td>
                            <td>@item.PointsRequired @Localizer["SponsorReward_Pts"].Value</td>
                            <td>@item.QuantityAvailable</td>
                            <td>
                                <span class="fw-bold" style="color: var(--egy-primary);">@redemptionRate%</span>
                                <small class="text-muted">(@redemptionCount)</small>
                            </td>
                            <td>
                                @switch (item.Status)
                                {
                                    case "Active":
                                        <span class="badge bg-success">@Localizer["SponsorReward_Active"].Value</span>
                                        break;
                                    case "Paused":
                                        <span class="badge bg-warning text-dark">@Localizer["SponsorReward_Paused"].Value</span>
                                        break;
                                    case "Expired":
                                        <span class="badge bg-secondary">@Localizer["SponsorReward_Expired"].Value</span>
                                        break;
                                    case "Removed":
                                        <span class="badge bg-danger">@Localizer["SponsorReward_Removed"].Value</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@item.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-warning" title="@Localizer["SponsorReward_Edit"].Value">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="@Localizer["SponsorReward_Delete"].Value">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-gift" style="font-size:3rem; color:var(--egy-primary);"></i>
                <p class="text-muted mt-2">@Localizer["SponsorReward_EmptyState"].Value</p>
            </div>
        }
    </div>
</div>
