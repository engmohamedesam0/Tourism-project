@model Tourist_Project_MVC.Models.Sponsor

    @{
        ViewData["Title"] = "Sponsor Details";
        var avgRating = Model.Reviews != null && Model.Reviews.Any()
            ? Model.Reviews.Average(r => r.Rating)
            : 0;
        var avgStars = (int)Math.Round(avgRating);
        var displayBranch = Model.Branches?.FirstOrDefault();
        var displayLat = displayBranch?.Location?.Y ?? 0;
        var displayLong = displayBranch?.Location?.X ?? 0;
    }

<div class="container my-4" style="max-width: 960px;">

    <!-- Header -->
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #2C1A0E, #C8832A);">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h4 class="text-white mb-0">
                    <i class="bi bi-building-fill me-2"></i> @Model.Name
                </h4>
                <span class="badge bg-light text-dark fs-6">@Model.Type</span>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row text-center mb-3">
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-star-fill text-warning"></i>
                        <div class="stat-mini-number">
                            @(avgRating > 0 ? avgRating.ToString("0.0") : "—")
                        </div>
                        <div class="stat-mini-label">Avg Rating</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-geo-alt-fill text-danger"></i>
                        <div class="stat-mini-number" style="font-size:1rem;">
                            @Model.Address
                        </div>
                        <div class="stat-mini-label">Address</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-telephone-fill text-success"></i>
                        <div class="stat-mini-number" style="font-size:1.1rem;">
                            @Model.ContactNumber
                        </div>
                        <div class="stat-mini-label">Contact</div>
                    </div>
                </div>
            </div>

            <!-- Map placeholder -->
            <div id="sponsorMap" class="sponsor-map-container"
                 data-lat="@displayLat" data-lng="@displayLong" data-id="@Model.Id">
                <div class="map-watermark">
                    <i class="bi bi-geo-alt" style="font-size: 2.5rem;"></i>
                    <p class="mb-0 mt-2 small">Map will render here</p>
                    <small class="text-muted">data-lat="@displayLat" data-lng="@displayLong"</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews + Add Review -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-chat-square-quote-fill me-2 text-primary"></i> Reviews
                <span class="badge bg-secondary ms-1">@(Model.Reviews?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body p-4">
            @if (User.IsInRole("User"))
            {
                <form asp-controller="NearMe" asp-action="AddReview" asp-route-id="@Model.Id" method="post" class="mb-4 p-3 border rounded-3 bg-light">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="0" />
                    <div class="row g-2 align-items-end">
                        <div class="col-auto">
                            <label class="form-label small mb-1">Your rating</label>
                            <select name="Rating" class="form-select form-select-sm" required>
                                <option value="5">5 ★ Excellent</option>
                                <option value="4">4 ★ Good</option>
                                <option value="3">3 ★ OK</option>
                                <option value="2">2 ★ Poor</option>
                                <option value="1">1 ★ Bad</option>
                            </select>
                        </div>
                        <div class="col">
                            <label class="form-label small mb-1">Comment</label>
                            <input name="Comment" class="form-control form-control-sm" placeholder="Share your experience…" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-success btn-sm">
                                <i class="bi bi-send-fill me-1"></i> Post Review
                            </button>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <p class="text-muted small mb-3">
                    <a asp-controller="Account" asp-action="Login">Sign in</a> as a tourist to post a review.
                </p>
            }

            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedDate))
                {
                    var rStars = review.Rating;
                    <div class="border-bottom pb-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>@(review.Tourist?.Name ?? "Tourist")</strong>
                            <small class="text-muted">@review.CreatedDate.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="mb-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= rStars)
                                {
                                    <i class="bi bi-star-fill text-warning small"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-muted small"></i>
                                }
                            }
                        </div>
                        <p class="mb-0 small">@review.Comment</p>
                    </div>
                }
            }
            else
            {
                <p class="text-muted mb-0">No reviews yet. Be the first to share your experience!</p>
            }
        </div>
    </div>

    <!-- Menu -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0"><i class="bi bi-menu-button-fill me-2 text-primary"></i> Menu</h5>
        </div>
        <div class="card-body p-4">
            @if (Model.MenuItems != null && Model.MenuItems.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Description</th>
                                <th class="text-end">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.MenuItems)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Name</td>
                                    <td class="text-muted small">@item.Description</td>
                                    <td class="text-end">@item.Price.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No menu items listed.</p>
            }
        </div>
    </div>

    <!-- Rewards from this sponsor -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0"><i class="bi bi-gift-fill me-2 text-primary"></i> Rewards from this partner</h5>
        </div>
        <div class="card-body p-4">
            @if (Model.Rewards != null && Model.Rewards.Any())
            {
                <div class="row g-3">
                    @foreach (var reward in Model.Rewards)
                    {
                        <div class="col-md-6">
                            <div class="border rounded-3 p-3 h-100">
                                <span class="badge bg-warning text-dark mb-1">@reward.RewardType</span>
                                <h6 class="mb-1">@reward.Title</h6>
                                <p class="small text-muted mb-0">@reward.Description</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No rewards linked to this partner yet.</p>
            }
        </div>
    </div>

    <a asp-controller="NearMe" asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left me-1"></i> Back to Near Me
    </a>
</div>

@section Scripts {
    <style>
        .sponsor-map-container {
            height: 240px;
            border-radius: 12px;
            border: 1px dashed rgba(200, 131, 42, 0.5);
            background: repeating-linear-gradient(45deg, #e7e0d5 0 18px, #efe9df 18px 36px);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stat-mini-card {
            background: #FDF6EC;
            border: 1px solid #E8A045;
            border-radius: 12px;
            padding: 12px 8px;
        }

        .stat-mini-number {
            font-family: 'Cinzel', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: #2C1A0E;
            margin: 6px 0 2px;
        }

        .stat-mini-label {
            font-size: 0.7rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
}
