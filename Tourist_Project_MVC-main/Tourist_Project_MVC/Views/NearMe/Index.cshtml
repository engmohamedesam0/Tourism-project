@model Tourist_Project_MVC.View_Model.NearMeIndexVM

@{
    ViewData["Title"] = "Near Me";
    ViewData["IsHomePage"] = true;
}

<div class="nearme-page">
    <div class="container-fluid">
        <div class="row g-0">

            <!-- LEFT PANEL: filters + sponsor list -->
            <div class="col-lg-5 col-xl-4 nearme-list-panel">

                <div class="nearme-header">
                    <h2 class="page-title mb-0">
                        <i class="bi bi-geo-fill me-1"></i> @Localizer["NearMe_Title"].Value <span class="text-accent">@Model.DestinationName</span>
                    </h2>
                    <p class="text-muted small mb-2">@Localizer["NearMe_Subtitle"].Value</p>

                    <!-- Destination picker (re-GET to Index) -->
                    <form method="get" id="nearMeForm" class="nearme-filter-form">
                        <input type="hidden" name="type" value="@Model.Type" />
                        <input type="hidden" name="rating" value="@Model.Rating" />
                        <input type="hidden" name="distance" value="@Model.Distance" />

                        <div class="mb-2">
                            <label class="form-label small text-muted mb-1">@Localizer["NearMe_Reference"].Value</label>
                            <select name="destinationId" class="form-select form-select-sm"
                                    onchange="applyNearMeFilter('destinationId', this.value)">
                                @foreach (var d in Model.Destinations)
                                {
                                    <option value="@d.Value" selected="@d.Selected">@d.Text</option>
                                }
                            </select>
                        </div>

                        <div class="input-group input-group-sm mb-2">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="search" class="form-control border-start-0"
                                   placeholder="@Localizer["NearMe_SearchPlaceholder"].Value" value="@Model.Search" />
                             <button class="btn btn-outline-secondary" type="submit">@Localizer["NearMe_Go"].Value</button>
                        </div>
                    </form>
                </div>

                <!-- Type chips -->
                <div class="nearme-chips">
                    <span class="chip-label">@Localizer["NearMe_Type"].Value</span>
                    <button type="button" class="chip @(string.IsNullOrEmpty(Model.Type) ? "chip-active" : "")"
                            onclick="applyNearMeFilter('type', null)">@Localizer["NearMe_All"].Value</button>
                    <button type="button" class="chip @(Model.Type == "Hotel" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('type','Hotel')">@Localizer["NearMe_Hotel"].Value</button>
                    <button type="button" class="chip @(Model.Type == "Airline" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('type','Airline')">@Localizer["NearMe_Airline"].Value</button>
                    <button type="button" class="chip @(Model.Type == "Tourism Agency" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('type','Tourism Agency')">@Localizer["NearMe_Agency"].Value</button>
                </div>

                <!-- Rating chips -->
                <div class="nearme-chips">
                    <span class="chip-label">@Localizer["NearMe_Rating"].Value</span>
                    <button type="button" class="chip @(string.IsNullOrEmpty(Model.Rating) ? "chip-active" : "")"
                            onclick="applyNearMeFilter('rating', null)">@Localizer["NearMe_Any"].Value</button>
                    <button type="button" class="chip @(Model.Rating == "4" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('rating','4')">4★+</button>
                    <button type="button" class="chip @(Model.Rating == "5" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('rating','5')">5★</button>
                </div>

                <!-- Distance chips -->
                <div class="nearme-chips">
                    <span class="chip-label">@Localizer["NearMe_Distance"].Value</span>
                    <button type="button" class="chip @(string.IsNullOrEmpty(Model.Distance) ? "chip-active" : "")"
                            onclick="applyNearMeFilter('distance', null)">@Localizer["NearMe_Any"].Value</button>
                    <button type="button" class="chip @(Model.Distance == "5" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('distance','5')">≤ 5 km</button>
                    <button type="button" class="chip @(Model.Distance == "10" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('distance','10')">≤ 10 km</button>
                    <button type="button" class="chip @(Model.Distance == "25" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('distance','25')">≤ 25 km</button>
                </div>

                <!-- Sort -->
                <div class="nearme-chips">
                    <span class="chip-label">@Localizer["NearMe_Sort"].Value</span>
                    <button type="button" class="chip @(Model.Sort != "rating" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('sort','distance')">@Localizer["NearMe_Nearest"].Value</button>
                    <button type="button" class="chip @(Model.Sort == "rating" ? "chip-active" : "")"
                            onclick="applyNearMeFilter('sort','rating')">@Localizer["NearMe_TopRated"].Value</button>
                </div>

                <!-- Sponsor list -->
                <div class="nearme-list" id="nearMeList">
                    @foreach (var card in Model.Cards)
                    {
                        var avg = (int)Math.Round(card.AvgRating);
                        <div class="nearme-card stat-card" data-id="@card.Sponsor.Id" data-lat="@card.Lat"
                             data-lng="@card.Long" data-name="@card.Sponsor.Name">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h5 class="nearme-card-title mb-0">@card.Sponsor.Name</h5>
                                     <span class="distance-badge" title="@Localizer["NearMe_DistanceTitle"].Value">
                                    <i class="bi bi-geo-alt-fill"></i> @card.DistanceKm.ToString("0.#") km
                                </span>
                            </div>

                            <span class="badge-category">@card.Sponsor.Type</span>

                            <div class="nearme-rating small mt-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= avg)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-muted"></i>
                                    }
                                }
                                <span class="text-muted ms-1">
                                    @(card.ReviewCount > 0 ? card.AvgRating.ToString("0.0") : @Localizer["Explore_New"].Value)
                                    (@card.ReviewCount)
                                </span>
                            </div>

                            <div class="mt-2 d-flex gap-2">
                                 <a asp-controller="NearMe" asp-action="Details" asp-route-id="@card.Sponsor.Id"
                                    class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye-fill me-1"></i> @Localizer["Explore_Details"].Value
                                </a>
                            </div>
                        </div>
                    }

                    @if (!Model.Cards.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-geo-alt" style="font-size: 2.5rem; color: var(--egy-primary);"></i>
                            <p class="mt-2 mb-0">@Localizer["NearMe_NoSponsors"].Value</p>
                        </div>
                    }
                </div>
            </div>

            <!-- RIGHT PANEL: map placeholder -->
            <div class="col-lg-7 col-xl-8 nearme-map-panel">
                <div id="nearbyMap" class="nearme-map-container">
                    <div class="map-watermark">
                        <i class="bi bi-map" style="font-size: 3rem;"></i>
                        <p class="mb-0 mt-2">@Localizer["Explore_MapPlaceholder"].Value</p>
                        <small class="text-muted">@Localizer["Explore_MapNote"].Value</small>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@if (ViewBag.NearMeCarousel is Tourist_Project_MVC.View_Model.ReviewsCarouselVM nearMeVm && nearMeVm.Items != null && nearMeVm.Items.Any())
{
    <div class="container my-4" style="max-width: 1200px;">
        @await Html.PartialAsync("_ReviewsCarousel", nearMeVm)
    </div>
}

@section Scripts {
    <style>
        .nearme-page {
            padding-top: var(--nav-offset);
        }

        .nearme-list-panel {
            background: var(--egy-light);
            border-right: 1px solid rgba(200, 131, 42, 0.2);
            height: calc(100vh - var(--nav-offset));
            display: flex;
            flex-direction: column;
        }

        .nearme-header {
            padding: 20px 20px 0;
        }

        .nearme-header .text-accent {
            color: var(--egy-primary);
        }

        .nearme-filter-form .form-select-sm {
            font-family: 'Nunito', sans-serif;
        }

        .nearme-chips {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 8px;
            padding: 8px 20px 0;
        }

        .chip-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            font-weight: 700;
        }

        .nearme-list {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px 40px;
        }

        .nearme-card {
            background: #fff;
            border: 1px solid rgba(200, 131, 42, 0.25) !important;
            border-radius: 14px;
            padding: 16px 18px;
            margin-bottom: 14px;
            transition: all 0.3s ease;
        }

        .nearme-card:hover {
            background: #fff !important;
            border-color: var(--egy-primary) !important;
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(200, 131, 42, 0.18);
        }

        .nearme-card::before {
            display: none;
        }

        .nearme-card-title {
            font-family: 'Cinzel', serif;
            color: var(--egy-dark);
            font-size: 1.05rem;
        }

        .distance-badge {
            background: rgba(200, 131, 42, 0.12);
            color: var(--egy-muted-gold);
            border: 1px solid var(--egy-accent);
            border-radius: 20px;
            padding: 2px 10px;
            font-size: 0.78rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .distance-badge i {
            color: var(--egy-primary);
        }

        .nearme-map-panel {
            height: calc(100vh - var(--nav-offset));
            background: #ece6db;
            position: relative;
        }

        .nearme-map-container {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: repeating-linear-gradient(45deg, #e7e0d5 0 18px, #efe9df 18px 36px);
        }

        .map-watermark {
            text-align: center;
            color: var(--egy-muted-gold);
            opacity: 0.75;
        }

        @@media (max-width: 991.98px) {

            .nearme-list-panel,
            .nearme-map-panel {
                height: auto;
            }

            .nearme-map-panel {
                min-height: 320px;
                position: relative;
            }

            .nearme-map-container {
                position: relative;
                inset: auto;
            }

            .nearme-list {
                max-height: 60vh;
            }
        }
    </style>

    <script>
        function applyNearMeFilter(key, value) {
            var form = document.getElementById('nearMeForm');
            var input = form.querySelector('input[name="' + key + '"]');
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.name = key;
                form.appendChild(input);
            }
            input.value = (value === null) ? '' : value;
            form.submit();
        }

        (function () {
            var nearMePropMap = {
                id: ['id', 'Id', 'sponsor_id', 'SponsorId'],
                name: ['name', 'Name', 'sponsor_name'],
                city: ['city', 'City'],
                category: ['category', 'Category', 'type', 'Type'],
                detailsUrl: '/NearMe/Details/{id}'
            };

            function buildPopup(feature) {
                var p = feature.properties || {};
                var id = _firstDefined(p, nearMePropMap.id, []);
                var name = _firstDefined(p, nearMePropMap.name, ['Sponsor']);
                var city = _firstDefined(p, nearMePropMap.city, ['']);
                var cat = _firstDefined(p, nearMePropMap.category, ['']);
                var html = '';
                if (name) html += '<strong>' + _esc(name) + '</strong>';
                if (cat) html += '<br><span class="badge bg-secondary">' + _esc(cat) + '</span>';
                if (id && nearMePropMap.detailsUrl) {
                    html += '<br><a href="' + nearMePropMap.detailsUrl.replace('{id}', encodeURIComponent(id)) + '" class="btn btn-sm btn-outline-primary mt-1">View Details</a>';
                }
                return html;
            }

            function _esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
            function _firstDefined(p, keys, fallback) {
                for (var i = 0; i < keys.length; i++) {
                    var val = p[keys[i]];
                    if (val !== undefined && val !== null && String(val) !== '') return String(val);
                }
                return fallback[0] || '';
            }

            var nearMeMap = EGYMaps.initWfsMap({
                mapElId: 'nearbyMap',
                proxyUrl: '/Map/GetBranchesGeoJson',
                propMap: nearMePropMap,
                popupHtml: buildPopup,
                markerStyle: { radius: 9, fillColor: '#2e9e5b', color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.85 },
                onLayerReady: function () {
                    var visibleSponsorIds = Array.prototype.slice
                        .call(document.querySelectorAll('#nearMeList .nearme-card[data-id]'))
                        .map(function (el) { return el.getAttribute('data-id'); });
                    nearMeMap.filterMarkers(function (f) {
                        var sid = _firstDefined(f.properties, ['sponsor_id', 'SponsorId', 'sponsorId']);
                        return visibleSponsorIds.indexOf(String(sid)) > -1;
                    });
                }
            });
        })();
    </script>
}
