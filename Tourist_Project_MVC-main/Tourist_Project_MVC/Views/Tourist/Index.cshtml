@model IEnumerable<Tourist_Project_MVC.Models.Tourist>
@{
    ViewData["Title"] = Localizer["TouristAdmin_Title"].Value;
}

<div class="container-fluid mt-4 px-md-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4 page-header-section">
        <div>
            <h2 class="page-title text-uppercase mb-1">
                <span class="header-icon">🧳</span> @Localizer["TouristAdmin_Heading"].Value
            </h2>
            <p class="text-muted small mb-0">
                @Localizer["TouristAdmin_Total"].Value: <span class="badge bg-secondary">@ViewBag.AllCount</span> @Localizer["TouristAdmin_TotalTourists"].Value
            </p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-egy-success px-4 py-2 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> @Localizer["TouristAdmin_Add"].Value
            </a>
        }
    </div>

    <!-- Stat boxes -->
    @await Html.PartialAsync("_StatBoxRow", (List<Tourist_Project_MVC.View_Model.StatBoxItem>)ViewBag.StatBoxes)

    <!-- Filter Bar Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 filter-card">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" id="filterForm">
                <div class="row g-3 align-items-center">
                    <div class="col-md-7 col-lg-8">
                        <div class="input-group search-input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="search"
                                   id="touristSearchInput"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="@Localizer["TouristAdmin_SearchPlaceholder"].Value"
                                   value="@ViewBag.Search" />
                            @if (!string.IsNullOrEmpty(ViewBag.Search))
                            {
                                <button type="button" class="btn bg-transparent border-0 text-muted clear-search-btn" onclick="clearSearch()">
                                    <i class="bi bi-x-circle-fill"></i>
                                </button>
                            }
                            <input type="hidden" name="nationality" value="@ViewBag.Nationality" />
                        </div>
                    </div>
                    <div class="col-md-5 col-lg-4">
                        <div class="input-group select-input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="bi bi-globe"></i>
                            </span>
                            <select class="form-select border-start-0 ps-0 filter-select" onchange="window.location.href=this.value">
                                <option value="@Url.Action("Index", new { search = ViewBag.Search })">
                                    @Localizer["TouristAdmin_AllNationalities"].Value
                                </option>
                                @foreach (var nat in ViewBag.Nationalities as List<string> ?? new List<string>())
                                {
                                    var url = Url.Action("Index", new { search = ViewBag.Search, nationality = nat });
                                    bool isSelected = ViewBag.Nationality == nat;
                                    <option value="@url" selected="@(isSelected ? "selected" : null)">@nat</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden table-card">
        <div class="table-responsive">
            <table class="table align-middle custom-tourist-table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">#</th>
                        <th>@Localizer["TouristAdmin_Name"].Value</th>
                        <th>@Localizer["TouristAdmin_Nationality"].Value</th>
                        <th>@Localizer["TouristAdmin_Points"].Value</th>
                        <th>@Localizer["TouristAdmin_Missions"].Value</th>
                        <th>@Localizer["TouristAdmin_Trips"].Value</th>
                        <th>@Localizer["TouristAdmin_Status"].Value</th>
                        <th class="pe-4 text-end">@Localizer["TouristAdmin_Actions"].Value</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        var missionCount = item.UserMissions?.Count ?? 0;
                        var completedMissions = item.UserMissions?.Count(m => m.Status == "Completed") ?? 0;
                        var tripCount = item.TripPlans?.Count ?? 0;
                        var activeTrips = item.TripPlans?.Count(t => t.Status == "Active") ?? 0;

                        var statusClass = item.Status switch
                        {
                            "Active" => "badge-status-active",
                            "Inactive" => "badge-status-inactive",
                            "Suspended" => "badge-status-pending",
                            _ => "badge-status-active"
                        };

                        <tr>
                            <td class="ps-4 fw-semibold text-secondary-egy">#@i.ToString("D2")</td>
                            <td>
                                <div class="fw-bold text-dark font-cinzel">@item.Name</div>
                                <div class="text-muted small">@item.Email</div>
                            </td>
                            <td>
                                <span class="badge badge-nationality">
                                    <i class="bi bi-geo-alt me-1"></i> @item.Nationality
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-points">
                                    <i class="bi bi-star-fill text-warning me-1"></i>
                                    @item.point_Balance @Localizer["TouristAdmin_Pts"].Value
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1 text-dark">
                                    <i class="bi bi-trophy-fill text-warning"></i>
                                    <strong class="font-cinzel">@missionCount</strong>
                                    <small class="text-muted">(@completedMissions @Localizer["TouristAdmin_Done"].Value)</small>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1 text-dark">
                                    <i class="bi bi-map-fill text-info"></i>
                                    <strong class="font-cinzel">@tripCount</strong>
                                    <small class="text-muted">(@activeTrips @Localizer["TouristAdmin_Active"].Value)</small>
                                </div>
                            </td>
                            <td>
                                <span class="badge-status-custom @statusClass">@item.Status</span>
                            </td>
                            <td class="pe-4 text-end">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-action-view" title="@Localizer["TouristAdmin_Details"].Value">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-action-edit" title="@Localizer["TouristAdmin_Edit"].Value">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-action-delete" title="@Localizer["TouristAdmin_Delete"].Value">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border py-1.5 px-3">
                                        <i class="bi bi-lock me-1"></i> @Localizer["TouristAdmin_GuestsOnly"].Value
                                    </span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 empty-state-container">
                <div class="empty-state-icon mb-3">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h5 class="fw-bold font-cinzel">@Localizer["TouristAdmin_NoTourists"].Value</h5>
                <p class="text-muted small">Try adjusting your filters or search term.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        .page-header-section {
            border-bottom: 2px solid var(--egy-primary);
            padding-bottom: 1rem;
        }

        .text-secondary-egy {
            color: var(--egy-muted-gold);
        }

        .btn-egy-success {
            background-color: var(--egy-success);
            color: #ffffff;
            border: none;
            border-radius: var(--radius-md);
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .btn-egy-success:hover {
            background-color: var(--egy-success-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(46, 125, 50, 0.25);
            color: #ffffff;
        }

        /* Filter Card */
        .filter-card {
            background-color: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.15) !important;
            box-shadow: var(--shadow-soft) !important;
        }

        .search-input-group, .select-input-group {
            background-color: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-md);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .search-input-group:focus-within, .select-input-group:focus-within {
            border-color: var(--egy-primary);
            box-shadow: 0 0 0 3px rgba(200, 131, 42, 0.15);
        }

        .search-input-group input, .select-input-group select {
            border: none !important;
            box-shadow: none !important;
            padding-top: 0.6rem;
            padding-bottom: 0.6rem;
        }

        .search-input-group input:focus, .select-input-group select:focus {
            outline: none !important;
        }

        /* Table Design */
        .table-card {
            border: 1px solid rgba(200, 131, 42, 0.1) !important;
            box-shadow: var(--shadow-medium) !important;
        }

        .custom-tourist-table thead {
            background-color: var(--egy-dark);
            color: #ffffff;
        }

        .custom-tourist-table thead th {
            font-family: 'Cinzel', serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            padding-top: 1.1rem;
            padding-bottom: 1.1rem;
            border: none;
        }

        .custom-tourist-table tbody tr {
            border-bottom: 1px solid rgba(200, 131, 42, 0.08);
            transition: background-color 0.2s ease;
        }

        .custom-tourist-table tbody tr:last-child {
            border-bottom: none;
        }

        .custom-tourist-table tbody tr:hover {
            background-color: rgba(200, 131, 42, 0.04);
        }

        .custom-tourist-table td {
            padding-top: 1.1rem;
            padding-bottom: 1.1rem;
        }

        /* Badges */
        .badge-nationality {
            background-color: rgba(200, 131, 42, 0.1);
            color: var(--egy-muted-gold);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.5rem 0.8rem;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .badge-points {
            background-color: rgba(232, 160, 69, 0.15);
            color: var(--egy-dark);
            border: 1px solid var(--egy-accent);
            border-radius: var(--radius-md);
            padding: 0.5rem 0.8rem;
            font-size: 0.82rem;
            font-weight: 700;
        }

        /* Custom Status Badges */
        .badge-status-custom {
            padding: 0.4rem 0.9rem;
            border-radius: var(--radius-pill);
            font-size: 0.8rem;
            font-weight: 700;
            display: inline-block;
        }

        .badge-status-active {
            background-color: #d1e7dd;
            color: #0f5132;
            border: 1px solid #badbcc;
        }

        .badge-status-inactive {
            background-color: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .badge-status-pending {
            background-color: #fff3cd;
            color: #664d03;
            border: 1px solid #ffecb5;
        }

        /* Action Buttons */
        .btn-action-view, .btn-action-edit, .btn-action-delete {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-md);
            border: 1px solid;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }

        .btn-action-view {
            color: #0d6efd;
            border-color: rgba(13, 110, 253, 0.25);
        }
        .btn-action-view:hover {
            background-color: #0d6efd;
            color: #ffffff;
            border-color: #0d6efd;
            transform: translateY(-2px);
        }

        .btn-action-edit {
            color: var(--egy-primary);
            border-color: rgba(200, 131, 42, 0.25);
        }
        .btn-action-edit:hover {
            background-color: var(--egy-primary);
            color: #ffffff;
            border-color: var(--egy-primary);
            transform: translateY(-2px);
        }

        .btn-action-delete {
            color: #dc3545;
            border-color: rgba(220, 53, 69, 0.25);
        }
        .btn-action-delete:hover {
            background-color: #dc3545;
            color: #ffffff;
            border-color: #dc3545;
            transform: translateY(-2px);
        }

        /* Empty State */
        .empty-state-container {
            background-color: #ffffff;
            border-radius: var(--radius-lg);
        }

        .empty-state-icon {
            font-size: 3rem;
            color: var(--egy-primary);
            animation: bounce 2s infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
        }
    </style>
    <script>
        document.getElementById('touristSearchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('filterForm').submit();
            }
        });

        function clearSearch() {
            document.getElementById('touristSearchInput').value = '';
            document.getElementById('filterForm').submit();
        }
    </script>
}