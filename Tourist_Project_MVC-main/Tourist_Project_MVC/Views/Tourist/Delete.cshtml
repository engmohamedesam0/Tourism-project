@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = @Localizer["TouristAdmin_DeleteTourist"].Value;
}
@if (User.Identity.IsAuthenticated)
{
<div class="container mt-4">
    <h2 class="text-danger">🗑️ @Localizer["TouristAdmin_DeleteTourist"].Value</h2>
    <hr />
    <p class="lead">@Localizer["TouristAdmin_DeleteConfirm"].Value <strong>@Model.Name</strong>?</p>

    <dl class="row">
        <dt class="col-sm-3">@Localizer["TouristAdmin_Nationality"].Value</dt>
        <dd class="col-sm-9">@Model.Nationality</dd>

        <dt class="col-sm-3">@Localizer["TouristAdmin_Email"].Value</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">@Localizer["TouristAdmin_PointBalance"].Value</dt>
        <dd class="col-sm-9">@Model.point_Balance pts</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">@Localizer["TouristAdmin_YesDelete"].Value</button>
        <a asp-action="Index" class="btn btn-secondary">@Localizer["TouristAdmin_Cancel"].Value</a>
    </form>
</div>
}