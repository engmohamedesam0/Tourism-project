@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = "Add Tourist";
}

@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4" style="max-width: 700px;">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <div class="card-header py-3"
                 style="background: linear-gradient(135deg, #2C1A0E, #C8832A);">
                <h4 class="text-white mb-0">
                    <i class="bi bi-plus-circle-fill me-2"></i> Add New Tourist
                </h4>
            </div>

            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Nationality" class="form-label fw-bold"></label>
                        <input asp-for="Nationality" class="form-control" />
                        <span asp-validation-for="Nationality" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-bold"></label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IdNumber" class="form-label fw-bold">ID Number</label>
                        <input asp-for="IdNumber" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Passport" class="form-label fw-bold"></label>
                        <input asp-for="Passport" class="form-control" />
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-lg me-1"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
}