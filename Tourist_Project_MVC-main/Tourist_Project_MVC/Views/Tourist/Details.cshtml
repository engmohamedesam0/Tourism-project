@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = "Tourist Details";
}

@if (User.Identity.IsAuthenticated)
{
    var completedMissions = Model.UserMissions?.Count(m => m.Status == "Completed") ?? 0;
    var inProgressMissions = Model.UserMissions?.Count(m => m.Status == "In Progress") ?? 0;
    var totalMissions = Model.UserMissions?.Count ?? 0;
    var activeTrips = Model.TripPlans?.Count(t => t.Status == "Active") ?? 0;
    var totalTrips = Model.TripPlans?.Count ?? 0;

    var statusClass = Model.Status switch
    {
        "Active" => "bg-success",
        "Inactive" => "bg-danger",
        "Suspended" => "bg-warning text-dark",
        _ => "bg-success"
    };

    <div class="container mt-4" style="max-width: 900px;">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <div class="card-header py-3"
                 style="background: linear-gradient(135deg, #2C1A0E, #C8832A);">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="text-white mb-0">
                        <i class="bi bi-person-fill me-2"></i> @Model.Name
                    </h4>
                    <span class="badge @statusClass fs-6">@Model.Status</span>
                </div>
            </div>

            <div class="card-body p-4">

                <div class="row text-center mb-4">
                    <div class="col-3">
                        <div class="stat-mini-card">
                            <i class="bi bi-trophy-fill text-warning"></i>
                            <div class="stat-mini-number">@totalMissions</div>
                            <div class="stat-mini-label">Total Missions</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-mini-card">
                            <i class="bi bi-check-circle-fill text-success"></i>
                            <div class="stat-mini-number">@completedMissions</div>
                            <div class="stat-mini-label">Completed</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-mini-card">
                            <i class="bi bi-map-fill text-info"></i>
                            <div class="stat-mini-number">@totalTrips</div>
                            <div class="stat-mini-label">Total Trips</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-mini-card">
                            <i class="bi bi-airplane-fill text-primary"></i>
                            <div class="stat-mini-number">@activeTrips</div>
                            <div class="stat-mini-label">Active Trips</div>
                        </div>
                    </div>
                </div>

                <hr />


                <dl class="row mb-4">
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 text-muted">Nationality</dt>
                    <dd class="col-sm-8">@Model.Nationality</dd>

                    <dt class="col-sm-4 text-muted">ID Number</dt>
                    <dd class="col-sm-8">@(Model.IdNumber ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Passport</dt>
                    <dd class="col-sm-8">@(Model.Passport ?? "—")</dd>

                    <dt class="col-sm-4 text-muted">Points Balance</dt>
                    <dd class="col-sm-8">
                        <span class="fw-bold" style="color: var(--egy-primary);">
                            @Model.point_Balance pts
                        </span>
                    </dd>

                    <dt class="col-sm-4 text-muted">Register Date</dt>
                    <dd class="col-sm-8">@Model.RegisterDate.ToShortDateString()</dd>
                </dl>

                <hr />


                @if (Model.UserMissions != null && Model.UserMissions.Any())
                {
                    <h5 class="mb-3">
                        <i class="bi bi-trophy-fill me-2" style="color:var(--egy-primary);"></i>
                        Missions
                    </h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-hover align-middle destinations-table">
                            <thead>
                                <tr>
                                    <th>Mission</th>
                                    <th>Points Earned</th>
                                    <th>Status</th>
                                    <th>Completed At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var um in Model.UserMissions)
                                {
                                    var mClass = um.Status switch
                                    {
                                        "Completed" => "badge-status-active",
                                        "In Progress" => "badge-status-pending",
                                        _ => "badge-status-inactive"
                                    };
                                    <tr>
                                        <td><div class="fw-bold">@um.Mission?.Title</div></td>
                                        <td>
                                            <span class="fw-bold" style="color:var(--egy-primary);">
                                                @um.PointsEarned pts
                                            </span>
                                        </td>
                                        <td><span class="badge-status @mClass">@um.Status</span></td>
                                        <td>
                                            @(um.Status == "Completed"
                                                ? um.Completed_At.ToShortDateString()
                                                : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }


                @if (Model.TripPlans != null && Model.TripPlans.Any())
                {
                    <h5 class="mb-3">
                        <i class="bi bi-map-fill me-2" style="color:var(--egy-primary);"></i>
                        Trip Plans
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle destinations-table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trip in Model.TripPlans)
                                {
                                    var tClass = trip.Status switch
                                    {
                                        "Active" => "badge-status-active",
                                        "Completed" => "badge-status-inactive",
                                        "Cancelled" => "badge-status-pending",
                                        _ => "badge-status-active"
                                    };
                                    <tr>
                                        <td><div class="fw-bold">@trip.Title</div></td>
                                        <td>@trip.StartDate.ToShortDateString()</td>
                                        <td>@trip.EndDate.ToShortDateString()</td>
                                        <td>@((trip.EndDate - trip.StartDate).Days) days</td>
                                        <td>
                                            <span class="badge-status @tClass">@trip.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="card-footer bg-white d-flex gap-2 justify-content-end">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-fill me-1"></i> Edit
                </a>
                }
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <style>
        .stat-mini-card {
            background: #FDF6EC;
            border: 1px solid #E8A045;
            border-radius: 12px;
            padding: 15px 10px;
        }

        .stat-mini-number {
            font-family: 'Cinzel',sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: #2C1A0E;
            margin: 6px 0 2px;
        }

        .stat-mini-label {
            font-size: 0.75rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .badge-status {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .badge-status-active {
            background-color: #d4edda;
            color: #155724;
        }

        .badge-status-inactive {
            background-color: #f8d7da;
            color: #721c24;
        }

        .badge-status-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .destinations-table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
    </style>
}