@model Tourist_Project_MVC.Models.Tourist

@{
    ViewData["Title"] = Localizer["TouristAdmin_TouristDetails"].Value;
}

@if (User.Identity.IsAuthenticated)
{
    var completedMissions = Model.UserMissions?.Count(m => m.Status == "Completed") ?? 0;
    var inProgressMissions = Model.UserMissions?.Count(m => m.Status == "In Progress") ?? 0;
    var totalMissions = Model.UserMissions?.Count ?? 0;
    var activeTrips = Model.TripPlans?.Count(t => t.Status == "Active") ?? 0;
    var totalTrips = Model.TripPlans?.Count ?? 0;

    var statusClass = Model.Status switch
    {
        "Active" => "badge-status-active",
        "Inactive" => "badge-status-inactive",
        "Suspended" => "badge-status-pending",
        _ => "badge-status-active"
    };

    <div class="container mt-5 mb-5" style="max-width: 950px;">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden details-card">
            <!-- Card Header -->
            <div class="card-header py-4 header-gradient">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <div>
                        <span class="text-white-50 text-uppercase small tracking-wider fw-bold">Tourist Profile</span>
                        <h3 class="text-white mb-0 mt-1 font-cinzel">
                            <i class="bi bi-person-fill me-2 text-warning-egy"></i> @Model.Name
                        </h3>
                    </div>
                    <span class="badge-status-custom @statusClass fs-6">
                        @Model.Status
                    </span>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4 p-md-5 bg-white">
                <!-- Mini Stats Grid -->
                <div class="row g-3 mb-5 text-center">
                    <!-- Total Missions -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-missions">
                            <div class="stat-icon-wrapper"><i class="bi bi-trophy-fill"></i></div>
                            <div class="stat-value font-cinzel">@totalMissions</div>
                            <div class="stat-label">@Localizer["TouristAdmin_TotalMissions"].Value</div>
                        </div>
                    </div>
                    <!-- Completed -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-completed">
                            <div class="stat-icon-wrapper"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="stat-value font-cinzel">@completedMissions</div>
                            <div class="stat-label">@Localizer["TouristAdmin_Completed"].Value</div>
                        </div>
                    </div>
                    <!-- Total Trips -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-trips">
                            <div class="stat-icon-wrapper"><i class="bi bi-map-fill"></i></div>
                            <div class="stat-value font-cinzel">@totalTrips</div>
                            <div class="stat-label">@Localizer["TouristAdmin_TotalTrips"].Value</div>
                        </div>
                    </div>
                    <!-- Active Trips -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-active-trips">
                            <div class="stat-icon-wrapper"><i class="bi bi-airplane-fill"></i></div>
                            <div class="stat-value font-cinzel">@activeTrips</div>
                            <div class="stat-label">@Localizer["TouristAdmin_ActiveTrips"].Value</div>
                        </div>
                    </div>
                </div>

                <!-- Personal Information -->
                <div class="details-section mb-5">
                    <h5 class="section-title mb-4 font-cinzel text-dark-egy">
                        <i class="bi bi-info-circle-fill me-2 text-primary-egy"></i> Personal Information
                    </h5>
                    
                    <div class="detail-rows-container p-3 rounded-3 bg-light border border-light-egy">
                        <div class="row align-items-center py-2.5 border-bottom border-light-egy-subtle">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_Email"].Value</div>
                            <div class="col-sm-8 text-dark">@Model.Email</div>
                        </div>
                        
                        <div class="row align-items-center py-2.5 border-bottom border-light-egy-subtle">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_Nationality"].Value</div>
                            <div class="col-sm-8 text-dark">
                                <span class="badge badge-nationality">@Model.Nationality</span>
                            </div>
                        </div>
                        
                        <div class="row align-items-center py-2.5 border-bottom border-light-egy-subtle">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_IdNumber"].Value</div>
                            <div class="col-sm-8 text-dark">@(Model.IdNumber ?? Localizer["TouristAdmin_NotSpecified"].Value)</div>
                        </div>
                        
                        <div class="row align-items-center py-2.5 border-bottom border-light-egy-subtle">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_Passport"].Value</div>
                            <div class="col-sm-8 text-dark">@(Model.Passport ?? Localizer["TouristAdmin_NotSpecified"].Value)</div>
                        </div>

                        <div class="row align-items-center py-2.5 border-bottom border-light-egy-subtle">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_PointsBalance"].Value</div>
                            <div class="col-sm-8 text-dark fw-bold text-primary-egy">
                                <i class="bi bi-star-fill text-warning me-1"></i> @Model.point_Balance @Localizer["TouristAdmin_Pts"].Value
                            </div>
                        </div>

                        <div class="row align-items-center py-2.5">
                            <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["TouristAdmin_RegisterDate"].Value</div>
                            <div class="col-sm-8 text-dark">@Model.RegisterDate.ToShortDateString()</div>
                        </div>
                    </div>
                </div>

                <!-- Sub-tables (Missions & Trips) -->
                @if (Model.UserMissions != null && Model.UserMissions.Any())
                {
                    <div class="details-section mb-5">
                        <h5 class="section-title mb-3 font-cinzel text-dark-egy">
                            <i class="bi bi-trophy-fill me-2 text-primary-egy"></i> @Localizer["TouristAdmin_Missions"].Value
                        </h5>
                        <div class="card border border-light-egy overflow-hidden rounded-3 mb-4 table-sub-card">
                            <div class="table-responsive">
                                <table class="table align-middle custom-sub-table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-3">@Localizer["TouristAdmin_Mission"].Value</th>
                                            <th>@Localizer["TouristAdmin_PointsEarned"].Value</th>
                                            <th>@Localizer["TouristAdmin_Status"].Value</th>
                                            <th class="pe-3">@Localizer["TouristAdmin_CompletedAt"].Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var um in Model.UserMissions)
                                        {
                                            var mClass = um.Status switch
                                            {
                                                "Completed" => "badge-status-active",
                                                "In Progress" => "badge-status-pending",
                                                _ => "badge-status-inactive"
                                            };
                                            <tr>
                                                <td class="ps-3 fw-bold text-dark">@um.Mission?.Title</td>
                                                <td>
                                                    <span class="fw-bold text-secondary-egy">
                                                        @um.PointsEarned @Localizer["TouristAdmin_Pts"].Value
                                                    </span>
                                                </td>
                                                <td><span class="badge-status-custom @mClass">@um.Status</span></td>
                                                <td class="pe-3 text-muted">
                                                    @(um.Status == "Completed"
                                                        ? um.Completed_At.ToShortDateString()
                                                        : Localizer["TouristAdmin_NotSpecified"].Value)
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.TripPlans != null && Model.TripPlans.Any())
                {
                    <div class="details-section mb-4">
                        <h5 class="section-title mb-3 font-cinzel text-dark-egy">
                            <i class="bi bi-map-fill me-2 text-primary-egy"></i> @Localizer["TouristAdmin_TripPlans"].Value
                        </h5>
                        <div class="card border border-light-egy overflow-hidden rounded-3 table-sub-card">
                            <div class="table-responsive">
                                <table class="table align-middle custom-sub-table mb-0">
                                    <thead>
                                        <tr>
                                            <th class="ps-3">@Localizer["TouristAdmin_Title"].Value</th>
                                            <th>@Localizer["TouristAdmin_Start"].Value</th>
                                            <th>@Localizer["TouristAdmin_End"].Value</th>
                                            <th>@Localizer["TouristAdmin_Duration"].Value</th>
                                            <th class="pe-3">@Localizer["TouristAdmin_Status"].Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var trip in Model.TripPlans)
                                        {
                                            var tClass = trip.Status switch
                                            {
                                                "Active" => "badge-status-active",
                                                "Completed" => "badge-status-inactive",
                                                "Cancelled" => "badge-status-pending",
                                                _ => "badge-status-active"
                                            };
                                            <tr>
                                                <td class="ps-3 fw-bold text-dark">@trip.Title</td>
                                                <td>@trip.StartDate.ToShortDateString()</td>
                                                <td>@trip.EndDate.ToShortDateString()</td>
                                                <td>@((trip.EndDate - trip.StartDate).Days) @Localizer["TouristAdmin_Days"].Value</td>
                                                <td class="pe-3">
                                                    <span class="badge-status-custom @tClass">@trip.Status</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Card Footer -->
            <div class="card-footer bg-light p-4 d-flex flex-column flex-sm-row gap-3 justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-back-custom px-4 py-2.5">
                    <i class="bi bi-arrow-left me-1"></i> @Localizer["TouristAdmin_Back"].Value
                </a>
                
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit-custom px-4 py-2.5 shadow-sm">
                        <i class="bi bi-pencil-fill me-1"></i> @Localizer["TouristAdmin_Edit"].Value
                    </a>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <style>
        .details-card {
            border: 1px solid rgba(200, 131, 42, 0.15) !important;
            box-shadow: 0 15px 35px rgba(30, 18, 10, 0.08) !important;
        }

        .header-gradient {
            background: linear-gradient(135deg, var(--egy-dark) 0%, #3a2212 50%, var(--egy-primary) 100%);
            border-bottom: 3px solid var(--egy-accent);
        }

        .text-warning-egy {
            color: var(--egy-accent) !important;
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
            letter-spacing: 0.5px;
        }

        .tracking-wider {
            letter-spacing: 1.5px;
        }

        /* Stat Cards */
        .stat-card-custom {
            background: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.15);
            border-radius: var(--radius-lg);
            padding: 1.25rem 0.75rem;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-soft);
        }

        .stat-card-custom:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-large);
            border-color: var(--egy-primary);
        }

        .stat-icon-wrapper {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin-bottom: 0.75rem;
            font-size: 1.25rem;
        }

        /* Stats Themes */
        .stat-missions .stat-icon-wrapper {
            background-color: rgba(232, 160, 69, 0.15);
            color: var(--egy-accent);
        }
        .stat-missions {
            border-top: 3px solid var(--egy-accent);
        }

        .stat-completed .stat-icon-wrapper {
            background-color: rgba(46, 125, 50, 0.1);
            color: var(--egy-success);
        }
        .stat-completed {
            border-top: 3px solid var(--egy-success);
        }

        .stat-trips .stat-icon-wrapper {
            background-color: rgba(0, 180, 216, 0.1);
            color: #00b4d8;
        }
        .stat-trips {
            border-top: 3px solid #00b4d8;
        }

        .stat-active-trips .stat-icon-wrapper {
            background-color: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
        }
        .stat-active-trips {
            border-top: 3px solid #0d6efd;
        }

        .stat-value {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--egy-dark);
            margin-bottom: 0.25rem;
            max-width: 100%;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--egy-text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Detail List Box */
        .border-light-egy {
            border: 1px solid rgba(200, 131, 42, 0.15) !important;
        }
        
        .border-light-egy-subtle {
            border-bottom-color: rgba(200, 131, 42, 0.08) !important;
        }

        .text-dark-egy {
            color: var(--egy-dark);
        }
        
        .text-primary-egy {
            color: var(--egy-primary);
        }

        .text-secondary-egy {
            color: var(--egy-muted-gold);
        }

        .text-muted-egy {
            color: var(--egy-text-muted);
            font-size: 0.95rem;
        }

        .py-2.5 {
            padding-top: 0.8rem !important;
            padding-bottom: 0.8rem !important;
        }

        .badge-nationality {
            background-color: rgba(200, 131, 42, 0.1);
            color: var(--egy-muted-gold);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.4rem 0.8rem;
            font-size: 0.82rem;
            font-weight: 600;
        }

        /* Sub-tables */
        .table-sub-card {
            box-shadow: var(--shadow-soft);
        }

        .custom-sub-table thead {
            background-color: var(--egy-dark);
            color: #ffffff;
        }

        .custom-sub-table thead th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
            border: none;
        }

        .custom-sub-table tbody tr {
            border-bottom: 1px solid rgba(200, 131, 42, 0.06);
            transition: background-color 0.15s ease;
        }

        .custom-sub-table tbody tr:last-child {
            border-bottom: none;
        }

        .custom-sub-table tbody tr:hover {
            background-color: rgba(200, 131, 42, 0.03);
        }

        .custom-sub-table td {
            padding-top: 0.85rem;
            padding-bottom: 0.85rem;
            font-size: 0.92rem;
        }

        /* Custom Status Badges */
        .badge-status-custom {
            padding: 0.35rem 0.8rem;
            border-radius: var(--radius-pill);
            font-size: 0.78rem;
            font-weight: 700;
            display: inline-block;
        }

        .badge-status-active {
            background-color: #d1e7dd;
            color: #0f5132;
            border: 1px solid #badbcc;
        }

        .badge-status-inactive {
            background-color: #f8d7da;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .badge-status-pending {
            background-color: #fff3cd;
            color: #664d03;
            border: 1px solid #ffecb5;
        }

        /* Footer buttons */
        .btn-back-custom {
            background-color: #f8f9fa;
            color: #495057;
            border: 1px solid #dee2e6;
            border-radius: var(--radius-pill);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-back-custom:hover {
            background-color: #e9ecef;
            color: #212529;
            transform: translateX(-3px);
        }

        .btn-edit-custom {
            background-color: var(--egy-primary);
            color: #ffffff;
            border: none;
            border-radius: var(--radius-pill);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-edit-custom:hover {
            background-color: var(--egy-accent);
            transform: translateY(-2px);
            box-shadow: var(--shadow-glow-gold);
            color: #ffffff;
        }
    </style>
}
