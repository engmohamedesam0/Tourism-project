@model Tourist_Project_MVC.View_Model.UserRoleViewModel

@{
    ViewData["Title"] = Localizer["RoleAdmin_AssignRoleToUser"].Value;
}

<div class="container mt-5">
    <h2>@Localizer["RoleAdmin_AssignRoleToUser"].Value</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="AssignRole" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="UserId" class="control-label">@Localizer["RoleAdmin_SelectUser"].Value</label>
                    <select asp-for="UserId" class="form-select" required>
                        <option value="">@Localizer["RoleAdmin_SelectUserOption"].Value</option>
                        @if (Model.Users != null)
                        {
                            foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.UserName (@user.Email)</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="RoleName" class="control-label">@Localizer["RoleAdmin_SelectRole"].Value</label>
                    <select asp-for="RoleName" class="form-select" required>
                        <option value="">@Localizer["RoleAdmin_SelectRoleOption"].Value</option>
                        @if (Model.Roles != null)
                        {
                            foreach (var role in Model.Roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">@Localizer["RoleAdmin_AssignRole"].Value</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["RoleAdmin_Cancel"].Value</a>
                </div>
            </form>
        </div>
    </div>
</div>