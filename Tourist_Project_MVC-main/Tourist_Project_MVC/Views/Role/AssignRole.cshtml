@model Tourist_Project_MVC.View_Model.UserRoleViewModel

@{
    ViewData["Title"] = "Assign Role to User";
}

<div class="container mt-5">
    <h2>Assign Role to User</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="AssignRole" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="UserId" class="control-label">Select User</label>
                    <select asp-for="UserId" class="form-select" required>
                        <option value="">-- Select a User --</option>
                        @if (Model.Users != null)
                        {
                            foreach (var user in Model.Users)
                            {
                                <option value="@user.Id">@user.UserName (@user.Email)</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="RoleName" class="control-label">Select Role</label>
                    <select asp-for="RoleName" class="form-select" required>
                        <option value="">-- Select a Role --</option>
                        @if (Model.Roles != null)
                        {
                            foreach (var role in Model.Roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Assign Role</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
