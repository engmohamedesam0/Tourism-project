<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - EGYXPLORE</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />

    <!-- Font Awesome -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@500;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- Base Stylesheet -->
    <link href="~/css/styles.css" rel="stylesheet" />
    <!-- Custom Egyptian Theme -->
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        /* =============================================
           STAT-BOX (reusable stat cards: Home hero,
           About values, Tourist rewards, Admin/Sponsor
           data pages — one consistent white treatment)
           ============================================= */
        .stats-section {
        background: linear-gradient(135deg, #1a0f00 0%, #2C1A0E 50%, #1a0f00 100%);
        padding: 100px 0;
        border-top: 2px solid #C8832A;
        border-bottom: 2px solid #C8832A;
        }

        .stat-card {
        background: #ffffff;
        border: 1px solid rgba(30, 18, 10, 0.08);
        border-radius: 14px;
        padding: 22px 22px 20px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        height: 100%;
        position: relative;
        }

        .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(30, 18, 10, 0.12);
        border-color: var(--egy-primary);
        }

        /* Small colored square icon — accent tone set per card below. */
        .stat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        border-radius: 12px;
        font-size: 1.4rem;
        color: #ffffff;
        background: var(--egy-primary);
        margin-bottom: 16px;
        }

        .stat-number {
        font-family: 'Cinzel', serif;
        font-size: 2.1rem;
        font-weight: 900;
        color: var(--egy-dark);
        line-height: 1.1;
        display: inline-block;
        }

        .stat-suffix {
        font-family: 'Cinzel', serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--egy-primary);
        margin-left: 2px;
        display: inline;
        }

        .stat-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: #6b7280;
        font-weight: 600;
        letter-spacing: 0.3px;
        margin-top: 6px;
        display: block;
        }

        /* Per-card accent colors (colored square icon). Reuses the site's
           ochre/gold palette plus a few complementary tones for variety. */
        .stat-blue   .stat-icon { background: #2f6fed; }
        .stat-green  .stat-icon { background: #2e9e5b; }
        .stat-gold   .stat-icon { background: var(--egy-primary); }
        .stat-purple .stat-icon { background: #8b5cf6; }
        .stat-teal   .stat-icon { background: #0d9488; }
        .stat-red    .stat-icon { background: #e0533d; }
        .stat-amber  .stat-icon { background: #e8a045; }

        .stat-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 16px;
        padding: 45px 25px 35px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        }

        .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C8832A, transparent);
        opacity: 0;
        transition: opacity 0.4s ease;
        }

        .stat-card:hover {
        background: rgba(200, 131, 42, 0.08);
        border-color: #C8832A;
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(200, 131, 42, 0.15);
        }

        .stat-card:hover::before {
        opacity: 1;
        }

        .stat-icon {
        font-size: 2.5rem;
        color: #C8832A;
        margin-bottom: 20px;
        display: block;
        }

        .stat-number {
        font-family: 'Cinzel', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        color: #E8A045;
        letter-spacing: 2px;
        display: inline;
        line-height: 1;
        }

        .stat-suffix {
        font-family: 'Cinzel', sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: #C8832A;
        display: inline;
        }

        .stat-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: 12px;
        display: block;
        }

        /* =============================================
        INNER PAGES
        ============================================= */
        .inner-page-wrapper {
        padding-top: 140px;
        min-height: 80vh;
        background-color: #FDF6EC;
        font-family: 'Nunito', sans-serif;
        }

        .inner-page-wrapper .container {
        padding-top: 30px;
        padding-bottom: 50px;
        }

        /* Tables */
        .table thead {
        background-color: #2C1A0E;
        color: white;
        }

        .table thead th {
        font-family: 'Cinzel', sans-serif;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.8rem;
        }

        /* Page Title */
        .page-title {
        color: #2C1A0E;
        font-family: 'Cinzel', sans-serif;
        border-bottom: 2px solid #C8832A;
        padding-bottom: 8px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
        }

        /* Buttons Override */
        .btn-success {
        background-color: #2C1A0E;
        border-color: #2C1A0E;
        }

        .btn-success:hover {
        background-color: #C8832A;
        border-color: #C8832A;
        }

        /* =============================================
        FOOTER
        ============================================= */
        .main-footer {
        background-color: #2C1A0E;
        color: #f0d9b5;
        border-top: 3px solid #C8832A;
        padding: 20px 0;
        font-family: 'Nunito', sans-serif;
        letter-spacing: 1px;
        }

        .footer-logo {
        font-family: 'Cinzel Decorative', cursive;
        color: #E8A045;
        font-size: 1.2rem;
        }

        /* 
        NAVBAR SPACER */
        .nav-spacer {
        color: rgba(255,255,255,0.2);
        font-size: 1.2rem;
        }
    </style>
</head>
<body id="page-top">

    <!-- NAVBAR (two-tier: utility + primary) -->
    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">

        <!-- UPPER UTILITY BAR -->
        <div class="navbar-utility">
            <div class="container px-4 d-flex align-items-center justify-content-between gy-1">
                <div class="utility-left">
                    <span class="role-badge">
                        <i class="bi bi-patch-check-fill me-1"></i>@(User.IsInRole("Admin") ? "Admin" : (User.IsInRole("Sponsor") ? "Sponsor" : (User.Identity.IsAuthenticated ? "Tourist" : "Guest")))
                    </span>
                </div>

                <div class="utility-right d-flex align-items-center gap-2 flex-wrap justify-content-end">
                    <!-- Site search (initial scope = destination name search via /Explore) -->
                    <form class="utility-search d-none d-lg-flex" method="get" asp-controller="Explore" asp-action="Index">
                        <div class="input-group input-group-sm">
                            <input type="text" name="search" class="form-control form-control-sm"
                                   placeholder="Search Egypt…" aria-label="Search destinations" />
                            <button class="btn btn-outline-light btn-sm" type="submit" title="Search">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <!-- Language switcher (sets .AspNetCore.Culture cookie) -->
                    <div class="dropdown lang-switcher">
                        <a class="utility-link dropdown-toggle" href="#" id="langDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate me-1"></i> Language
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="langDropdown">
                            <li><a class="dropdown-item lang-option" href="#" data-culture="en">English</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="ar">العربية</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="es">Español</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="de">Deutsch</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="zh">中文</a></li>
                        </ul>
                    </div>

                    <!-- Account -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown account-switcher">
                            <a class="utility-link dropdown-toggle" href="#" id="acctDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="acctDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="Create">
                                            <i class="bi bi-shield-fill me-2"></i> Add Role
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="AssignRole">
                                            <i class="bi bi-person-check-fill me-2"></i> Assign Roles
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> Log out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="utility-link" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                        </a>
                        <a class="utility-link utility-register" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus-fill me-1"></i> Sign Up
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- LOWER PRIMARY BAR -->
        <div class="navbar-primary">
            <div class="container px-4 d-flex align-items-center">
                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🏺</span> EGY<span class="brand-gold">XPLORE</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarResponsive"
                        aria-controls="navbarResponsive"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="me-2 text-uppercase small tracking-wide">Menu</span>
                    <i class="fas fa-bars"></i>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarResponsive">
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        <!-- Home (visible to everyone) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-fill"></i> Home
                            </a>
                        </li>

                        <!-- Separator -->
                        <li class="nav-spacer d-none d-lg-block mx-2">|</li>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- ============ ADMIN EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tourist" asp-action="Index">
                                    <i class="bi bi-people-fill"></i> Tourists
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Destination" asp-action="Index">
                                    <i class="bi bi-geo-alt-fill"></i> Destinations
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TripPlan" asp-action="Index">
                                    <i class="bi bi-map-fill"></i> Trip Plans
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Mission" asp-action="Index">
                                    <i class="bi bi-trophy-fill"></i> Missions
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#"
                                   id="rewardsDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gift-fill"></i> Rewards
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end"
                                    aria-labelledby="rewardsDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Reward" asp-action="Index">
                                            <i class="bi bi-star-fill me-2"></i> All Rewards
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Sponsor" asp-action="Index">
                                            <i class="bi bi-building me-2"></i> Sponsors
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <!-- Public discovery pages -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> Near Me
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Features" asp-action="Index">
                                    <i class="bi bi-phone-fill"></i> Features
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Role" asp-action="ManageAccounts">
                                    <i class="bi bi-person-gear"></i> Accounts
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminSupport" asp-action="Index">
                                    <i class="bi bi-headset"></i> Support Inbox
                                </a>
                            </li>
                            @await Component.InvokeAsync("AdminApprovalBell")
                        }
                        else if (User.IsInRole("Sponsor"))
                        {
                            <!-- ============ SPONSOR EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorPortal" asp-action="Index">
                                    <i class="bi bi-house-fill"></i> Portal
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorBranch" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> Branches
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorReward" asp-action="Index">
                                    <i class="bi bi-gift-fill"></i> Rewards
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorPortal" asp-action="Reports">
                                    <i class="bi bi-bar-chart-fill"></i> Reports
                                </a>
                            </li>
                            @await Component.InvokeAsync("NotificationBell")
                            @await Component.InvokeAsync("SupportBell")
                        }
                        else if (User.Identity.IsAuthenticated)
                        {
                            <!-- ============ TOURIST EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Explore" asp-action="Index">
                                    <i class="bi bi-compass-fill"></i> Explore
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Trip" asp-action="Index">
                                    <i class="bi bi-map-fill"></i> Trip
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> Near Me
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Features" asp-action="Index">
                                    <i class="bi bi-phone-fill"></i> Features
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristReward" asp-action="Index">
                                    <i class="bi bi-gift-fill"></i> Rewards
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristProfile" asp-action="Index">
                                    <i class="bi bi-person-fill"></i> Profile
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristSupport" asp-action="Index">
                                    <i class="bi bi-headset"></i> Support
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="About" asp-action="Index">
                                    <i class="bi bi-info-circle-fill"></i> About
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- ============ GUEST EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Explore" asp-action="Index">
                                    <i class="bi bi-compass-fill"></i> Explore
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> Near Me
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Features" asp-action="Index">
                                    <i class="bi bi-phone-fill"></i> Features
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="About" asp-action="Index">
                                    <i class="bi bi-info-circle-fill"></i> About
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Language switcher: persist culture via .AspNetCore.Culture cookie then reload -->
    <script>
        (function () {
            document.querySelectorAll('.lang-option').forEach(function (el) {
                el.addEventListener('click', function (e) {
                    e.preventDefault();
                    var culture = el.getAttribute('data-culture');
                    document.cookie = ".AspNetCore.Culture=c=" + culture + "|uic=" + culture + ";path=/";
                    location.reload();
                });
            });
        })();
    </script>

    <!-- MAIN CONTENT -->
    @if (ViewData["IsHomePage"] as bool? == true)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <main role="main" class="inner-page-wrapper">
            <div class="container">
                @RenderBody()
            </div>
        </main>
    }

    <!-- FOOTER -->
    <footer class="main-footer">
        <div class="container text-center">
            <div class="footer-logo mb-2">🏺 EGYXPLORE</div>
            <p class="mb-0 small text-muted">
                &copy; @DateTime.Now.Year — Unlocking Hidden Wonders Across Egypt. All rights reserved.
            </p>
        </div>
    </footer>

    <!-- ============================================================
         FLOATING AI ASSISTANT (global, placeholder UI shell only)
         Real assistant integration will be wired up later.
         ============================================================ -->
    <button type="button"
            id="aiAssistantBtn"
            class="ai-fab"
            data-bs-toggle="modal"
            data-bs-target="#aiAssistantModal"
            aria-label="Open AI assistant">
        <i class="bi bi-stars"></i>
    </button>

    <div class="modal fade" id="aiAssistantModal" tabindex="-1"
         aria-labelledby="aiAssistantModalLabel" aria-hidden="true">
        <div class="modal-dialog ai-modal-dialog">
            <div class="modal-content ai-modal">
                <div class="modal-header ai-modal-header">
                    <h5 class="modal-title" id="aiAssistantModalLabel">
                        <i class="bi bi-stars me-2"></i> EGYXPLORE Assistant
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body ai-modal-body">
                    <div class="ai-coming-soon text-center">
                        <i class="bi bi-stars" style="font-size: 2.5rem; color: var(--egy-primary);"></i>
                        <p class="mt-3 mb-1 fw-semibold">AI Assistant — Coming Soon</p>
                        <p class="text-muted small">
                            Your smart travel companion for personalized itineraries will live here.
                        </p>
                    </div>
                </div>
                <div class="modal-footer ai-modal-footer">
                    <input type="text" class="form-control" placeholder="Ask me anything…" disabled />
                    <button class="btn btn-secondary" disabled>Send</button>
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Global anti-forgery token for AJAX POSTs (read by JS helpers). -->
    <form id="antiforgeryForm" style="display:none">@Html.AntiForgeryToken()</form>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Grayscale Script -->
    <script src="~/js/scripts.js"></script>

    <style>
        /* Floating AI assistant button */
        .ai-fab {
            position: fixed;
            right: 22px;
            bottom: 22px;
            z-index: 1040;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            border: none;
            background: var(--egy-primary);
            color: #fff;
            font-size: 1.5rem;
            box-shadow: 0 8px 22px rgba(200, 131, 42, 0.45);
            cursor: pointer;
            transition: all 0.25s ease;
        }

            .ai-fab:hover,
            .ai-fab:focus {
                background: var(--egy-accent);
                color: var(--egy-dark);
                transform: translateY(-3px) scale(1.05);
                box-shadow: 0 12px 28px rgba(200, 131, 42, 0.55);
            }

        .ai-modal-dialog {
            position: fixed;
            right: 22px;
            bottom: 90px;
            margin: 0;
            max-width: 360px;
            width: calc(100% - 44px);
        }

        @@media (max-width: 575.98px) {
            .ai-modal-dialog {
                right: 10px;
                left: 10px;
                bottom: 80px;
                width: auto;
                max-width: none;
            }
        }

        .ai-modal {
            border: 1px solid var(--egy-primary);
            border-radius: 16px;
            overflow: hidden;
        }

        .ai-modal-header {
            background: var(--egy-dark);
            color: #fff;
            border-bottom: 2px solid var(--egy-primary);
        }

        .ai-modal-body {
            background: var(--egy-light);
            min-height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ai-modal-footer {
            background: #fff;
            border-top: 1px solid rgba(200, 131, 42, 0.2);
        }

        /* Keep it clear of the footer on small screens */
        @@media (max-width: 575.98px) {
            .ai-fab {
                right: 14px;
                bottom: 14px;
                width: 52px;
                height: 52px;
                font-size: 1.3rem;
            }
        }

        /* Notification bell */
        .notification-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: #dc3545;
            color: #fff;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 50%;
            line-height: 1;
            border: 2px solid #fff;
        }

        .notification-panel {
            right: 22px;
            top: 80px;
            margin: 0;
            max-width: 380px;
            width: calc(100% - 44px);
        }

        @@media (max-width: 575.98px) {
            .notification-panel {
                left: 10px;
                right: 10px;
                top: 70px;
                width: auto;
                max-width: none;
            }
            .notification-bell {
                right: 14px;
                top: 14px;
            }
        }
    </style>

</body>
