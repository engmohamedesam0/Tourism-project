<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - EGYXPLORE</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />

    <!-- Font Awesome -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@500;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- Base Stylesheet -->
    <link href="~/css/styles.css" rel="stylesheet" />
    <!-- Custom Egyptian Theme -->
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        /* =============================================
        STATS SECTION
        ============================================= */
        .stats-section {
        background: linear-gradient(135deg, #1a0f00 0%, #2C1A0E 50%, #1a0f00 100%);
        padding: 100px 0;
        border-top: 2px solid #C8832A;
        border-bottom: 2px solid #C8832A;
        }

        .stat-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 16px;
        padding: 45px 25px 35px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        }

        .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C8832A, transparent);
        opacity: 0;
        transition: opacity 0.4s ease;
        }

        .stat-card:hover {
        background: rgba(200, 131, 42, 0.08);
        border-color: #C8832A;
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(200, 131, 42, 0.15);
        }

        .stat-card:hover::before {
        opacity: 1;
        }

        .stat-icon {
        font-size: 2.5rem;
        color: #C8832A;
        margin-bottom: 20px;
        display: block;
        }

        .stat-number {
        font-family: 'Cinzel', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        color: #E8A045;
        letter-spacing: 2px;
        display: inline;
        line-height: 1;
        }

        .stat-suffix {
        font-family: 'Cinzel', sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: #C8832A;
        display: inline;
        }

        .stat-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: 12px;
        display: block;
        }

        /* =============================================
        INNER PAGES
        ============================================= */
        .inner-page-wrapper {
        padding-top: 80px;
        min-height: 80vh;
        background-color: #FDF6EC;
        font-family: 'Nunito', sans-serif;
        }

        .inner-page-wrapper .container {
        padding-top: 30px;
        padding-bottom: 50px;
        }

        /* Tables */
        .table thead {
        background-color: #2C1A0E;
        color: white;
        }

        .table thead th {
        font-family: 'Cinzel', sans-serif;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.8rem;
        }

        /* Page Title */
        .page-title {
        color: #2C1A0E;
        font-family: 'Cinzel', sans-serif;
        border-bottom: 2px solid #C8832A;
        padding-bottom: 8px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
        }

        /* Buttons Override */
        .btn-success {
        background-color: #2C1A0E;
        border-color: #2C1A0E;
        }

        .btn-success:hover {
        background-color: #C8832A;
        border-color: #C8832A;
        }

        /* =============================================
        FOOTER
        ============================================= */
        .main-footer {
        background-color: #2C1A0E;
        color: #f0d9b5;
        border-top: 3px solid #C8832A;
        padding: 20px 0;
        font-family: 'Nunito', sans-serif;
        letter-spacing: 1px;
        }

        .footer-logo {
        font-family: 'Cinzel Decorative', cursive;
        color: #E8A045;
        font-size: 1.2rem;
        }

        /* 
        NAVBAR SPACER */
        .nav-spacer {
        color: rgba(255,255,255,0.2);
        font-size: 1.2rem;
        }
    </style>
</head>
<body id="page-top">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container px-4">

            <!-- Brand -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">🏺</span> EGY<span class="brand-gold">XPLORE</span>
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarResponsive"
                    aria-controls="navbarResponsive"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="me-2 text-uppercase small tracking-wide">Menu</span>
                <i class="fas fa-bars"></i>
            </button>

            <!-- Links -->
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto align-items-lg-center">

                    <!-- Home -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill"></i> Home
                        </a>
                    </li>

                    <!-- Separator -->
                    <li class="nav-spacer d-none d-lg-block mx-2">|</li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <!-- Tourists -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tourist" asp-action="Index">
                                <i class="bi bi-people-fill"></i> Tourists
                            </a>
                        </li>

                        <!-- Destinations -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Destination" asp-action="Index">
                                <i class="bi bi-geo-alt-fill"></i> Destinations
                            </a>
                        </li>

                        <!-- Trip Plans -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TripPlan" asp-action="Index">
                                <i class="bi bi-map-fill"></i> Trip Plans
                            </a>
                        </li>

                        <!-- Missions -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Mission" asp-action="Index">
                                <i class="bi bi-trophy-fill"></i> Missions
                            </a>
                        </li>

                        <!-- Rewards Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="rewardsDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gift-fill"></i> Rewards
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end"
                                aria-labelledby="rewardsDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Reward" asp-action="Index">
                                        <i class="bi bi-star-fill me-2"></i> All Rewards
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Sponsor" asp-action="Index">
                                        <i class="bi bi-building me-2"></i> Sponsors
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Account Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="AccountsDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end"
                                aria-labelledby="AccountsDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="Create">
                                            <i class="bi bi-shield-fill me-2"></i> Add Role
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="AssignRole">
                                            <i class="bi bi-person-check-fill me-2"></i> Assign Roles
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> Log out
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-auth-btn" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-auth-btn auth-register"
                               asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus-fill me-1"></i> Sign Up
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    @if (ViewData["IsHomePage"] as bool? == true)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <main role="main" class="inner-page-wrapper">
            <div class="container">
                @RenderBody()
            </div>
        </main>
    }

    <!-- FOOTER -->
    <footer class="main-footer">
        <div class="container text-center">
            <div class="footer-logo mb-2">🏺 EGYXPLORE</div>
            <p class="mb-0 small text-muted">
                &copy; @DateTime.Now.Year — Unlocking Hidden Wonders Across Egypt. All rights reserved.
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Grayscale Script -->
    <script src="~/js/scripts.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>