<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" dir="@(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar" ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - EGYXPLORE</title>

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@500;700&family=Nunito:wght@300;400;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css" />

    <!-- Base Stylesheet -->
    <link href="~/css/styles.css" rel="stylesheet" />
    <!-- Custom Egyptian Theme -->
    <link href="~/css/site.css" rel="stylesheet" />
    @if (CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "ar")
    {
        <link href="~/css/rtl.css" rel="stylesheet" />
    }

    <style>
        /* =============================================
           STAT-BOX (reusable stat cards: Home hero,
           About values, Tourist rewards, Admin/Sponsor
           data pages — one consistent white treatment)
           ============================================= */
        .stats-section {
        background: linear-gradient(135deg, #1a0f00 0%, var(--egy-dark) 50%, #1a0f00 100%);
        padding: 100px 0;
        border-top: 2px solid #C8832A;
        border-bottom: 2px solid #C8832A;
        }

        .stat-card {
        background: #ffffff;
        border: 1px solid rgba(30, 18, 10, 0.08);
        border-radius: 14px;
        padding: 22px 22px 20px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
        height: 100%;
        position: relative;
        }

        .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 30px rgba(30, 18, 10, 0.12);
        border-color: var(--egy-primary);
        }

        /* Small colored square icon — accent tone set per card below. */
        .stat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        border-radius: 12px;
        font-size: 1.4rem;
        color: #ffffff;
        background: var(--egy-primary);
        margin-bottom: 16px;
        }

        .stat-number {
        font-family: 'Cinzel', serif;
        font-size: 2.1rem;
        font-weight: 900;
        color: var(--egy-dark);
        line-height: 1.1;
        display: inline-block;
        }

        .stat-suffix {
        font-family: 'Cinzel', serif;
        font-size: 1.3rem;
        font-weight: 900;
        color: var(--egy-primary);
        margin-left: 2px;
        display: inline;
        }

        .stat-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: #6b7280;
        font-weight: 600;
        letter-spacing: 0.3px;
        margin-top: 6px;
        display: block;
        }

        /* Per-card accent colors (colored square icon). Reuses the site's
           ochre/gold palette plus a few complementary tones for variety. */
        .stat-blue   .stat-icon { background: #2f6fed; }
        .stat-green  .stat-icon { background: #2e9e5b; }
        .stat-gold   .stat-icon { background: var(--egy-primary); }
        .stat-purple .stat-icon { background: #8b5cf6; }
        .stat-teal   .stat-icon { background: #0d9488; }
        .stat-red    .stat-icon { background: #e0533d; }
        .stat-amber  .stat-icon { background: #e8a045; }

        .stats-section .stat-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(200, 131, 42, 0.25);
        border-radius: 16px;
        padding: 45px 25px 35px;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        }

        .stats-section .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C8832A, transparent);
        opacity: 0;
        transition: opacity 0.4s ease;
        }

        .stats-section .stat-card:hover {
        background: rgba(200, 131, 42, 0.08);
        border-color: #C8832A;
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(200, 131, 42, 0.15);
        }

        .stats-section .stat-card:hover::before {
        opacity: 1;
        }

        .stats-section .stat-icon {
        font-size: 2.5rem;
        color: #C8832A;
        margin-bottom: 20px;
        display: block;
        }

        .stats-section .stat-number {
        font-family: 'Cinzel', sans-serif;
        font-size: 3.5rem;
        font-weight: 900;
        color: #E8A045;
        letter-spacing: 2px;
        display: inline;
        line-height: 1;
        }

        .stats-section .stat-suffix {
        font-family: 'Cinzel', sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: #C8832A;
        display: inline;
        }

        .stats-section .stat-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.55);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-top: 12px;
        display: block;
        }

        /* =============================================
        INNER PAGES
        ============================================= */
        .inner-page-wrapper {
        padding-top: var(--nav-offset);
        min-height: 80vh;
        background-color: #FDF6EC;
        font-family: 'Nunito', sans-serif;
        }

        .inner-page-wrapper .container {
        padding-top: 30px;
        padding-bottom: 50px;
        }

        /* Nested wrappers (some views self-wrap in .inner-page-wrapper while the
           layout already wraps non-home pages) must not re-apply the top offset. */
        .inner-page-wrapper .inner-page-wrapper {
        padding-top: 0 !important;
        }

        /* Tables */
        .table thead {
        background-color: var(--egy-dark);
        color: white;
        }

        .table thead th {
        font-family: 'Cinzel', sans-serif;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-size: 0.8rem;
        }

        /* Page Title */
        .page-title {
        color: var(--egy-dark);
        font-family: 'Cinzel', sans-serif;
        border-bottom: 2px solid #C8832A;
        padding-bottom: 8px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
        }

        /* Add / Create (.btn-success) is styled in site.css with the EGY green tokens. */

        /* =============================================
        FOOTER
        ============================================= */
        .main-footer {
        background-color: var(--egy-dark);
        color: #f0d9b5;
        border-top: 3px solid #C8832A;
        padding: 20px 0;
        font-family: 'Nunito', sans-serif;
        letter-spacing: 1px;
        }

        .footer-logo {
        font-family: 'Cinzel Decorative', cursive;
        color: #E8A045;
        font-size: 1.2rem;
        }

        /* 
        NAVBAR SPACER */
        .nav-spacer {
        color: rgba(255,255,255,0.2);
        font-size: 1.2rem;
        }
    </style>
</head>
<body id="page-top">

    <!-- NAVBAR (two-tier: utility + primary) -->
    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">

        <!-- UPPER UTILITY BAR -->
        <div class="navbar-utility">
            <div class="container px-4 d-flex align-items-center justify-content-between gy-1">
                <div class="utility-left">
                    <span class="role-badge">
                        <i class="bi bi-patch-check-fill me-1"></i>@(User.IsInRole("Admin") ? Localizer["Role_Admin"].Value : (User.IsInRole("Sponsor") ? Localizer["Role_Sponsor"].Value : (User.Identity.IsAuthenticated ? Localizer["Role_Tourist"].Value : Localizer["Role_Guest"].Value)))
                    </span>
                </div>

                <div class="utility-right d-flex align-items-center gap-2 flex-wrap justify-content-end">
                    <!-- Site search (initial scope = destination name search via /Explore) -->
                    <form class="utility-search d-none d-lg-flex" method="get" asp-controller="Explore" asp-action="Index">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text utility-search-icon">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="search" class="form-control form-control-sm"
                                   placeholder="@Localizer["Search_Placeholder"].Value" aria-label="@Localizer["Search_Aria"].Value" />
                        </div>
                    </form>

                    <!-- Language switcher (sets .AspNetCore.Culture cookie) -->
                    <div class="dropdown lang-switcher">
                        <a class="utility-link dropdown-toggle" href="#" id="langDropdown" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-translate me-1"></i> @Localizer["Language"].Value
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="langDropdown">
                            <li><a class="dropdown-item lang-option" href="#" data-culture="en">@Localizer["Lang_English"].Value</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="ar">@Localizer["Lang_Arabic"].Value</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="es">@Localizer["Lang_Spanish"].Value</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="de">@Localizer["Lang_German"].Value</a></li>
                            <li><a class="dropdown-item lang-option" href="#" data-culture="zh">@Localizer["Lang_Chinese"].Value</a></li>
                        </ul>
                    </div>

                    <!-- Account -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown account-switcher">
                            <a class="utility-link dropdown-toggle" href="#" id="acctDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="acctDropdown">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="Create">
                                            <i class="bi bi-shield-fill me-2"></i> @Localizer["Nav_AddRole"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="AssignRole">
                                            <i class="bi bi-person-check-fill me-2"></i> @Localizer["Nav_AssignRoles"].Value
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> @Localizer["Nav_Logout"].Value
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="utility-link" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i> @Localizer["SignIn"].Value
                        </a>
                        <a class="utility-link utility-register" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus-fill me-1"></i> @Localizer["SignUp"].Value
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- LOWER PRIMARY BAR -->
        <div class="navbar-primary">
            <div class="container px-4 d-flex align-items-center">
                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🏺</span> EGY<span class="brand-gold">XPLORE</span>
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarResponsive"
                        aria-controls="navbarResponsive"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="me-2 text-uppercase small tracking-wide">@Localizer["Menu"].Value</span>
                    <i class="bi bi-list"></i>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarResponsive">
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        <!-- Home (visible to everyone) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-fill"></i> @Localizer["Nav_Home"].Value
                            </a>
                        </li>

                        <li class="nav-spacer d-none d-lg-block mx-2">|</li>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- ============ ADMIN EXPERIENCE ============ -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle position-relative" href="#"
                                   id="adminDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill me-1"></i> @Localizer["Nav_Administration"].Value
                                    @await Component.InvokeAsync("AdminApprovalBell")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end"
                                    aria-labelledby="adminDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Tourist" asp-action="Index">
                                            <i class="bi bi-people-fill me-2"></i> @Localizer["Nav_Tourists"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Destination" asp-action="Index">
                                            <i class="bi bi-geo-alt-fill me-2"></i> @Localizer["Nav_Destinations"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="TripPlan" asp-action="Index">
                                            <i class="bi bi-map-fill me-2"></i> @Localizer["Nav_TripPlans"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Mission" asp-action="Index">
                                            <i class="bi bi-trophy-fill me-2"></i> @Localizer["Nav_Missions"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Reward" asp-action="Index">
                                            <i class="bi bi-star-fill me-2"></i> @Localizer["Nav_AllRewards"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Sponsor" asp-action="Index">
                                            <i class="bi bi-building me-2"></i> @Localizer["Nav_Sponsors"].Value
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Role" asp-action="ManageAccounts">
                                            <i class="bi bi-person-gear me-2"></i> @Localizer["Nav_Accounts"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="AdminSupport" asp-action="Index">
                                            <i class="bi bi-headset me-2"></i> @Localizer["Nav_SupportInbox"].Value
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="SponsorApproval" asp-action="Index">
                                            <i class="bi bi-bell-fill me-2"></i> @Localizer["Nav_Approvals"].Value
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <!-- Public discovery pages -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> @Localizer["Nav_NearMe"].Value
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("Sponsor"))
                        {
                            <!-- ============ SPONSOR EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorPortal" asp-action="Index">
                                    <i class="bi bi-house-fill"></i> @Localizer["Nav_Portal"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorBranch" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> @Localizer["Nav_Branches"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorReward" asp-action="Index">
                                    <i class="bi bi-gift-fill"></i> @Localizer["Nav_Rewards"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="SponsorPortal" asp-action="Reports">
                                    <i class="bi bi-bar-chart-fill"></i> @Localizer["Nav_Reports"].Value
                                </a>
                            </li>
                            @await Component.InvokeAsync("SupportBell")
                        }
                        else if (User.Identity.IsAuthenticated)
                        {
                            <!-- ============ TOURIST EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Explore" asp-action="Index">
                                    <i class="bi bi-compass-fill"></i> @Localizer["Nav_Explore"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Trip" asp-action="Index">
                                    <i class="bi bi-map-fill"></i> @Localizer["Nav_Trip"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> @Localizer["Nav_NearMe"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Features" asp-action="Index">
                                    <i class="bi bi-phone-fill"></i> @Localizer["Nav_Features"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristReward" asp-action="Index">
                                    <i class="bi bi-gift-fill"></i> @Localizer["Nav_Rewards"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristProfile" asp-action="Index">
                                    <i class="bi bi-person-fill"></i> @Localizer["Nav_Profile"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TouristSupport" asp-action="Index">
                                    <i class="bi bi-headset"></i> @Localizer["Nav_Support"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="About" asp-action="Index">
                                    <i class="bi bi-info-circle-fill"></i> @Localizer["Nav_About"].Value
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- ============ GUEST EXPERIENCE ============ -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Explore" asp-action="Index">
                                    <i class="bi bi-compass-fill"></i> @Localizer["Nav_Explore"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NearMe" asp-action="Index">
                                    <i class="bi bi-geo-fill"></i> @Localizer["Nav_NearMe"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Features" asp-action="Index">
                                    <i class="bi bi-phone-fill"></i> @Localizer["Nav_Features"].Value
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="About" asp-action="Index">
                                    <i class="bi bi-info-circle-fill"></i> @Localizer["Nav_About"].Value
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Language switcher: persist culture via .AspNetCore.Culture cookie then reload -->
    <script>
        (function () {
            document.querySelectorAll('.lang-option').forEach(function (el) {
                el.addEventListener('click', function (e) {
                    e.preventDefault();
                    var culture = el.getAttribute('data-culture');
                    document.cookie = ".AspNetCore.Culture=c=" + culture + "|uic=" + culture + ";path=/";
                    location.reload();
                });
            });
        })();
    </script>

    <!-- AI Assistant widget toggle -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('aiAssistantBtn');
            var panel = document.getElementById('aiAssistantPanel');
            var closeBtn = panel ? panel.querySelector('.ai-widget-close') : null;

            function openWidget() {
                panel.classList.add('ai-widget-open');
                panel.setAttribute('aria-hidden', 'false');
                btn.setAttribute('aria-expanded', 'true');
            }

            function closeWidget() {
                panel.classList.remove('ai-widget-open');
                panel.setAttribute('aria-hidden', 'true');
                btn.setAttribute('aria-expanded', 'false');
            }

            if (btn && panel) {
                btn.addEventListener('click', function () {
                    if (panel.classList.contains('ai-widget-open')) {
                        closeWidget();
                    } else {
                        openWidget();
                    }
                });
            }

            if (closeBtn && panel) {
                closeBtn.addEventListener('click', function () {
                    closeWidget();
                });
            }
        });
    </script>

    <!-- Notification widget toggle (sponsor-only FAB) -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('notificationFabBtn');
            var panel = document.getElementById('notificationPanel');
            var panelBody = document.getElementById('notificationPanelBody');
            var closeBtn = panel ? panel.querySelector('.notification-widget-close') : null;
            var markAllBtn = document.getElementById('markAllReadBtn');
            var loaded = false;

            var notifEmptyHtml =
                '<div class="text-center py-4 text-muted w-100">' +
                    '<i class="bi bi-bell-slash" style="font-size:2rem;"></i>' +
                    '<p class="mb-0 mt-2">You\'re all caught up 🏺</p>' +
                '</div>';

            function openNotif() {
                panel.classList.add('notification-widget-open');
                panel.setAttribute('aria-hidden', 'false');
                btn.setAttribute('aria-expanded', 'true');
                if (loaded || !panelBody) return;
                loaded = true;
                var role = btn.getAttribute('data-user-role');
                if (role === 'Sponsor') {
                    fetch('/SponsorNotification/Panel')
                        .then(function (r) { return r.text(); })
                        .then(function (html) {
                            panelBody.innerHTML = html;
                            formatRelativeTimes(panelBody);
                        })
                        .catch(function () {
                            panelBody.innerHTML = '<div class="alert alert-danger m-3">Failed to load.</div>';
                        });
                } else {
                    panelBody.innerHTML = notifEmptyHtml;
                    var markAll = document.getElementById('markAllReadBtn');
                    if (markAll) markAll.style.display = 'none';
                }
            }

            function closeNotif() {
                panel.classList.remove('notification-widget-open');
                panel.setAttribute('aria-hidden', 'true');
                btn.setAttribute('aria-expanded', 'false');
            }

            if (btn && panel) {
                btn.addEventListener('click', function () {
                    if (panel.classList.contains('notification-widget-open')) {
                        closeNotif();
                    } else {
                        openNotif();
                    }
                });
            }

            if (closeBtn && panel) {
                closeBtn.addEventListener('click', function () {
                    closeNotif();
                });
            }

            if (markAllBtn) {
                markAllBtn.addEventListener('click', function () {
                    var f = document.getElementById('antiforgeryForm');
                    var token = f ? f.querySelector('input[name="__RequestVerificationToken"]').value : '';
                    fetch('/SponsorNotification/MarkAllRead', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            updateNotifBadge(data.unreadCount);
                            if (panelBody) {
                                fetch('/SponsorNotification/Panel')
                                    .then(function (r) { return r.text(); })
                                    .then(function (html) { panelBody.innerHTML = html; formatRelativeTimes(panelBody); });
                            }
                        }
                    })
                    .catch(function () {});
                });
            }

            function updateNotifBadge(count) {
                var badge = document.getElementById('notifFabBadge');
                if (!badge) return;
                if (count == null || count <= 0) badge.remove();
                else badge.textContent = count;
            }

            function relativeTime(date) {
                var seconds = (Date.now() - date.getTime()) / 1000;
                if (seconds < 60) return 'just now';
                if (seconds < 3600) return Math.floor(seconds / 60) + 'm ago';
                if (seconds < 86400) return Math.floor(seconds / 3600) + 'h ago';
                if (seconds < 604800) return Math.floor(seconds / 86400) + 'd ago';
                return date.toLocaleDateString();
            }

            function formatRelativeTimes(container) {
                if (!container) return;
                container.querySelectorAll('[data-time]').forEach(function (el) {
                    var d = new Date(el.getAttribute('data-time'));
                    if (!isNaN(d)) el.textContent = relativeTime(d);
                });
            }

            function getToken() {
                var f = document.getElementById('antiforgeryForm');
                return f ? f.querySelector('input[name="__RequestVerificationToken"]').value : '';
            }

            function notifTarget(type, relId) {
                if (!type) return null;
                if (type === 'Reward') return '/SponsorReward/Edit/' + relId;
                if (type === 'Redemption') return '/SponsorRedemption/Index';
                if (type === 'SupportTicket') return '/SponsorNotification/Support';
                return null;
            }

            document.addEventListener('click', function (e) {
                var delBtn = e.target.closest('.notif-delete');
                if (delBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    var item = delBtn.closest('.notification-item');
                    var id = item && item.getAttribute('data-notif-id');
                    if (!id) return;
                    delBtn.disabled = true;
                    fetch('/SponsorNotification/DeleteNotification/' + id, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': getToken() }
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            if (item) item.remove();
                            updateNotifBadge(data.unreadCount);
                        }
                    })
                    .catch(function () { delBtn.disabled = false; });
                    return;
                }

                var item = e.target.closest('.notification-item');
                if (item && (e.target.closest('a') === null)) {
                    var id = item.getAttribute('data-notif-id');
                    var target = notifTarget(item.getAttribute('data-related-type'), item.getAttribute('data-related-id'));
                    fetch('/SponsorNotification/MarkRead/' + id, {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': getToken() }
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        updateNotifBadge(data ? data.unreadCount : null);
                        if (target) { window.location.href = target; return; }
                        item.classList.remove('notification-unread');
                        item.classList.add('notification-read');
                        var list = document.querySelector('[data-notif-list]');
                        if (list && list.getAttribute('data-current-filter') === 'unread') {
                            item.remove();
                        }
                    })
                    .catch(function () {
                        if (target) window.location.href = target;
                    });
                }
            });
        });
    </script>

