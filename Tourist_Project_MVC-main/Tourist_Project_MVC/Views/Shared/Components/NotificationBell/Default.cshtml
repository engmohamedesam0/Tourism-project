@model Tourist_Project_MVC.View_Model.NotificationBellVM

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle position-relative" href="#" id="notifNavDropdown" role="button"
       data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
        <i class="bi bi-bell-fill"></i> Notifications
        @if (Model?.UnreadCount > 0)
        {
            <span class="badge rounded-pill text-bg-danger ms-1" id="notifNavBadge">@Model.UnreadCount</span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end" aria-labelledby="notifNavDropdown" style="width: 360px; max-width: calc(100vw - 40px);">
        <li class="px-3 py-2 d-flex align-items-center justify-content-between">
            <h6 class="mb-0"><i class="bi bi-bell-fill me-1"></i> Notifications</h6>
            @if (Model?.UnreadCount > 0)
            {
                <small class="text-white-50">@Model.UnreadCount unread</small>
            }
        </li>
        <li><hr class="dropdown-divider" /></li>
        <li>
            <div id="notifNavBody" style="max-height: 55vh; overflow-y: auto;">
                <div class="text-center py-4 text-white-50">
                    <div class="spinner-border text-warning" role="status"><span class="visually-hidden">Loading…</span></div>
                </div>
            </div>
        </li>
        <li><hr class="dropdown-divider" /></li>
        <li>
            <a class="dropdown-item" asp-controller="SponsorNotification" asp-action="Index">
                <i class="bi bi-list-ul me-2"></i> View all
            </a>
        </li>
    </ul>
</li>

<script>
    (function () {
        var toggle = document.getElementById('notifNavDropdown');
        if (!toggle) return;
        var loaded = false;

        toggle.addEventListener('shown.bs.dropdown', function () {
            if (loaded) return;
            loaded = true;
            fetch('@Url.Action("Panel", "SponsorNotification")')
                .then(function (r) { return r.text(); })
                .then(function (html) {
                    document.getElementById('notifNavBody').innerHTML = html;
                })
                .catch(function () {
                    document.getElementById('notifNavBody').innerHTML = '<div class="alert alert-danger m-3">Failed to load.</div>';
                });
        });

        function getToken() {
            var f = document.getElementById('antiforgeryForm');
            return f ? f.querySelector('input[name="__RequestVerificationToken"]').value : '';
        }

        function notifTarget(type, relId) {
            if (!type) return null;
            if (type === 'Reward') return '/SponsorReward/Edit/' + relId;
            if (type === 'Redemption') return '/SponsorRedemption/Index';
            if (type === 'SupportTicket') return '/SponsorNotification/Support';
            return null;
        }

        function updateNotifBadge(count) {
            var badge = document.getElementById('notifNavBadge');
            if (!badge) return;
            if (count == null || count <= 0) badge.remove();
            else badge.textContent = count;
        }

        // Shared handler for notification items (nav panel AND full page).
        document.addEventListener('click', function (e) {
            var delBtn = e.target.closest('.notif-delete');
            if (delBtn) {
                e.preventDefault();
                e.stopPropagation();
                var item = delBtn.closest('.notification-item');
                var id = item && item.getAttribute('data-notif-id');
                if (!id) return;
                delBtn.disabled = true;
                fetch('/SponsorNotification/DeleteNotification/' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': getToken() }
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            if (item) item.remove();
                            updateNotifBadge(data.unreadCount);
                        }
                    })
                    .catch(function () { delBtn.disabled = false; });
                return;
            }

            var item = e.target.closest('.notification-item');
            if (item && (e.target.closest('a') === null)) {
                var id = item.getAttribute('data-notif-id');
                var target = notifTarget(item.getAttribute('data-related-type'), item.getAttribute('data-related-id'));
                fetch('/SponsorNotification/MarkRead/' + id, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': getToken() }
                })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        updateNotifBadge(data ? data.unreadCount : null);
                        if (target) { window.location.href = target; return; }
                        item.classList.remove('notification-unread');
                        item.classList.add('notification-read');
                        var list = document.querySelector('[data-notif-list]');
                        if (list && list.getAttribute('data-current-filter') === 'unread') {
                            item.remove();
                        }
                    })
                    .catch(function () {
                        if (target) window.location.href = target;
                    });
            }
        });
    })();
</script>
