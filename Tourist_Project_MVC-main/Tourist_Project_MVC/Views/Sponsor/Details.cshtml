@model Tourist_Project_MVC.Models.Sponsor

@{
    ViewData["Title"] = Localizer["Sponsor_DetailsTitle"].Value;
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <!-- Card Header -->
        <div class="card-header py-3"
             style="background: linear-gradient(135deg, var(--egy-dark), #C8832A);">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="text-white mb-0">
                    <i class="bi bi-building me-2"></i> @Model.Name
                </h4>
                <span class="badge bg-warning text-dark fs-6">@Model.Type</span>
            </div>
        </div>

        <div class="card-body p-4">

            <!-- Info -->
            <dl class="row mb-4">
                <dt class="col-sm-3 text-muted">@Localizer["Sponsor_ColType"].Value</dt>
                <dd class="col-sm-9">
                    <span class="badge-category">@Model.Type</span>
                </dd>

                <dt class="col-sm-3 text-muted">@Localizer["Sponsor_ColAddress"].Value</dt>
                <dd class="col-sm-9">
                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                    @Model.Address
                </dd>

                <dt class="col-sm-3 text-muted">@Localizer["Sponsor_PhoneNumber"].Value</dt>
                <dd class="col-sm-9">
                    <i class="bi bi-telephone-fill text-success me-1"></i>
                    @Model.ContactNumber
                </dd>
            </dl>

            <hr />

            <h5 class="mb-3">
                <i class="bi bi-gift-fill me-2" style="color: var(--egy-primary);"></i>
                @Localizer["Sponsor_AllRewardsHeading"].Value
            </h5>

            @if (Model.Rewards != null && Model.Rewards.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle destinations-table">
                        <thead>
                            <tr>
                                <th>@Localizer["Sponsor_ColHash"].Value</th>
                                <th>@Localizer["Sponsor_ColName"].Value</th>
                                <th>@Localizer["Sponsor_ColDescription"].Value</th>
                                <th>@Localizer["Sponsor_ColRequiredPoints"].Value</th>
                                <th>@Localizer["Sponsor_ColAvailable"].Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }
                            @foreach (var item in Model.Rewards)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">@i.ToString("D2")</td>
                                    <td><div class="fw-bold">@item.Title</div></td>
                                    <td><small class="text-muted">@item.Description</small></td>
                                    <td>
                                        <span class="fw-bold" style="color: var(--egy-primary);">
                                            @item.PointsRequired @Localizer["Sponsor_PtsUnit"].Value
                                        </span>
                                    </td>
                                    <td>@item.QuantityAvailable</td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-3">
                    <i class="bi bi-gift" style="font-size: 2rem; color: var(--egy-primary);"></i>
                    <p class="text-muted mt-2">@Localizer["Sponsor_NoRewardsMessage"].Value</p>
                </div>
            }
        </div>

        <div class="card-footer bg-white d-flex gap-2 justify-content-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-controller="Sponsor"
                   asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-fill me-1"></i> @Localizer["Sponsor_EditBtn"].Value
                </a>
            }
            <a asp-action="Index" asp-controller="Sponsor" class="btn-back">
                <i class="bi bi-arrow-left me-1"></i> @Localizer["Sponsor_BackBtn"].Value
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .badge-category {
            background-color: #FDF6EC;
            color: var(--egy-primary);
            border: 1px solid var(--egy-accent);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .destinations-table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
    </style>
}