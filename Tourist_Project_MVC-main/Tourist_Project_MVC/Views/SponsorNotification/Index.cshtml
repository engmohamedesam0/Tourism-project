@model Tourist_Project_MVC.View_Model.SponsorNotificationVM

@{
    ViewData["Title"] = Localizer["SponsorNotification_NotificationsPageTitle"].Value;
    ViewData["IsHomePage"] = false;
}

<div class="container my-4" style="max-width: 1000px;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="page-title mb-0">
            <i class="bi bi-bell-fill me-2"></i> @Localizer["SponsorNotification_NotificationsTitle"].Value
        </h1>
        <form asp-action="MarkAllRead" method="post" id="markAllReadForm">
            <button class="btn btn-outline-primary btn-sm">
                <i class="bi bi-check2-all me-1"></i> @Localizer["SponsorNotification_MarkAllRead"].Value
            </button>
        </form>
    </div>

    <div class="filter-bar mb-3">
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-sm @(string.IsNullOrEmpty(Model.Filter) ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Index" asp-route-filter="">@Localizer["SponsorNotification_All"].Value</a>
            <a class="btn btn-sm @(Model.Filter == "Read" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Index" asp-route-filter="Read">@Localizer["SponsorNotification_Read"].Value</a>
            <a class="btn btn-sm @(Model.Filter == "Unread" ? "btn-primary" : "btn-outline-secondary")"
               asp-action="Index" asp-route-filter="Unread">@Localizer["SponsorNotification_Unread"].Value</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
            @if (!Model.Notifications.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check-circle" style="font-size:2.5rem;"></i>
                    <p class="mb-0 mt-2">@Localizer["SponsorNotification_NoNotifications"].Value</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush notification-list" data-notif-list data-current-filter="@Model.Filter">
                    @foreach (var n in Model.Notifications)
                    {
                        <div class="list-group-item notification-item @(n.IsRead ? "notification-read" : "notification-unread")"
                             id="notification-@n.Id"
                             data-notif-id="@n.Id"
                             data-related-type="@n.RelatedEntityType"
                             data-related-id="@n.RelatedEntityId"
                             style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="flex-grow-1">
                                    <span class="badge bg-@(n.Type == "RewardExpired" ? "danger" : n.Type == "RewardLowStock" ? "warning" : "info") me-1">@n.Type</span>
                                    <p class="mb-1 mt-1 small @(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</p>
                                    <small class="text-muted">@n.CreatedDate.ToString("yyyy-MM-dd HH:mm")</small>
                                </div>
                                <button type="button" class="btn btn-sm btn-link text-danger notif-delete p-0" title="@Localizer["SponsorNotification_Delete"].Value" data-notif-id="@n.Id">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <p class="text-muted small mt-4 mb-0">
        @Localizer["SponsorNotification_AlertsInfo"].Value
    </p>
</div>

@section Scripts {
    <style>
        .notification-item {
            transition: all 0.2s ease;
        }
        .notification-unread {
            background-color: rgba(200, 131, 42, 0.08);
            border-left: 3px solid var(--egy-primary);
        }
        .notification-read {
            opacity: 0.7;
        }
        .notification-list {
            max-height: 60vh;
            overflow-y: auto;
        }
    </style>
}