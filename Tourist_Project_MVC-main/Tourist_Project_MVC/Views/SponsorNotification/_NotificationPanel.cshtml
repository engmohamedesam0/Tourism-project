@model List<Tourist_Project_MVC.Models.Notification>

@if (!Model.Any())
{
    <div class="text-center py-4 text-muted w-100">
        <i class="bi bi-bell-slash" style="font-size:2rem;"></i>
        <p class="mb-0 mt-2">No new notifications.</p>
    </div>
}
else
{
    <div class="list-group list-group-flush notification-list w-100">
        @foreach (var n in Model)
        {
            <div class="list-group-item notification-item @(n.IsRead ? "notification-read" : "notification-unread") w-100" id="notification-@n.Id">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="flex-grow-1">
                        <span class="badge bg-@(n.Type == "RewardExpired" ? "danger" : n.Type == "RewardLowStock" ? "warning" : "info") me-1" style="font-size:0.65rem;">@n.Type</span>
                        <p class="mb-1 mt-1 small @(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</p>
                        <small class="text-muted">@n.CreatedDate.ToString("MMM dd, HH:mm")</small>
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" asp-route-id="@n.Id" method="post" class="mark-read-form">
                            <button class="btn btn-sm btn-outline-success" type="submit" title="Mark read">
                                <i class="bi bi-check-lg"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        document.querySelectorAll('.mark-read-form').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                var btn = form.querySelector('button');
                btn.disabled = true;

                var formData = new FormData(form);
                fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        var row = document.getElementById('notification-' + form.querySelector('input[name=\"id\"]')?.value || form.getAttribute('asp-route-id'));
                        if (row) {
                            row.classList.remove('notification-unread');
                            row.classList.add('notification-read');
                            form.remove();
                        }
                        var badge = document.getElementById('notificationBadge');
                        if (badge) {
                            var newCount = data.unreadCount;
                            if (newCount <= 0) {
                                badge.remove();
                            } else {
                                badge.textContent = newCount;
                            }
                        }
                    }
                })
                .catch(function () {
                    btn.disabled = false;
                });
            });
        });
    })();
</script>
