@model List<Tourist_Project_MVC.Models.Notification>

@if (!Model.Any())
{
    <div class="text-center py-4 text-white-50 w-100">
        <i class="bi bi-bell-slash" style="font-size:2rem;"></i>
        <p class="mb-0 mt-2">No new notifications.</p>
    </div>
}
else
{
    <div class="list-group list-group-flush notification-list w-100">
        @foreach (var n in Model)
        {
            <div class="list-group-item notification-item @(n.IsRead ? "notification-read" : "notification-unread") w-100"
                 data-notif-id="@n.Id"
                 data-related-type="@n.RelatedEntityType"
                 data-related-id="@n.RelatedEntityId"
                 style="cursor: pointer; background: transparent; color: inherit;">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="flex-grow-1">
                        <span class="badge bg-@(n.Type == "RewardExpired" ? "danger" : n.Type == "RewardLowStock" ? "warning" : "info") me-1" style="font-size:0.65rem;">@n.Type</span>
                        <p class="mb-1 mt-1 small @(n.IsRead ? "text-white-50" : "fw-semibold")">@n.Message</p>
                        <small class="text-white-50">@n.CreatedDate.ToString("MMM dd, HH:mm")</small>
                    </div>
                    <button type="button" class="btn btn-sm btn-link text-white-50 notif-delete p-0 ms-1" title="Delete" data-notif-id="@n.Id">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}
