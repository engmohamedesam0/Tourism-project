@model List<Tourist_Project_MVC.Models.Notification>

@{
    string IconFor(string type) => type switch
    {
        "RewardExpired" => "bi-calendar-x-fill",
        "RewardLowStock" => "bi-box-seam-fill",
        "RewardRedeemed" => "bi-gift-fill",
        _ => "bi-bell-fill"
    };
}

@if (!Model.Any())
{
    <div class="text-center py-4 text-muted w-100">
        <i class="bi bi-bell-slash" style="font-size:2rem;"></i>
        <p class="mb-0 mt-2">You're all caught up 🏺</p>
    </div>
}
else
{
    <div class="notification-list w-100" data-notif-list>
        @foreach (var n in Model)
        {
            <div class="notification-item @(n.IsRead ? "notification-read" : "notification-unread") w-100"
                 data-notif-id="@n.Id"
                 data-related-type="@n.RelatedEntityType"
                 data-related-id="@n.RelatedEntityId"
                 style="cursor: pointer; background: transparent; color: inherit;">
                <div class="notif-row">
                    <span class="notif-icon">
                        <i class="bi @IconFor(n.Type)"></i>
                    </span>
                    <div class="notif-content">
                        <p class="notif-msg @(n.IsRead ? "" : "fw-semibold")">@n.Message</p>
                        <small class="notif-time" data-time="@n.CreatedDate.ToString("o")"></small>
                    </div>
                    <button type="button" class="btn btn-sm btn-link text-muted notif-delete p-0 ms-1" title="Delete" data-notif-id="@n.Id">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        }
    </div>
}
