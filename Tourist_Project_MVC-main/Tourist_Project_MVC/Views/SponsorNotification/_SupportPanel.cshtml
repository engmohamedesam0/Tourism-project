@model List<Tourist_Project_MVC.Models.SupportTicket>

@if (!Model.Any())
{
    <div class="text-center py-4 text-white-50 w-100">
        <i class="bi bi-inbox" style="font-size:2rem;"></i>
        <p class="mb-0 mt-2">@Localizer["SponsorNotification_NoTickets"].Value</p>
    </div>
}
else
{
    <div class="list-group list-group-flush w-100">
        @foreach (var t in Model)
        {
            <a class="list-group-item list-group-item-action text-white-50"
               asp-controller="SponsorNotification" asp-action="SupportDetails" asp-route-id="@t.Id"
               style="background: transparent;">
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <div class="flex-grow-1 text-truncate">
                        <div class="fw-semibold text-white text-truncate">@t.Subject</div>
                        <span class="badge bg-secondary" style="font-size:0.65rem;">@t.Category</span>
                    </div>
                    <span class="badge bg-@(t.Status == "Open" ? "warning" : t.Status == "Resolved" ? "success" : "info")" style="font-size:0.65rem;">@t.Status</span>
                </div>
            </a>
        }
    </div>
}