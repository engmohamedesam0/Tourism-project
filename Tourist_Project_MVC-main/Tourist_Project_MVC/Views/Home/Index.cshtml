@{
    ViewData["Title"] = "Home";
    ViewData["IsHomePage"] = true;
}

<!-- Masthead / Hero -->
<header class="masthead">
    <div class="container px-4 px-lg-5 d-flex h-100 align-items-center justify-content-center">
        <div class="d-flex justify-content-center">
            <div class="text-center">
                <h1 class="mx-auto my-0 text-uppercase">EGYXPLORE</h1>
                <h2 class="text-white-50 mx-auto mt-2 mb-5">
                    Unlock Hidden Wonders Across Egypt
                </h2>
                <a class="btn btn-primary" asp-controller="Destination" asp-action="Index">
                    <i class="fas fa-map-marker-alt me-2"></i> Explore Now
                </a>
            </div>
        </div>
    </div>
</header>

<!-- About Section -->
<section class="about-section text-center" id="about">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-8">
                <h2 class="text-white mb-4">AI-Powered Smart Tourism Platform</h2>
                <p class="text-white-50">
                    EGYXPLORE combines Artificial Intelligence, GIS, and Gamification
                    to revolutionize tourism in Egypt. Discover hidden archaeological sites,
                    earn rewards, and experience Egypt like never before.
                </p>
            </div>
        </div>
        <img class="img-fluid mt-4" src="~/assets/img/ipad.png" alt="EGYXPLORE App" />
    </div>
</section>

<!-- =============================================
     STATS SECTION - Counter Animation
     ============================================= -->
<section class="stats-section" id="stats">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center text-center">

            <div class="col-12 mb-5">
                <h2 class="text-white text-uppercase"
                    style="letter-spacing: 3px; font-family: 'Varela Round', sans-serif;">
                    Tourism in Numbers
                </h2>
                <hr style="border-color: #C8832A; width: 60px; border-width: 2px; margin: auto;" />
            </div>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <i class="fas fa-monument stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.DestinationCount">0</div>
                    <div class="stat-suffix"></div>
                    <div class="stat-label">Archaeological Sites</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <i class="fas fa-users stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.TouristCount">0</div>
                    <div class="stat-suffix">+</div>
                    <div class="stat-label">Registered Tourists</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <i class="fas fa-route stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.TripPlanCount">0</div>
                    <div class="stat-suffix">+</div>
                    <div class="stat-label">Trip Plans Created</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card">
                    <i class="fas fa-trophy stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.MissionCount">0</div>
                    <div class="stat-suffix"></div>
                    <div class="stat-label">Active Missions</div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Features Section -->
<section class="projects-section bg-light" id="projects">
    <div class="container px-4 px-lg-5">

        <!-- Feature 1 -->
        <div class="row gx-0 mb-4 mb-lg-5 align-items-center">
            <div class="col-xl-8 col-lg-7">
                <img class="img-fluid mb-3 mb-lg-0"
                     src="~/assets/img/bg-masthead.jpg"
                     alt="Hidden Destinations" />
            </div>
            <div class="col-xl-4 col-lg-5">
                <div class="featured-text text-center text-lg-left">
                    <h4>Tourist Attractions in Egypt</h4>
                    <p class="text-black-50 mb-0">
                        The Great Pyramids of Giza were built more than 4,500 years ago as tombs for the ancient Egyptian pharaohs.
                        The Great Pyramid is the oldest of the Seven Wonders of the Ancient World and the only one still standing today.
                        The Pyramids of Giza are one of the most famous tourist attractions in the world.
                        There are many interesting places to visit in Egypt. 
                    </p>
                    <a asp-controller="Destination" asp-action="Index"
                       class="btn btn-primary mt-3 btn-sm">
                        <i class="fas fa-compass me-1"></i> View All Destinations
                    </a>
                </div>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="row gx-0 mb-5 mb-lg-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid"
                     src="~/assets/img/demo-image-01.jpg"
                     alt="AI Trip Planner" />
            </div>
            <div class="col-lg-6">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-left">
                            <h4 class="text-white">
                                <i class="fas fa-robot me-2"></i> AI Trip Planner
                            </h4>
                            <p class="mb-0 text-white-50">
                                Our AI generates personalized itineraries based on your
                                interests, budget, and trip duration. Smart GIS routing
                                finds the optimal path between destinations.
                            </p>
                            <a asp-controller="TripPlan" asp-action="Index"
                               class="btn btn-outline-light mt-3 btn-sm">
                                <i class="fas fa-plane me-1"></i> Plan Your Trip
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="row gx-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid"
                     src="~/assets/img/demo-image-02.jpg"
                     alt="Gamification" />
            </div>
            <div class="col-lg-6 order-lg-first">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-right">
                            <h4 class="text-white">
                                <i class="fas fa-trophy me-2"></i> Gamification & Rewards
                            </h4>
                            <p class="mb-0 text-white-50">
                                Complete missions, earn points, and collect badges on
                                your Digital Heritage Passport. Redeem points for hotel
                                discounts, museum tickets, and exclusive experiences.
                            </p>
                            <a asp-controller="Mission" asp-action="Index"
                               class="btn btn-outline-light mt-3 btn-sm">
                                <i class="fas fa-star me-1"></i> View Missions
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Contact Cards -->
<section class="contact-section bg-black" id="contact">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5">

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-map-marked-alt text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">GIS Powered</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Smart route optimization using ArcGIS Network Analysis
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-robot text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">AI Driven</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Personalized recommendations powered by OpenAI
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-trophy text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">Gamified</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            Missions, badges, and rewards for every explorer
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="social d-flex justify-content-center mt-4">
            <a class="mx-2" href="#"><i class="fab fa-twitter"></i></a>
            <a class="mx-2" href="#"><i class="fab fa-facebook-f"></i></a>
            <a class="mx-2" href="#"><i class="fab fa-github"></i></a>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        /* Stats Section */
        .stats-section {
            background: linear-gradient(135deg, #1a0f00 0%, #2C1A0E 50%, #1a0f00 100%);
            padding: 100px 0;
            border-top: 2px solid #C8832A;
            border-bottom: 2px solid #C8832A;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: 16px;
            padding: 45px 25px 35px;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, transparent, #C8832A, transparent);
                opacity: 0;
                transition: opacity 0.4s ease;
            }

            .stat-card:hover {
                background: rgba(200, 131, 42, 0.08);
                border-color: #C8832A;
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(200, 131, 42, 0.15);
            }

                .stat-card:hover::before {
                    opacity: 1;
                }

        .stat-icon {
            font-size: 2.5rem;
            color: #C8832A;
            margin-bottom: 20px;
            display: block;
        }

        .stat-number {
            font-family: 'Varela Round', sans-serif;
            font-size: 3.5rem;
            font-weight: 900;
            color: #E8A045;
            letter-spacing: 2px;
            display: inline;
            line-height: 1;
        }

        .stat-suffix {
            font-family: 'Varela Round', sans-serif;
            font-size: 2rem;
            font-weight: 900;
            color: #C8832A;
            display: inline;
        }

        .stat-label {
            font-family: 'Nunito', sans-serif;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.55);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 12px;
            display: block;
        }
    </style>

    <script>
        // Counter Animation
        const counters = document.querySelectorAll('.stat-number');

        const animateCounter = (counter) => {
            const target = parseInt(counter.getAttribute('data-target'));
            const duration = 2000;
            const frameRate = 16;
            const totalFrames = duration / frameRate;
            const step = target / totalFrames;
            let current = 0;

            const update = () => {
                current += step;
                if (current < target) {
                    counter.textContent = Math.floor(current).toLocaleString();
                    requestAnimationFrame(update);
                } else {
                    counter.textContent = target.toLocaleString();
                }
            };
            update();
        };

        // Intersection Observer
        const observerOptions = {
            threshold: 0.3,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target;
                    if (!counter.classList.contains('animated')) {
                        counter.classList.add('animated');
                        animateCounter(counter);
                    }
                }
            });
        }, observerOptions);

        counters.forEach(counter => observer.observe(counter));
    </script>
}