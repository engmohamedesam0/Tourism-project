@{
    ViewData["Title"] = "Home";
    ViewData["IsHomePage"] = true;
}

<!-- Masthead / Hero -->
<header class="masthead">
    <div class="container px-4 px-lg-5 d-flex h-100 align-items-center justify-content-center">
        <div class="d-flex justify-content-center">
            <div class="text-center">
                <h1 class="mx-auto my-0 text-uppercase">EGYXPLORE</h1>
                <h2 class="text-white-50 mx-auto mt-2 mb-5">
                    @Localizer["Hero_Subtitle"].Value
                </h2>
                <a class="btn btn-primary" asp-controller="Explore" asp-action="Index">
                    <i class="bi bi-geo-alt-fill me-2"></i> @Localizer["Hero_ExploreBtn"].Value
                </a>
            </div>
        </div>
    </div>
</header>

<!-- About Section -->
<section class="about-section text-center" id="about">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-lg-8">
                <h2 class="text-white mb-4">@Localizer["About_Title"].Value</h2>
                <p class="text-white-50">
                    @Localizer["About_Text"].Value
                </p>
            </div>
        </div>
        <img class="img-fluid mt-4" src="~/assets/img/ipad.png" alt="EGYXPLORE App" />
    </div>
</section>

<!-- =============================================
     STATS SECTION - Counter Animation
     ============================================= -->
<section class="stats-section" id="stats">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center text-center">

            <div class="col-12 mb-5">
                    <h2 class="text-white text-uppercase"
                        style="letter-spacing: 3px; font-family: 'Varela Round', sans-serif;">
                        @Localizer["Stats_Title"].Value
                    </h2>
                <hr style="border-color: #C8832A; width: 60px; border-width: 2px; margin: auto;" />
            </div>
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card stat-blue">
                    <i class="bi bi-geo-alt-fill stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.DestinationCount">0</div>
                    <div class="stat-suffix"></div>
                    <div class="stat-label">@Localizer["Stat_ArchaeologicalSites"].Value</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card stat-green">
                    <i class="bi bi-people-fill stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.TouristCount">0</div>
                    <div class="stat-suffix">+</div>
                    <div class="stat-label">@Localizer["Stat_RegisteredTourists"].Value</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card stat-gold">
                    <i class="bi bi-signpost-split stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.TripPlanCount">0</div>
                    <div class="stat-suffix">+</div>
                    <div class="stat-label">@Localizer["Stat_TripPlansCreated"].Value</div>
                </div>
            </div>

            <div class="col-md-3 col-sm-6 mb-4">
                <div class="stat-card stat-purple">
                    <i class="bi bi-trophy-fill stat-icon"></i>
                    <div class="stat-number" data-target="@ViewBag.MissionCount">0</div>
                    <div class="stat-suffix"></div>
                    <div class="stat-label">@Localizer["Stat_ActiveMissions"].Value</div>
                </div>
            </div>
            </div>
        </div>
    </div>
    </div>
</section>

<!-- Features Section -->
<section class="projects-section bg-light" id="projects">
    <div class="container px-4 px-lg-5">

        <!-- Feature 1 -->
        <div class="row gx-0 mb-4 mb-lg-5 align-items-center">
            <div class="col-xl-8 col-lg-7">
                <img class="img-fluid mb-3 mb-lg-0"
                     src="~/assets/img/bg-masthead.jpg"
                     alt="Hidden Destinations" />
            </div>
            <div class="col-xl-4 col-lg-5">
                <div class="featured-text text-center text-lg-left">
                    <h4>@Localizer["Feature1_Title"].Value</h4>
                    <p class="text-black-50 mb-0">
                        @Localizer["Feature1_Text"].Value
                    </p>
                    <a asp-controller="Explore" asp-action="Index"
                       class="btn btn-primary mt-3 btn-sm">
                         <i class="bi bi-compass-fill me-1"></i> @Localizer["Feature1_Link"].Value
                    </a>
                </div>
            </div>
        </div>

        <!-- Feature 2 -->
        <div class="row gx-0 mb-5 mb-lg-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid"
                     src="~/assets/img/demo-image-01.jpg"
                     alt="AI Trip Planner" />
            </div>
            <div class="col-lg-6">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-left">
                            <h4 class="text-white">
                                <i class="bi bi-stars me-2"></i> @Localizer["Feature2_Title"].Value
                            </h4>
                            <p class="mb-0 text-white-50">
                                @Localizer["Feature2_Text"].Value
                            </p>
                            <a asp-controller="Trip" asp-action="Index"
                               class="btn btn-outline-light mt-3 btn-sm">
                                 <i class="bi bi-airplane me-1"></i> @Localizer["Feature2_Link"].Value
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feature 3 -->
        <div class="row gx-0 justify-content-center">
            <div class="col-lg-6">
                <img class="img-fluid"
                     src="~/assets/img/demo-image-02.jpg"
                     alt="Gamification" />
            </div>
            <div class="col-lg-6 order-lg-first">
                <div class="bg-black text-center h-100 project">
                    <div class="d-flex h-100">
                        <div class="project-text w-100 my-auto text-center text-lg-right">
                            <h4 class="text-white">
                                <i class="bi bi-trophy-fill me-2"></i> @Localizer["Feature3_Title"].Value
                            </h4>
                            <p class="mb-0 text-white-50">
                                @Localizer["Feature3_Text"].Value
                            </p>
                            <a asp-controller="Mission" asp-action="Index"
                               class="btn btn-outline-light mt-3 btn-sm">
                                <i class="bi bi-star-fill me-1"></i> @Localizer["Feature3_Link"].Value
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- Contact Cards -->
<section class="contact-section bg-black" id="contact">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5">

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-map-fill text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">@Localizer["Contact_GIS"].Value</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            @Localizer["Contact_GIS_Text"].Value
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-stars text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">@Localizer["Contact_AI"].Value</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            @Localizer["Contact_AI_Text"].Value
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3 mb-md-0">
                <div class="card py-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-trophy-fill text-primary mb-2"></i>
                        <h4 class="text-uppercase m-0">@Localizer["Contact_Gamified"].Value</h4>
                        <hr class="my-4 mx-auto" />
                        <div class="small text-black-50">
                            @Localizer["Contact_Gamified_Text"].Value
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="social d-flex justify-content-center mt-4">
            <a class="mx-2" href="#"><i class="bi bi-twitter"></i></a>
            <a class="mx-2" href="#"><i class="bi bi-facebook"></i></a>
            <a class="mx-2" href="#"><i class="bi bi-github"></i></a>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        /* Stats Section */
        .stats-section {
            background: linear-gradient(135deg, #1a0f00 0%, var(--egy-dark) 50%, #1a0f00 100%);
            padding: 100px 0;
            border-top: 2px solid #C8832A;
            border-bottom: 2px solid #C8832A;
        }

        /* Hero stat numbers stay prominent on the dark section. */
        .stats-section .stat-number {
            font-size: 2.8rem;
        }

        .stats-section .stat-label {
            color: #6b7280;
        }
    </style>

    <script>
        // Counter Animation
        const counters = document.querySelectorAll('.stat-number');

        const animateCounter = (counter) => {
            const target = parseInt(counter.getAttribute('data-target'));
            const duration = 2000;
            const frameRate = 16;
            const totalFrames = duration / frameRate;
            const step = target / totalFrames;
            let current = 0;

            const update = () => {
                current += step;
                if (current < target) {
                    counter.textContent = Math.floor(current).toLocaleString();
                    requestAnimationFrame(update);
                } else {
                    counter.textContent = target.toLocaleString();
                }
            };
            update();
        };

        // Intersection Observer
        const observerOptions = {
            threshold: 0.3,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target;
                    if (!counter.classList.contains('animated')) {
                        counter.classList.add('animated');
                        animateCounter(counter);
                    }
                }
            });
        }, observerOptions);

        counters.forEach(counter => observer.observe(counter));
    </script>
}