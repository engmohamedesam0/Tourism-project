@{
    ViewData["Title"] = "Sponsor Account Status";
    var status = (string?)ViewData["Status"];
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header py-3" style="background: linear-gradient(135deg, var(--egy-dark), #C8832A);">
            <h4 class="text-white mb-0">
                <i class="bi bi-hourglass-split me-2"></i> Sponsor Account Status
            </h4>
        </div>
        <div class="card-body p-4 text-center">
            @if (status == "submitted")
            {
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Request Submitted</h5>
                <p class="text-muted">
                    Thank you for signing up as a Sponsor. Your account request is now
                    <strong>pending Admin approval</strong>. You will be able to access the
                    Sponsor portal once an Administrator approves your request.
                </p>
            }
            else if (status == "pending")
            {
                <i class="bi bi-hourglass-split text-warning" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Approval Pending</h5>
                <p class="text-muted">
                    Your sponsor account request is <strong>pending admin approval</strong>.
                    You cannot access the portal yet. Please try signing in again once an
                    Administrator has reviewed your request.
                </p>
            }
            else if (status == "rejected")
            {
                <i class="bi bi-x-circle-fill text-danger" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Request Not Approved</h5>
                <p class="text-muted">
                    Unfortunately, your sponsor request was <strong>not approved</strong>.
                    You are not able to access the Sponsor portal. If you believe this is a
                    mistake, please contact support.
                </p>
            }
            else
            {
                <p class="text-muted">Your sponsor account request status is unavailable.</p>
            }

            <div class="d-flex gap-2 justify-content-center mt-4">
                <a asp-action="Login" class="btn btn-outline-secondary">Back to Login</a>
                <a asp-action="Index" asp-controller="Home" class="btn btn-success">Go to Home</a>
            </div>
        </div>
    </div>
</div>
