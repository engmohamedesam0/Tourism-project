@model Tourist_Project_MVC.Models.Reward

@{
    ViewData["Title"] = "Reward Details";
}

@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4" style="max-width: 800px;">
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <div class="card-header py-3"
                 style="background: linear-gradient(135deg, #2C1A0E, #C8832A);">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="text-white mb-0">
                        <i class="bi bi-gift-fill me-2"></i> @Model.Title
                    </h4>
                    <span class="badge bg-warning text-dark fs-6">
                        @Model.RewardType
                    </span>
                </div>
            </div>

            <div class="card-body p-4">

                <div class="row text-center mb-4">
                    <div class="col-4">
                        <div class="stat-mini-card">
                            <i class="bi bi-star-fill text-warning"></i>
                            <div class="stat-mini-number">@Model.PointsRequired</div>
                            <div class="stat-mini-label">Points Required</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini-card">
                            <i class="bi bi-box-seam-fill text-success"></i>
                            <div class="stat-mini-number">@Model.QuantityAvailable</div>
                            <div class="stat-mini-label">Available</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-mini-card">
                            <i class="bi bi-calendar-x-fill text-danger"></i>
                            <div class="stat-mini-number">
                                @Model.ExpirationDate.ToShortDateString()
                            </div>
                            <div class="stat-mini-label">Expires</div>
                        </div>
                    </div>
                </div>

                <hr />

                <dl class="row">
                    <dt class="col-sm-3 text-muted">Description</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3 text-muted">Sponsor</dt>
                    <dd class="col-sm-9">
                        <i class="bi bi-building me-1" style="color: var(--egy-primary);"></i>
                        @Model.Sponsor?.Name
                    </dd>
                </dl>
            </div>

            <div class="card-footer bg-white d-flex gap-2 justify-content-end">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-fill me-1"></i> Edit
                </a>
                }
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <style>
        .stat-mini-card {
            background: #FDF6EC;
            border: 1px solid #E8A045;
            border-radius: 12px;
            padding: 15px 10px;
        }

        .stat-mini-number {
            font-family: 'Cinzel', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: #2C1A0E;
            margin: 6px 0 2px;
        }

        .stat-mini-label {
            font-size: 0.75rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
}