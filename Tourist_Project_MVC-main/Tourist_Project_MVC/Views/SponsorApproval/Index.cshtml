@using Tourist_Project_MVC.View_Model
@model List<SponsorApprovalListItem>

@{
    ViewData["Title"] = Localizer["SponsorApproval_IndexTitle"].Value;
}

<h1 class="page-title">@Localizer["SponsorApproval_IndexHeading"].Value</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle-fill me-2"></i> @Localizer["SponsorApproval_EmptyMessage"].Value
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>@Localizer["SponsorApproval_ColApplicant"].Value</th>
                    <th>@Localizer["SponsorApproval_ColEmail"].Value</th>
                    <th>@Localizer["SponsorApproval_ColPhone"].Value</th>
                    <th>@Localizer["SponsorApproval_ColNationality"].Value</th>
                    <th>@Localizer["SponsorApproval_ColRequested"].Value</th>
                    <th>@Localizer["SponsorApproval_ColStatus"].Value</th>
                    <th>@Localizer["SponsorApproval_ColActions"].Value</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.ApplicantName</td>
                        <td>@item.Email</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.Nationality</td>
                        <td>@item.RequestedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge rounded-pill text-bg-warning">@Localizer["SponsorApproval_Status_Pending"].Value</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge rounded-pill text-bg-success">@Localizer["SponsorApproval_Status_Approved"].Value</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill text-bg-danger">@Localizer["SponsorApproval_Status_Rejected"].Value</span>
                            }
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <form asp-action="Approve" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg me-1"></i> @Localizer["SponsorApproval_ApproveBtn"].Value
                                    </button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-lg me-1"></i> @Localizer["SponsorApproval_RejectBtn"].Value
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">@Localizer["SponsorApproval_Reviewed"].Value</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}