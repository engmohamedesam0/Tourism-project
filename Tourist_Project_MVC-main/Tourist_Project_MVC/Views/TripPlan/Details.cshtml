@model Tourist_Project_MVC.Models.TripPlan

@{
    ViewData["Title"] = @Localizer["TripPlan_TripDetails"].Value;
}

<div class="container mt-4" style="max-width: 900px;">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

        <div class="card-header py-3"
             style="background: linear-gradient(135deg, var(--egy-dark), #C8832A);">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="text-white mb-0">
                    <i class="bi bi-map-fill me-2"></i> @Model.Title
                </h4>
                <div class="d-flex gap-2">
                    @{
                        var statusClass = Model.Status switch
                        {
                            "Active" => "badge-status-active",
                            "Paused" => "badge-status-pending",
                            "Completed" => "badge-status-completed",
                            _ => "badge-status-active"
                        };
                    }
                    <span class="badge-status @statusClass">@Model.Status</span>
                    <span class="badge bg-warning text-dark">
                        @((Model.EndDate - Model.StartDate).Days) @Localizer["TripPlan_Days"].Value
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body p-4">

            <div class="row text-center mb-4">
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-person-fill text-primary"></i>
                        <div class="stat-mini-number">@Model.Tourist?.Name</div>
                        <div class="stat-mini-label">@Localizer["TripPlan_Tourist"].Value</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-calendar-check-fill text-success"></i>
                        <div class="stat-mini-number">@Model.StartDate.ToShortDateString()</div>
                        <div class="stat-mini-label">@Localizer["TripPlan_StartDate"].Value</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="stat-mini-card">
                        <i class="bi bi-calendar-x-fill text-danger"></i>
                        <div class="stat-mini-number">@Model.EndDate.ToShortDateString()</div>
                        <div class="stat-mini-label">@Localizer["TripPlan_EndDate"].Value</div>
                    </div>
                </div>
            </div>

            <hr />

            <h5 class="mb-3">
                <i class="bi bi-geo-alt-fill me-2" style="color: var(--egy-primary);"></i>
                @Localizer["TripPlan_Destinations"].Value
            </h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle destinations-table">
                    <thead>
                        <tr>
                            <th>@Localizer["TripPlan_Order"].Value</th>
                            <th>@Localizer["TripPlan_Destination"].Value</th>
                            <th>@Localizer["TripPlan_City"].Value</th>
                            <th>@Localizer["TripPlan_Arrival"].Value</th>
                            <th>@Localizer["TripPlan_Departure"].Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var td in Model.TripDestinations.OrderBy(t => t.Visit_Order))
                        {
                            <tr>
                                <td>
                                    <span class="badge-category">@td.Visit_Order</span>
                                </td>
                                <td><div class="fw-bold">@td.Destination?.Name</div></td>
                                <td>@td.Destination?.City</td>
                                <td>@td.ArrivalDate.ToShortDateString()</td>
                                <td>@td.DepartureDate.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white d-flex gap-2 justify-content-end">
          @if (User.IsInRole("Admin"))
              {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-fill me-1"></i> @Localizer["TripPlan_Edit"].Value
            </a>
              }
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-left me-1"></i> @Localizer["TripPlan_Back"].Value
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .stat-mini-card {
            background: #FDF6EC;
            border: 1px solid #E8A045;
            border-radius: 12px;
            padding: 15px 10px;
        }

        .stat-mini-number {
            font-family: 'Cinzel',sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--egy-dark);
            margin: 6px 0 2px;
        }

        .stat-mini-label {
            font-size: 0.75rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .destinations-table {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

        .badge-category {
            background-color: #FDF6EC;
            color: var(--egy-primary);
            border: 1px solid var(--egy-accent);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .badge-status {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .badge-status-active {
            background-color: #d4edda;
            color: #155724;
        }

        .badge-status-pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .badge-status-completed {
            background-color: #d1ecf1;
            color: #0c5460;
        }
    </style>
}