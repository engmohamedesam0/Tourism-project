@model Tourist_Project_MVC.Models.Mission

@{
    ViewData["Title"] = Localizer["Mission_Page_Title_Delete"].Value;
}

@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-5 mb-5" style="max-width: 650px;">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden delete-card">
            <!-- Card Header -->
            <div class="card-header py-4 text-center header-gradient">
                <div class="delete-icon-wrapper mb-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h3 class="text-white mb-0 font-cinzel">
                    @Localizer["Mission_Page_Heading_Delete"].Value
                </h3>
                <p class="text-white-50 small mb-0 mt-1">This action cannot be undone.</p>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4 p-md-5 bg-white">
                <div class="alert alert-warning border-0 rounded-3 mb-4 d-flex align-items-center gap-3">
                    <i class="bi bi-info-circle-fill fs-4 text-warning"></i>
                    <div>
                        @Localizer["Mission_Delete_Confirm"].Value
                        <strong class="text-dark">@Model.Title</strong>
                    </div>
                </div>

                <h5 class="section-title mb-3 font-cinzel text-dark-egy">Mission Summary</h5>
                <div class="summary-box p-3 rounded-3 mb-4">
                    <div class="row g-2">
                        <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["Mission_Label_Title"].Value:</div>
                        <div class="col-sm-8 text-dark fw-semibold">@Model.Title</div>

                        <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["Mission_Label_Type"].Value:</div>
                        <div class="col-sm-8 text-dark">
                            <span class="badge badge-mission-type">@Model.MissionType</span>
                        </div>

                        <div class="col-sm-4 fw-bold text-muted-egy">@Localizer["Mission_Label_Points"].Value:</div>
                        <div class="col-sm-8 text-dark fw-bold text-primary-egy">@Model.PointsReward pts</div>
                    </div>
                </div>

                <!-- Form Actions -->
                <form asp-action="Delete" method="post" class="mt-4 pt-3 border-top border-light">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-end">
                        <a asp-action="Index" class="btn btn-cancel-custom px-4 py-2.5 order-2 order-sm-1">
                            <i class="bi bi-x-lg me-1"></i> @Localizer["Mission_Button_Cancel"].Value
                        </a>
                        <button type="submit" class="btn btn-delete-custom px-4 py-2.5 order-1 order-sm-2 shadow-sm">
                            <i class="bi bi-trash-fill me-1"></i> @Localizer["Mission_Button_ConfirmDelete"].Value
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <style>
        .delete-card {
            border: 1px solid rgba(220, 53, 69, 0.15) !important;
            box-shadow: 0 15px 35px rgba(30, 18, 10, 0.08) !important;
        }

        .header-gradient {
            background: linear-gradient(135deg, var(--egy-dark) 0%, #4c1a1e 100%);
            border-bottom: 3px solid #dc3545;
        }

        .delete-icon-wrapper {
            font-size: 2.5rem;
            color: #dc3545;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.08); }
            100% { transform: scale(1); }
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
            letter-spacing: 1px;
        }

        .text-dark-egy {
            color: var(--egy-dark);
        }

        .text-primary-egy {
            color: var(--egy-primary);
        }

        .text-muted-egy {
            color: var(--egy-text-muted);
            font-size: 0.9rem;
        }

        .summary-box {
            background-color: #f8f9fa;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .badge-mission-type {
            background-color: rgba(200, 131, 42, 0.1);
            color: var(--egy-muted-gold);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.35rem 0.75rem;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* Buttons Styling */
        .btn-delete-custom {
            background-color: #dc3545;
            color: #ffffff;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-delete-custom:hover {
            background-color: #bb2d3b;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(220, 53, 69, 0.2);
            color: #ffffff;
        }

        .btn-cancel-custom {
            background-color: #f8f9fa;
            color: #495057;
            border: 1px solid #dee2e6;
            border-radius: var(--radius-md);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-cancel-custom:hover {
            background-color: #e9ecef;
            color: #212529;
            transform: translateY(-2px);
        }
    </style>
}
