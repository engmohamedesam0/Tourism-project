@model Tourist_Project_MVC.Models.Mission

@{
    ViewData["Title"] = @Localizer["Mission_Page_Title_Delete"].Value;
}
@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-4">
        <h2 class="text-danger">🗑️ @Localizer["Mission_Page_Heading_Delete"].Value</h2>
        <hr />
        <p class="lead">@Localizer["Mission_Delete_Confirm"].Value <strong>@Model.Title</strong>?</p>

        <dl class="row">
            <dt class="col-sm-3">@Localizer["Mission_Label_Title"].Value</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">@Localizer["Mission_Label_Type"].Value</dt>
            <dd class="col-sm-9">@Model.MissionType</dd>


            <dt class="col-sm-3">@Localizer["Mission_Label_Points"].Value</dt>
            <dd class="col-sm-9">@Model.PointsReward</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">@Localizer["Mission_Button_ConfirmDelete"].Value</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["Mission_Button_Cancel"].Value</a>
        </form>
    </div>

}
