@model IEnumerable<Tourist_Project_MVC.Models.Mission>
@{
    ViewData["Title"] = Localizer["Mission_PageTitle"].Value;
}

<div class="container-fluid mt-4 px-md-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4 page-header-section">
        <div>
            <h2 class="page-title text-uppercase mb-1">
                <span class="header-icon">🎯</span> @Localizer["Mission_PageTitle"].Value
            </h2>
            <p class="text-muted small mb-0">
                @Localizer["Mission_Total"].Value: <span class="badge bg-secondary">@ViewBag.AllCount</span> @Localizer["Mission_Unit"].Value
            </p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-egy-success px-4 py-2 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> @Localizer["Mission_CreateButton"].Value
            </a>
        }
    </div>

    <!-- Stat boxes -->
    @await Html.PartialAsync("_StatBoxRow", (List<Tourist_Project_MVC.View_Model.StatBoxItem>)ViewBag.StatBoxes)

    <!-- Filter Bar Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 filter-card">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" id="filterForm">
                <div class="row g-3 align-items-center">
                    <div class="col-md-7 col-lg-8">
                        <div class="input-group search-input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="search"
                                   id="missionSearchInput"
                                   class="form-control border-start-0 ps-0"
                                   placeholder="@Localizer["Mission_SearchPlaceholder"].Value"
                                   value="@ViewBag.Search" />
                            @if (!string.IsNullOrEmpty(ViewBag.Search))
                            {
                                <button type="button" class="btn bg-transparent border-0 text-muted clear-search-btn" onclick="clearSearch()">
                                    <i class="bi bi-x-circle-fill"></i>
                                </button>
                            }
                            <input type="hidden" name="missionType" value="@ViewBag.MissionType" />
                        </div>
                    </div>
                    <div class="col-md-5 col-lg-4">
                        <div class="input-group select-input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-muted">
                                <i class="bi bi-funnel"></i>
                            </span>
                            <select class="form-select border-start-0 ps-0 filter-select" onchange="window.location.href=this.value">
                                <option value="@Url.Action("Index", new { search = ViewBag.Search })">
                                    @Localizer["Mission_AllTypes"].Value
                                </option>
                                @foreach (var type in ViewBag.MissionTypes as List<string> ?? new List<string>())
                                {
                                    var url = Url.Action("Index", new { search = ViewBag.Search, missionType = type });
                                    bool isSelected = ViewBag.MissionType == type;
                                    <option value="@url" selected="@(isSelected ? "selected" : null)">@type</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden table-card">
        <div class="table-responsive">
            <table class="table align-middle custom-mission-table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">@Localizer["Mission_Number"].Value</th>
                        <th>@Localizer["Mission_TitleColumn"].Value</th>
                        <th>@Localizer["Mission_TypeColumn"].Value</th>
                        <th>@Localizer["Mission_DestinationColumn"].Value</th>
                        <th>@Localizer["Mission_PointsRewardColumn"].Value</th>
                        <th class="pe-4 text-end">@Localizer["Mission_ActionsColumn"].Value</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold text-secondary-egy">#@i.ToString("D2")</td>
                            <td>
                                <div class="fw-bold text-dark font-cinzel">@item.Title</div>
                                <div class="text-muted small text-truncate" style="max-width: 300px;" title="@item.Description">
                                    @item.Description
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-mission-type">
                                    <i class="bi bi-tag-fill me-1"></i> @item.MissionType
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>
                                    <span class="fw-semibold">@item.Destination?.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-points-reward">
                                    <i class="bi bi-star-fill text-warning me-1"></i>
                                    @item.PointsReward @Localizer["Mission_Pts"].Value
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-action-view" title="@Localizer["Mission_Details"].Value">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-action-edit" title="@Localizer["Mission_Edit"].Value">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-action-delete" title="@Localizer["Mission_Delete"].Value">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark border py-1.5 px-3">
                                        <i class="bi bi-lock me-1"></i> @Localizer["Mission_GuestsOnly"].Value
                                    </span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5 empty-state-container">
                <div class="empty-state-icon mb-3">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <h5 class="fw-bold font-cinzel">@Localizer["Mission_NoMissions"].Value</h5>
                <p class="text-muted small">Try adjusting your filters or search term.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        .page-header-section {
            border-bottom: 2px solid var(--egy-primary);
            padding-bottom: 1rem;
        }
        
        .text-secondary-egy {
            color: var(--egy-muted-gold);
        }

        .btn-egy-success {
            background-color: var(--egy-success);
            color: #ffffff;
            border: none;
            border-radius: var(--radius-md);
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .btn-egy-success:hover {
            background-color: var(--egy-success-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(46, 125, 50, 0.25);
            color: #ffffff;
        }

        /* Filter Card */
        .filter-card {
            background-color: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.15) !important;
            box-shadow: var(--shadow-soft) !important;
        }

        .search-input-group, .select-input-group {
            background-color: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-md);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .search-input-group:focus-within, .select-input-group:focus-within {
            border-color: var(--egy-primary);
            box-shadow: 0 0 0 3px rgba(200, 131, 42, 0.15);
        }

        .search-input-group input, .select-input-group select {
            border: none !important;
            box-shadow: none !important;
            padding-top: 0.6rem;
            padding-bottom: 0.6rem;
        }

        .search-input-group input:focus, .select-input-group select:focus {
            outline: none !important;
        }

        /* Table Design */
        .table-card {
            border: 1px solid rgba(200, 131, 42, 0.1) !important;
            box-shadow: var(--shadow-medium) !important;
        }

        .custom-mission-table thead {
            background-color: var(--egy-dark);
            color: #ffffff;
        }

        .custom-mission-table thead th {
            font-family: 'Cinzel', serif;
            font-weight: 600;
            letter-spacing: 0.5px;
            padding-top: 1.1rem;
            padding-bottom: 1.1rem;
            border: none;
        }

        .custom-mission-table tbody tr {
            border-bottom: 1px solid rgba(200, 131, 42, 0.08);
            transition: background-color 0.2s ease;
        }

        .custom-mission-table tbody tr:last-child {
            border-bottom: none;
        }

        .custom-mission-table tbody tr:hover {
            background-color: rgba(200, 131, 42, 0.04);
        }

        .custom-mission-table td {
            padding-top: 1.1rem;
            padding-bottom: 1.1rem;
        }

        /* Badges */
        .badge-mission-type {
            background-color: rgba(200, 131, 42, 0.1);
            color: var(--egy-muted-gold);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.5rem 0.8rem;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .badge-points-reward {
            background-color: rgba(232, 160, 69, 0.15);
            color: var(--egy-dark);
            border: 1px solid var(--egy-accent);
            border-radius: var(--radius-md);
            padding: 0.5rem 0.8rem;
            font-size: 0.82rem;
            font-weight: 700;
        }

        /* Action Buttons */
        .btn-action-view, .btn-action-edit, .btn-action-delete {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-md);
            border: 1px solid;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }

        .btn-action-view {
            color: #0d6efd;
            border-color: rgba(13, 110, 253, 0.25);
        }
        .btn-action-view:hover {
            background-color: #0d6efd;
            color: #ffffff;
            border-color: #0d6efd;
            transform: translateY(-2px);
        }

        .btn-action-edit {
            color: var(--egy-primary);
            border-color: rgba(200, 131, 42, 0.25);
        }
        .btn-action-edit:hover {
            background-color: var(--egy-primary);
            color: #ffffff;
            border-color: var(--egy-primary);
            transform: translateY(-2px);
        }

        .btn-action-delete {
            color: #dc3545;
            border-color: rgba(220, 53, 69, 0.25);
        }
        .btn-action-delete:hover {
            background-color: #dc3545;
            color: #ffffff;
            border-color: #dc3545;
            transform: translateY(-2px);
        }

        /* Empty State */
        .empty-state-container {
            background-color: #ffffff;
            border-radius: var(--radius-lg);
        }

        .empty-state-icon {
            font-size: 3rem;
            color: var(--egy-primary);
            animation: bounce 2s infinite;
        }

        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
        }
    </style>
    <script>
        document.getElementById('missionSearchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('filterForm').submit();
            }
        });

        function clearSearch() {
            document.getElementById('missionSearchInput').value = '';
            document.getElementById('filterForm').submit();
        }
    </script>
}