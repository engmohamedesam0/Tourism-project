@model Tourist_Project_MVC.Models.Mission

@{
    ViewData["Title"] = Localizer["Mission_Page_Title_Details"].Value;
}

@if (User.Identity.IsAuthenticated)
{
    <div class="container mt-5 mb-5" style="max-width: 850px;">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden details-card">
            <!-- Card Header -->
            <div class="card-header py-4 header-gradient">
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                    <div>
                        <span class="text-white-50 text-uppercase small tracking-wider fw-bold">Mission Details</span>
                        <h3 class="text-white mb-0 mt-1 font-cinzel">
                            <i class="bi bi-trophy-fill me-2 text-warning-egy"></i> @Model.Title
                        </h3>
                    </div>
                    <span class="badge badge-mission-type-lg">
                        <i class="bi bi-tag-fill me-1"></i> @Model.MissionType
                    </span>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4 p-md-5 bg-white">
                <!-- Mini Stats Grid -->
                <div class="row g-3 mb-5 text-center">
                    <!-- Points -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-points">
                            <div class="stat-icon-wrapper"><i class="bi bi-star-fill"></i></div>
                            <div class="stat-value font-cinzel">@Model.PointsReward</div>
                            <div class="stat-label">@Localizer["Mission_Label_Points"].Value</div>
                        </div>
                    </div>
                    <!-- Destination -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-dest">
                            <div class="stat-icon-wrapper"><i class="bi bi-geo-alt-fill"></i></div>
                            <div class="stat-value text-truncate px-2" title="@Model.Destination?.Name">@Model.Destination?.Name</div>
                            <div class="stat-label">@Localizer["Mission_Label_Destination"].Value</div>
                        </div>
                    </div>
                    <!-- In Progress -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-progress">
                            <div class="stat-icon-wrapper"><i class="bi bi-hourglass-split"></i></div>
                            <div class="stat-value font-cinzel">
                                @(Model.UserMissions?.Count(um => um.Status == "In Progress") ?? 0)
                            </div>
                            <div class="stat-label">@Localizer["Mission_Status_InProgress"].Value</div>
                        </div>
                    </div>
                    <!-- Completed -->
                    <div class="col-6 col-md-3">
                        <div class="stat-card-custom stat-completed">
                            <div class="stat-icon-wrapper"><i class="bi bi-check-circle-fill"></i></div>
                            <div class="stat-value font-cinzel">
                                @(Model.UserMissions?.Count(um => um.Status == "Completed") ?? 0)
                            </div>
                            <div class="stat-label">@Localizer["Mission_Status_Completed"].Value</div>
                        </div>
                    </div>
                </div>

                <!-- Structured Details -->
                <div class="details-section">
                    <h5 class="section-title mb-4 font-cinzel text-dark-egy">
                        <i class="bi bi-info-circle-fill me-2 text-primary-egy"></i> Information
                    </h5>
                    
                    <div class="detail-row">
                        <div class="row align-items-start py-3 border-bottom">
                            <div class="col-sm-3 fw-bold text-muted-egy">@Localizer["Mission_Label_Type"].Value</div>
                            <div class="col-sm-9">
                                <span class="badge badge-mission-type">@Model.MissionType</span>
                            </div>
                        </div>
                        
                        <div class="row align-items-start py-3">
                            <div class="col-sm-3 fw-bold text-muted-egy">@Localizer["Mission_Label_Description"].Value</div>
                            <div class="col-sm-9 text-dark lh-base description-text">@Model.Description</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card Footer -->
            <div class="card-footer bg-light p-4 d-flex flex-column flex-sm-row gap-3 justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-back-custom px-4 py-2.5">
                    <i class="bi bi-arrow-left me-1"></i> @Localizer["Mission_Button_Back"].Value
                </a>
                
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit-custom px-4 py-2.5 shadow-sm">
                        <i class="bi bi-pencil-fill me-1"></i> @Localizer["Mission_Button_Edit"].Value
                    </a>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <style>
        .details-card {
            border: 1px solid rgba(200, 131, 42, 0.15) !important;
            box-shadow: 0 15px 35px rgba(30, 18, 10, 0.08) !important;
        }

        .header-gradient {
            background: linear-gradient(135deg, var(--egy-dark) 0%, #3a2212 50%, var(--egy-primary) 100%);
            border-bottom: 3px solid var(--egy-accent);
        }

        .text-warning-egy {
            color: var(--egy-accent) !important;
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
            letter-spacing: 0.5px;
        }

        .tracking-wider {
            letter-spacing: 1.5px;
        }

        .badge-mission-type-lg {
            background-color: rgba(255, 255, 255, 0.15);
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.6rem 1.2rem;
            font-size: 0.88rem;
            font-weight: 600;
        }

        /* Stat Cards */
        .stat-card-custom {
            background: #ffffff;
            border: 1px solid rgba(200, 131, 42, 0.15);
            border-radius: var(--radius-lg);
            padding: 1.25rem 0.75rem;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            box-shadow: var(--shadow-soft);
        }

        .stat-card-custom:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-large);
            border-color: var(--egy-primary);
        }

        .stat-icon-wrapper {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin-bottom: 0.75rem;
            font-size: 1.25rem;
        }

        /* Points Theme */
        .stat-points .stat-icon-wrapper {
            background-color: rgba(232, 160, 69, 0.15);
            color: var(--egy-accent);
        }
        .stat-points {
            border-top: 3px solid var(--egy-accent);
        }

        /* Dest Theme */
        .stat-dest .stat-icon-wrapper {
            background-color: rgba(220, 53, 69, 0.1);
            color: #dc3545;
        }
        .stat-dest {
            border-top: 3px solid #dc3545;
        }

        /* Progress Theme */
        .stat-progress .stat-icon-wrapper {
            background-color: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
        }
        .stat-progress {
            border-top: 3px solid #0d6efd;
        }

        /* Completed Theme */
        .stat-completed .stat-icon-wrapper {
            background-color: rgba(46, 125, 50, 0.1);
            color: var(--egy-success);
        }
        .stat-completed {
            border-top: 3px solid var(--egy-success);
        }

        .stat-value {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--egy-dark);
            margin-bottom: 0.25rem;
            max-width: 100%;
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--egy-text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Detail List */
        .text-dark-egy {
            color: var(--egy-dark);
        }
        
        .text-primary-egy {
            color: var(--egy-primary);
        }

        .text-muted-egy {
            color: var(--egy-text-muted);
            font-size: 0.95rem;
        }

        .badge-mission-type {
            background-color: rgba(200, 131, 42, 0.1);
            color: var(--egy-muted-gold);
            border: 1px solid rgba(200, 131, 42, 0.25);
            border-radius: var(--radius-pill);
            padding: 0.4rem 0.8rem;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .description-text {
            white-space: pre-line;
            font-size: 1rem;
        }

        /* Footer buttons */
        .btn-back-custom {
            background-color: #f8f9fa;
            color: #495057;
            border: 1px solid #dee2e6;
            border-radius: var(--radius-pill);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-back-custom:hover {
            background-color: #e9ecef;
            color: #212529;
            transform: translateX(-3px);
        }

        .btn-edit-custom {
            background-color: var(--egy-primary);
            color: #ffffff;
            border: none;
            border-radius: var(--radius-pill);
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-edit-custom:hover {
            background-color: var(--egy-accent);
            transform: translateY(-2px);
            box-shadow: var(--shadow-glow-gold);
            color: #ffffff;
        }
    </style>
}
